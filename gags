-- velocity fly setup
local bv = Instance.new("BodyVelocity")
bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
bv.Velocity = Vector3.new(0,0,0)
bv.Parent = hrp

local bg = Instance.new("BodyGyro")
bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
bg.P = 9e4
bg.Parent = hrp

-- fixed bounds
local minX, maxX = -5533, -3609
local minZ, maxZ = -2610, -898
local flyY = 1623 -- just above floor
local flySpeed = 80 -- studs per second, smooth enough for streaming
local stepSize = 180 -- wider steps since velocity movement streams better

-- snake waypoints
local waypoints = {}
local row = 0
local z = minZ
while z <= maxZ do
    local goRight = (row % 2 == 0)
    local xStart = goRight and minX or maxX
    local xEnd = goRight and maxX or minX
    local xStep = goRight and stepSize or -stepSize
    local x = xStart
    repeat
        table.insert(waypoints, Vector3.new(x, flyY, z))
        x = x + xStep
    until (goRight and x > xEnd) or (not goRight and x < xEnd)
    z = z + stepSize
    row = row + 1
end

