stopBtn.MouseButton1Click:Connect(function()
    stopped = true
    bv.Velocity = Vector3.new(0,0,0)
end)

print("waypoints: " .. #waypoints .. " | speed: " .. flySpeed .. " studs/s")

local startTime = os.time()

-- fly using velocity between waypoints
for i, wp in pairs(waypoints) do
    if stopped then break end

    -- point toward waypoint
    local dir = (wp - hrp.Position)
    local dist = dir.Magnitude

    if dist > 5 then
        bv.Velocity = dir.Unit * flySpeed
        bg.CFrame = CFrame.lookAt(hrp.Position, wp)

        -- wait until we reach the waypoint
        local timeout = dist / flySpeed + 2
        local elapsed = 0
        repeat
            task.wait(0.05)
            elapsed = elapsed + 0.05
            dist = (wp - hrp.Position).Magnitude
        until dist < 15 or elapsed > timeout or stopped
    end

    -- pause briefly at each waypoint for streaming
    bv.Velocity = Vector3.new(0,0,0)
    task.wait(0.15)

    if i % 5 == 0 then
        local pct = math.floor(i/#waypoints*100)
        local remaining = math.ceil((#waypoints - i) * (180/flySpeed) * 0.15)
        lbl.Text = string.format("🔍 %d%% (%d/%d) | ~%ds left", pct, i, #waypoints, remaining)
        lbl2.Text = string.format("🥚 Eggs: %d | Rooms: %d", #found, #genBackrooms:GetChildren())
    end
end

bv:Destroy()
bg:Destroy()
roomWatcher:Disconnect()
noclip:Disconnect()
hum.PlatformStand = false
task.wait(1)

table.sort(found, function(a,b) return a.multi < b.multi end)
lbl.Text = "✅ " .. #found .. " eggs | " .. #genBackrooms:GetChildren() .. " rooms | " .. (os.time()-startTime) .. "s"
task.wait(3)
sg:Destroy()

print("=== FINAL ===")
for _, e in pairs(found) do
    print(e.name .. " [" .. e.multi .. "x] deep=" .. tostring(e.deep))
end

