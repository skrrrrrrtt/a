-- Safe function to check if player has at least 1 key
local function hasKey()
    local has = false
    pcall(function()
        local keyNames = {"Deep Daydream Key", "Backrooms Crayon Key", "Deep Backrooms Crayon Key"}
        for _, name in ipairs(keyNames) do
            local keyItem = MiscItem(name)
            if keyItem and keyItem.HasAny and keyItem:HasAny() then
                has = true
                break
            end
        end
    end)
    return has
end

