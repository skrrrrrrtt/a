-- Helper to check if a boss room is near a position
local function getBossRoomNearPosition(pos)
    for _, room in ipairs(GeneratedBackrooms:GetChildren()) do
        local roomId = room:GetAttribute("RoomID")
        if roomId == "GameMastersStage" or roomId == "GameMastersOffice" then
            local dist = (room:GetPivot().Position - pos).Magnitude
            if dist < 150 then -- If boss room is within 150 studs
                return room
            end
        end
    end
    return nil
end

