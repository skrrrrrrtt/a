                            if #validPlayers > 0 then
                                local randomPlayer = validPlayers[math.random(1, #validPlayers)]
                                setStatus("Teleporting to " .. randomPlayer.Name .. " to check for boss...")
                                myHRP.CFrame = randomPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
                                task.wait(2)
                                
                                local bossRoom = getBossRoomNearPosition(myHRP.Position)
                                if bossRoom then
                                    local roomUID = bossRoom:GetAttribute("RoomUID")
                                    local roomId = bossRoom:GetAttribute("RoomID")
                                    local roomData = {
                                        uid = roomUID,
                                        Id = roomId,
                                        Model = bossRoom,
                                        CFrame = bossRoom:GetPivot(),
                                        Position = bossRoom:GetPivot().Position
                                    }
                                    table.insert(_G.ScannedRooms, roomData)
                                    setStatus("Found Boss Room via " .. randomPlayer.Name .. "! Starting auto attack...")
                                    _G.AutoMiniBoss = true
                                    foundBossViaPlayer = true
                                else
                                    setStatus(randomPlayer.Name .. " is not in boss room. Trying another player...")
                                end
                            else
                                setStatus("No other players in server to teleport to. Waiting...")
                            end
                        end
                    end
                end
            end
        end
        task.wait(1)
    end
end)
