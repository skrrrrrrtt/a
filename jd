-- Crypto Trader v4 | Street Life Remastered
-- Targets Bitcoin specifically

local RS  = game:GetService("ReplicatedStorage")
local LP  = game:GetService("Players").LocalPlayer

local BUY_BELOW      = 5000
local SELL_ABOVE     = 8000
local CHECK_INTERVAL = 15

local holding      = false
local boughtAt     = 0
local currentPrice = nil

local PhoneRemote = RS:WaitForChild("Remotes"):WaitForChild("Phone")

-- read bitcoin price straight from the UI
local function getBitcoinPrice()
    local ok, price = pcall(function()
        local pg = LP:WaitForChild("PlayerGui")
        local phoneUI = pg:WaitForChild("PhoneUI", 3)
        if not phoneUI then return nil end

        -- search all descendants for "Bitcoin" label then grab sibling/child price
        for _, v in ipairs(phoneUI:GetDescendants()) do
            if v:IsA("TextLabel") and v.Text:lower():find("bitcoin") then
                -- price is usually a sibling or child TextLabel with $XXXX
                local parent = v.Parent
                for _, sibling in ipairs(parent:GetChildren()) do
                    if sibling:IsA("TextLabel") and sibling ~= v then
                        local num = sibling.Text:match("%$?(%d[%d,]+)")
                        if num then
                            local n = tonumber(num:gsub(",", ""))
                            if n and n > 0 then return n end
                        end
                    end
                end
                -- also check children
                for _, child in ipairs(v:GetChildren()) do
                    if child:IsA("TextLabel") then
                        local num = child.Text:match("%$?(%d[%d,]+)")
                        if num then
                            local n = tonumber(num:gsub(",", ""))
                            if n and n > 0 then return n end
                        end
                    end
                end
            end

            -- or find by $ price text directly near bitcoin context
            if v:IsA("TextLabel") then
                local num = v.Text:match("%$(%d[%d,]+)")
                if num then
                    local n = tonumber(num:gsub(",", ""))
                    -- bitcoin range: exclude eth (low) and doge (very low)
                    if n and n >= 1000 and n <= 100000 then
                        return n
                    end
                end
            end
        end
    end)
    return ok and price or nil
end

-- also sniff from outgoing FireServer since Purchase fires with price in arg3
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" and self == PhoneRemote then
        local args = {...}
        if args[1] == "Crypto" and args[2] == "Purchase" and type(args[3]) == "number" then
            currentPrice = args[3]
            print(string.format("[Crypto] Snooped price from game fire: $%d", currentPrice))
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- open crypto tab to force UI to populate
local function openCryptoApp()
    pcall(function() PhoneRemote:FireServer("Phone", "Open", "Crypto") end)
    pcall(function() PhoneRemote:FireServer("Crypto", "View") end)
    task.wait(1.5)
end

local function buy(price)
    print(string.format("[Crypto] ✅ BUYING Bitcoin at $%d", price))
    PhoneRemote:FireServer("Crypto", "Purchase", price)
    holding  = true
    boughtAt = price
end

local function sell(price)
    local profit = price - boughtAt
    print(string.format("[Crypto] 💰 SELLING Bitcoin at $%d | Profit: +$%d", price, profit))
    PhoneRemote:FireServer("Crypto", "Sell", price)
    holding  = false
    boughtAt = 0
end

-- dump all TextLabels in PhoneUI once for debugging
task.spawn(function()
    task.wait(3)
    local ok = pcall(function()
        local phoneUI = LP.PlayerGui:WaitForChild("PhoneUI", 5)
        print("[Crypto] Dumping all TextLabels in PhoneUI:")
        for _, v in ipairs(phoneUI:GetDescendants()) do
            if v:IsA("TextLabel") and v.Text ~= "" then
                print(string.format("  [%s] '%s' | Parent: %s", v.Name, v.Text, v.Parent.Name))
            end
        end
    end)
    if not ok then print("[Crypto] PhoneUI not found yet, open phone first") end
end)

task.spawn(function()
    print("[Crypto] Trader v4 started | Bitcoin only")
    print(string.format("[Crypto] Buy below $%d | Sell above $%d", BUY_BELOW, SELL_ABOVE))

    while true do
        openCryptoApp()

        local price = getBitcoinPrice() or currentPrice

        if not price then
            print("[Crypto] ⏳ Can't read price yet — open Phone > Crypto manually once")
            task.wait(CHECK_INTERVAL)
            continue
        end

        currentPrice = price
        print(string.format("[Crypto] Bitcoin: $%d | Holding: %s | Bought at: $%d",
            price, tostring(holding), boughtAt))

        if not holding then
            if price <= BUY_BELOW then
                buy(price)
            else
                print(string.format("[Crypto] Price too high ($%d), waiting for dip below $%d...", price, BUY_BELOW))
            end
        else
            if price >= SELL_ABOVE then
                sell(price)
            else
                print(string.format("[Crypto] Holding... target $%d | now $%d | profit so far: $%d",
                    SELL_ABOVE, price, price - boughtAt))
            end
        end

        task.wait(CHECK_INTERVAL)
    end
end)
