local function buildList()
    -- clear old buttons
    for _, c in pairs(scroll:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end
    end

    local eggs = getSpawnedEggs()

    if #eggs == 0 then
        local lbl = Instance.new("TextLabel", scroll)
        lbl.Size = UDim2.new(1, -8, 0, 40)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = Color3.fromRGB(180, 180, 180)
        lbl.Text = "No egg rooms found"
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 12
        return
    end

    for i, egg in pairs(eggs) do
        local col
        if egg.multi >= 50 then
            col = Color3.fromRGB(255, 80, 80)
        elseif egg.multi >= 10 then
            col = Color3.fromRGB(255, 200, 50)
        else
            col = Color3.fromRGB(80, 200, 80)
        end

        local btn = Instance.new("TextButton", scroll)
        btn.Size = UDim2.new(1, -8, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Text = "  " .. egg.name .. "  [" .. egg.multi .. "x]"
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 12
        btn.BorderSizePixel = 0
        btn.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

        local accent = Instance.new("Frame", btn)
        accent.Size = UDim2.new(0, 5, 1, 0)
        accent.BackgroundColor3 = col
        accent.BorderSizePixel = 0
        Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 4)

        btn.MouseButton1Click:Connect(function()
            local char = lp.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            if not egg.part or not egg.part.Parent then
                btn.Text = "  [GONE] " .. egg.name
                btn.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
                return
            end
            char.HumanoidRootPart.CFrame = egg.part.CFrame + Vector3.new(0, 5, 0)
            btn.BackgroundColor3 = Color3.fromRGB(20, 60, 20)
            task.delay(1, function()
                btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            end)
        end)
    end

    title.Text = "🟡 Backroom Eggs (" .. #eggs .. " rooms)"
end

refresh.MouseButton1Click:Connect(buildList)
buildList()
