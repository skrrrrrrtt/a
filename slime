local function teleportToZone(n)
    pcall(function()
        local r = getRemote("ZonesService")
        if r then r:InvokeServer("requestTeleportZone", n) end
    end)
end

local function getGameplayFolder()
    local net = RS.Packages._Index["leifstout_networker@0.3.1"].networker
    if not net then return nil end
    local rem = net._remotes; if not rem then return nil end
    for _, child in ipairs(rem:GetChildren()) do
        if child.Name:match("^Gameplay%d+$") then
            local wf = WS:FindFirstChild(child.Name)
            if wf then return wf end
        end
    end
end

local function findEnemyRoot(folder)
    for _, e in pairs(folder:GetChildren()) do
        if e:IsA("Model") then
            local r = e.PrimaryPart or e:FindFirstChild("HumanoidRootPart") or e:FindFirstChild("RootPart")
                   or e:FindFirstChild("SlimeBody") or e:FindFirstChild("Torso")
            if not r then
                for _, d in ipairs(e:GetDescendants()) do
                    if d:IsA("BasePart") then r=d; break end
                end
            end
            if r then return r end
        elseif e:IsA("BasePart") then return e end
    end
end

local function teleportToEnemy()
    if not getgenv().Config["Teleport To Enemies"] then return end
    local char = player.Character; if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("RootPart") or char:FindFirstChild("Torso")
    if not root then return end
    local gp = getGameplayFolder(); if not gp then return end
    local ef = gp:FindFirstChild("Enemies"); if not ef then return end
    local er = findEnemyRoot(ef); if not er then return end
    root.CFrame = CFrame.new(er.Position + Vector3.new(0,5,-2), er.Position)
    root.AssemblyLinearVelocity = Vector3.zero
end

local function teleportToLoot()
    local thr = getgenv().Config["Tp Loot"]
    if type(thr) ~= "number" then return end
    local lf = WS:FindFirstChild("Loot"); if not lf then return end
    local items = {}
    for _, item in pairs(lf:GetChildren()) do
        local pos
        if item:IsA("BasePart") then pos = item.Position
        elseif item:IsA("Model") then
            local p = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
            if p then pos = p.Position end
        end
        if pos then table.insert(items, pos) end
    end
    if #items < thr then return end
    local char = player.Character; if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
    local nearest, nd = nil, math.huge
    for _, p in ipairs(items) do
        local d = (p-root.Position).magnitude
        if d < nd then nd=d; nearest=p end
    end
    if nearest then root.CFrame = CFrame.new(nearest + Vector3.new(0,1,0)) end
end

