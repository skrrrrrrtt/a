local function startAutoUpgrade()
    if getgenv().AutoUpgradeStarted then return end
    getgenv().AutoUpgradeStarted = true
    loadOwnedUpgrades()
    
    if #getgenv().UpgradeBlacklist > 0 then
        print("[Auto Upgrade] Blacklisted upgrades:")
        for _, id in ipairs(getgenv().UpgradeBlacklist) do
            print("  - " .. id)
        end
    end
    
    print("[Auto Upgrade] Started -", #upgradesWithCost, "total upgrades")
    spawn(function()
        while getgenv().Config["Auto Buy Upgrades"] do
            local coins = getCurrentCoins()
            for _, item in ipairs(upgradesWithCost) do
                local upgradeId = item[1]
                
                if not isUpgradeBlacklisted(upgradeId) then
                    if not isUpgradeOwned(upgradeId) and coins >= item[2] then
                        if tryBuyUpgrade(upgradeId, coins) then
                            print("[✓] Bought:", upgradeId)
                            Stats.sessionUpgrades = Stats.sessionUpgrades + 1
                            Stats.currentAction = "Bought upgrade: " .. upgradeId
                            coins = getCurrentCoins()
                            wait(0.2)
                        end
                    end
                end
            end
            wait(2)
        end
    end)
end

-- Auto buy zones with teleport to best zone AFTER purchase
local function startAutoBuyZones()
    print("[Auto Buy Zones] Started")
    spawn(function()
        while getgenv().Config["Auto Buy Zones"] do
            local currentZone = getCurrentMaxZone()
            local nextZone = currentZone + 1
            local price = getZonePrice(nextZone)
            local coins = getCurrentCoins()
            
            if price and coins >= price then
                local remote = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.ZonesService.RemoteFunction
                local success = pcall(function() 
                    return remote:InvokeServer("requestPurchaseZone") 
                end)
                
                if success then
                    print("[Zone] ✓ Purchased zone", nextZone)
                    Stats.sessionZones = Stats.sessionZones + 1
                    Stats.currentAction = "Unlocked zone " .. nextZone .. "!"
                    wait(0.5)
                    local newBestZone = getCurrentMaxZone()
                    teleportToZone(newBestZone)
                    print("[Zone] Teleported to best zone:", newBestZone)
                end
            end
            wait(0.5)
        end
    end)
end

-- Main teleport loop - also check and teleport to best zone periodically
local function startTeleportLoop()
    print("[Teleport] Started")
    spawn(function()
        local lastZoneCheck = 0
        while getgenv().Config["Teleport To Enemies"] do
            teleportToEnemy()
            teleportToLoot()
            
            if tick() - lastZoneCheck > 30 then
                local bestZone = getCurrentMaxZone()
                if bestZone > 1 then
                    teleportToZone(bestZone)
                    print("[Teleport] Refreshed position in zone", bestZone)
                end
                lastZoneCheck = tick()
            end
            
            wait(1)
        end
    end)
end

