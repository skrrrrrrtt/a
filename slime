    leftCol.Size=UDim2.new(LEFT_W,-4,1,0); leftCol.BackgroundTransparency=1

    local rightCol = Instance.new("Frame", content)
    rightCol.Size=UDim2.new(1-LEFT_W,-4,1,0); rightCol.Position=UDim2.new(LEFT_W,4,0,0)
    rightCol.BackgroundTransparency=1

    local refs = {}

    local function card(parent, x, y, w, h, accentColor)
        local f = Instance.new("Frame", parent)
        f.Size=UDim2.new(w,0,h,0); f.Position=UDim2.new(x,0,y,0)
        f.BackgroundColor3=CARD; f.BorderSizePixel=0
        Instance.new("UICorner",f).CornerRadius=UDim.new(0,8)
        local s = Instance.new("UIStroke",f); s.Color=BORD; s.Thickness=1
        if accentColor then
            local top = Instance.new("Frame",f)
            top.Size=UDim2.new(1,0,0,2); top.BackgroundColor3=accentColor; top.BorderSizePixel=0
            Instance.new("UICorner",top).CornerRadius=UDim.new(0,8)
            local fix = Instance.new("Frame",top)
            fix.Size=UDim2.new(1,0,0.5,0); fix.Position=UDim2.new(0,0,0.5,0)
            fix.BackgroundColor3=accentColor; fix.BorderSizePixel=0
        end
        return f
    end

    local function lbl(parent, text, ys, color, size, font, align)
        local l = Instance.new("TextLabel",parent)
        l.Size=UDim2.new(1,-12,0,20); l.Position=UDim2.new(0,8,0,ys)
        l.BackgroundTransparency=1; l.Text=text
        l.TextColor3=color or DIM; l.TextSize=size or 11
        l.Font=font or Enum.Font.GothamBold
        l.TextXAlignment=align or Enum.TextXAlignment.Left
        l.TextTruncate=Enum.TextTruncate.AtEnd
        return l
    end

    -- ROW 1 — economy (4 cards, 25% each)
    local W4=0.245; local G4=0.0066
    local econ = {
        {key="coins", label="COINS",    col=GOLD},
        {key="goop",  label="GOOP",     col=TEAL},
        {key="rbs",   label="REBIRTHS", col=BLUE},
        {key="zone",  label="ZONE",     col=LIME},
    }
    for i, e in ipairs(econ) do
        local c = card(leftCol, (W4+G4)*(i-1), 0, W4, 0.31, e.col)
        lbl(c,e.label,6,DIM,10,Enum.Font.GothamBold)
        local v = lbl(c,"0",24,VAL,34,Enum.Font.GothamBold)
        v.Size=UDim2.new(1,-12,0,42); v.TextScaled=true
        refs[e.key]=v
        if e.key=="rbs" then
            local sub = lbl(c,"next: --",70,DIM,10,Enum.Font.Code)
            refs["rbsub"]=sub
        end
    end

    -- ROW 2 — session (6 cards)
    local W6=0.162; local G6=0.0056
    local sess = {
        {key="rolls",  label="ROLLS",        col=PURP},
        {key="srbs",   label="REBIRTHS",     col=PINK},
        {key="supg",   label="UPGRADES",     col=ORA},
        {key="szon",   label="ZONES",        col=CYAN},
        {key="rpm",    label="ROLLS / MIN",  col=LIME},
        {key="uptime", label="UPTIME",       col=BLUE},
    }
    for i, s in ipairs(sess) do
        local c = card(leftCol, (W6+G6)*(i-1), 0.33, W6, 0.3, s.col)
        lbl(c,s.label,5,DIM,9,Enum.Font.GothamBold)
        local v = lbl(c,"0",22,VAL,26,Enum.Font.GothamBold)
        v.Size=UDim2.new(1,-10,0,36); v.TextScaled=true
        refs[s.key]=v
    end

    -- ROW 3 — rebirth cost + goop progress bar
    local row3Y=0.645
    local rbC = card(leftCol, 0, row3Y, 0.34, 0.175, BAD)
    lbl(rbC,"REBIRTH COST",5,DIM,9,Enum.Font.GothamBold)
    local rbCostV = lbl(rbC,"--",22,VAL,22,Enum.Font.GothamBold)
    rbCostV.Size=UDim2.new(1,-10,0,30); rbCostV.TextScaled=true
    local rbCostSub = lbl(rbC,"--",52,DIM,10,Enum.Font.Code)
    refs["rbcost"]=rbCostV; refs["rbcostsub"]=rbCostSub

    local progC = card(leftCol, 0.346, row3Y, 0.654, 0.175, TEAL)
    lbl(progC,"GOOP PROGRESS",5,DIM,9,Enum.Font.GothamBold)
    local progPct = lbl(progC,"0%",22,VAL,28,Enum.Font.GothamBold)
    progPct.Size=UDim2.new(0.2,0,0,36); progPct.TextScaled=true

    local barBg = Instance.new("Frame",progC)
    barBg.Size=UDim2.new(0.76,0,0,10); barBg.Position=UDim2.new(0.22,0,0,28)
    barBg.BackgroundColor3=BORD; barBg.BorderSizePixel=0
    Instance.new("UICorner",barBg).CornerRadius=UDim.new(0,5)

    local barFill = Instance.new("Frame",barBg)
    barFill.Size=UDim2.new(0,0,1,0); barFill.BackgroundColor3=TEAL; barFill.BorderSizePixel=0
    Instance.new("UICorner",barFill).CornerRadius=UDim.new(0,5)

    local barSub = Instance.new("TextLabel",progC)
    barSub.Size=UDim2.new(0.76,0,0,14); barSub.Position=UDim2.new(0.22,0,0,44)
    barSub.BackgroundTransparency=1; barSub.Text="0 / 0"
    barSub.TextColor3=DIM; barSub.TextSize=10; barSub.Font=Enum.Font.Code
    barSub.TextXAlignment=Enum.TextXAlignment.Left

    refs["progPct"]=progPct; refs["barFill"]=barFill; refs["barSub"]=barSub

    -- ROW 4 — feature status list
    local featC = card(leftCol, 0, 0.83, 1, 0.17, ACC)
    lbl(featC,"FEATURES",5,DIM,9,Enum.Font.GothamBold)
    local featDefs = {
        {"Auto Roll",    "Auto Roll"},
        {"Auto Rebirth", "Auto Rebirth"},
        {"Auto Upgrade", "Auto Buy Upgrades"},
        {"Auto Zones",   "Auto Buy Zones"},
        {"Tp Enemies",   "Teleport To Enemies"},
        {"Auto Boosts",  "Auto Use Boosts"},
        {"Claim Rewards","Claim Rewards"},
    }
    local featInner = Instance.new("Frame",featC)
    featInner.Size=UDim2.new(1,-12,1,-22); featInner.Position=UDim2.new(0,6,0,20)
    featInner.BackgroundTransparency=1
    local featLayout = Instance.new("UIGridLayout",featInner)
    featLayout.CellSize=UDim2.new(1/4,-4, 1,-2); featLayout.CellPadding=UDim2.new(0,4,0,2)

    local featRefs = {}
    for _, fd in ipairs(featDefs) do
        local row = Instance.new("Frame",featInner)
        row.BackgroundTransparency=1; row.BorderSizePixel=0

        local dot = Instance.new("Frame",row)
        dot.Size=UDim2.new(0,6,0,6); dot.Position=UDim2.new(0,0,0.5,-3)
        dot.BackgroundColor3=BAD; dot.BorderSizePixel=0
        Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

        local nl = Instance.new("TextLabel",row)
        nl.Size=UDim2.new(1,-10,1,0); nl.Position=UDim2.new(0,10,0,0)
        nl.BackgroundTransparency=1; nl.Text=fd[1]
        nl.TextColor3=TXT; nl.TextSize=10; nl.Font=Enum.Font.Gotham
        nl.TextXAlignment=Enum.TextXAlignment.Left

        table.insert(featRefs, {dot=dot, cfgKey=fd[2]})
    end
    refs["feats"]=featRefs

    -- RIGHT COLUMN — boosts
    local boostC = card(rightCol, 0, 0, 1, 0.52, PURP)
    lbl(boostC,"BOOSTS",6,DIM,10,Enum.Font.GothamBold)

    local boostDefs = {
        {name="Luck",       key="luck",      col=LIME},
        {name="Ultra Luck", key="ultraLuck", col=GOLD},
        {name="Currency",   key="currency",  col=TEAL},
        {name="Roll Speed", key="rollSpeed", col=CYAN},
    }
    local boostRefs = {}
    for i, bd in ipairs(boostDefs) do
        local ry = 24 + (i-1)*32
        local dot = Instance.new("Frame",boostC)
        dot.Size=UDim2.new(0,8,0,8); dot.Position=UDim2.new(0,8,0,ry+7)
        dot.BackgroundColor3=BAD; dot.BorderSizePixel=0
        Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

        local nl = Instance.new("TextLabel",boostC)
        nl.Size=UDim2.new(0.58,-22,0,24); nl.Position=UDim2.new(0,22,0,ry)
        nl.BackgroundTransparency=1; nl.Text=bd.name
        nl.TextColor3=TXT; nl.TextSize=13; nl.Font=Enum.Font.Gotham
        nl.TextXAlignment=Enum.TextXAlignment.Left

        local sl = Instance.new("TextLabel",boostC)
        sl.Size=UDim2.new(0.38,0,0,24); sl.Position=UDim2.new(0.62,-4,0,ry)
        sl.BackgroundTransparency=1; sl.Text="OFF"
        sl.TextColor3=BAD; sl.TextSize=13; sl.Font=Enum.Font.Code
        sl.TextXAlignment=Enum.TextXAlignment.Right

        boostRefs[bd.key]={dot=dot, lbl=sl, col=bd.col}
    end
    refs["boosts"]=boostRefs

    -- RIGHT COLUMN — player info
    local infoC = card(rightCol, 0, 0.54, 1, 0.46, BLUE)
    lbl(infoC,"PLAYER",6,DIM,10,Enum.Font.GothamBold)
    local nameLbl  = lbl(infoC,player.Name,  26,VAL, 13,Enum.Font.GothamBold)
    local coinLbl  = lbl(infoC,"coins  --",  48,TXT, 11,Enum.Font.Code)
    local goopLbl  = lbl(infoC,"goop   --",  64,TXT, 11,Enum.Font.Code)
    local zoneLbl  = lbl(infoC,"zone   --",  80,TXT, 11,Enum.Font.Code)
    local rollLbl  = lbl(infoC,"rolls  --",  96,TXT, 11,Enum.Font.Code)
    local uptimeLbl2 = lbl(infoC,"up     --", 112,TXT, 11,Enum.Font.Code)
    refs["infoCoins"] = coinLbl; refs["infoGoop"]   = goopLbl
    refs["infoZone"]  = zoneLbl; refs["infoRolls"]  = rollLbl
    refs["infoUp"]    = uptimeLbl2

    -- ── UPDATE LOOP ──
    local startTime = tick()
    spawn(function()
        while true do
            pcall(function()
                local coins  = getCoins()
                local goop   = getGoop()
                local rbs    = getRebirths()
                local rbcost = getRebirthCost()
                local zone   = getMaxZone()
                local uptime = tick() - startTime
                local rpm    = #rollTimes

                -- big cards
                refs["coins"].Text  = fmt(coins)
                refs["goop"].Text   = fmt(goop)
                refs["rbs"].Text    = fmt(rbs)
                refs["rbsub"].Text  = "next: "..fmt(rbcost)
                refs["zone"].Text   = tostring(zone)

                -- session
                refs["rolls"].Text  = fmt(stats.rolls)
                refs["srbs"].Text   = fmt(stats.rebirths)
                refs["supg"].Text   = fmt(stats.upgrades)
                refs["szon"].Text   = fmt(stats.zones)
                refs["rpm"].Text    = tostring(rpm)
                refs["uptime"].Text = fmtTime(uptime)

                -- rebirth cost
                local canRB = goop >= rbcost
                refs["rbcost"].Text      = fmt(rbcost)
                refs["rbcost"].TextColor3= canRB and GOOD or VAL
                refs["rbcostsub"].Text   = canRB and "READY" or (fmt(goop).." / "..fmt(rbcost))
                refs["rbcostsub"].TextColor3 = canRB and GOOD or DIM

                -- goop bar
                local pct = rbcost > 0 and math.min(1, goop/rbcost) or 0
                refs["progPct"].Text         = math.floor(pct*100).."%"
                refs["progPct"].TextColor3   = pct >= 1 and GOOD or VAL
                refs["barFill"].Size         = UDim2.new(pct,0,1,0)
                refs["barFill"].BackgroundColor3 = pct >= 1 and GOOD or TEAL
                refs["barSub"].Text          = fmt(goop).." / "..fmt(rbcost)

                -- top bar
                statusL.Text = stats.action
                metaL.Text   = "up "..fmtTime(uptime).."   zone "..zone

                -- boosts
                for key, br in pairs(refs["boosts"]) do
                    local on = isBoostActive(key)
                    br.dot.BackgroundColor3 = on and (br.col or GOOD) or BAD
                    br.lbl.Text             = on and "ON" or "OFF"
                    br.lbl.TextColor3       = on and (br.col or GOOD) or DIM
                end

                -- feature dots
                for _, fr in ipairs(refs["feats"]) do
                    fr.dot.BackgroundColor3 = getgenv().Config[fr.cfgKey] and GOOD or BAD
                end

                -- right info panel
                refs["infoCoins"].Text = "coins   "..fmt(coins)
                refs["infoGoop"].Text  = "goop    "..fmt(goop)
                refs["infoZone"].Text  = "zone    "..tostring(zone)
                refs["infoRolls"].Text = "rolls   "..fmt(stats.rolls)
                refs["infoUp"].Text    = "uptime  "..fmtTime(uptime)
            end)
            wait(1)
        end
    end)

    -- blink dot
    spawn(function()
        while true do
            liveDot.BackgroundColor3=GOOD; wait(0.85)
            liveDot.BackgroundColor3=CARD;  wait(0.25)
        end
    end)
end

-- ──────────────────────────────────────────────
--  MAIN
-- ──────────────────────────────────────────────
local function init()
    local stats = {
        rolls=0, rebirths=0, upgrades=0, zones=0,
        action="starting up",
    }

    claimOffline()
    createHUD(stats)
    startAutoClaim(stats)
    startAutoRebirth(stats)
    startAutoRoll(stats)
    startAutoBuyZones(stats)
    startAutoUpgrade(stats)
    startAutoBoost(stats)
    startTeleportLoop()
    startOptimization()

    print("[Slime RNG] loaded")
end

if game:IsLoaded() then init() else game.Loaded:Wait(); init() end
