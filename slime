-- Silence networker error
local originalWarn = warn
warn = function(...)
    local msg = tostring((...))
    if msg:find("zoneEntered") or msg:find("does not exist on networkTag") or msg:find("NetworkerClient") then
        return
    end
    originalWarn(...)
