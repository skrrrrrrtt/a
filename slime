local OWNED_FILE = "SlimeRNG_" .. player.Name:gsub("[^%w_%-]","_") .. "_upgrades.json"
local owned, ownedSet = {}, {}

local function loadCache()
    local ok, d = pcall(readfile, OWNED_FILE)
    if ok and d and d ~= "" then
        local ok2, t = pcall(function() return HttpService:JSONDecode(d) end)
        if ok2 and type(t) == "table" then
            owned = t; ownedSet = {}
            for _, id in ipairs(owned) do ownedSet[id] = true end
            return true
        end
    end
    owned = {}; ownedSet = {}
    return false
end

local function saveUpgrade(id)
    if ownedSet[id] then return end
    table.insert(owned, id); ownedSet[id] = true
    pcall(function() writefile(OWNED_FILE, HttpService:JSONEncode(owned)) end)
end

local function isOwned(id)       return ownedSet[id] == true end
local function isBlacklisted(id)
    for _, b in ipairs(getgenv().UpgradeBlacklist) do if id == b then return true end end
    return false
end

