local function getRemote(name)
    local ok, r = pcall(function()
        return RS.Packages._Index["leifstout_networker@0.3.1"].networker._remotes[name].RemoteFunction
    end)
    return ok and r or nil
end
local function getRemoteEvent(name)
    local ok, r = pcall(function()
        return RS.Packages._Index["leifstout_networker@0.3.1"].networker._remotes[name].RemoteEvent
    end)
    return ok and r or nil
end
local function invoke(svc, method, ...)
    local r = getRemote(svc)
    if not r then return nil end
    local ok, res = pcall(function() return r:InvokeServer(method, ...) end)
    return ok and res or nil
end
local function fire(svc, method, ...)
    local r = getRemoteEvent(svc)
    if r then pcall(function() r:FireServer(method, ...) end) end
end

