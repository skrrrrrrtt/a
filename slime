local function tryBuyUpgrade(id, coins)
    if isBlacklisted(id) or isOwned(id) then return false end
    local cost = 0
    for _, item in ipairs(upgradesWithCost) do if item[1]==id then cost=item[2]; break end end
    if coins < cost then return false end
    local r = getRemote("UpgradeService"); if not r then return false end
    local ok, res = pcall(function() return r:InvokeServer("requestUnlock", id) end)
    if ok and res == true then saveUpgrade(id); return true end
    return false
end

