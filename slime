    statRow("Rebirths", "🔁", "0")
    statRow("Rebirth Cost", "💸", "0")
    divider()
    sectionLabel("── WORLD ───────────────")
    statRow("Zone", "🌍", "1")
    statRow("Uptime", "⏱", "0s")
    divider()
    sectionLabel("── SESSION ─────────────")
    statRow("Rolls", "🎲", "0")
    statRow("Rebirths Done", "⬆", "0")
    statRow("Upgrades Bought", "🔧", "0")
    statRow("Zones Unlocked", "📍", "0")
    divider()
    sectionLabel("── BOOSTS ──────────────")
    statRow("Luck", "🍀", "OFF")
    statRow("Ultra Luck", "✨", "OFF")
    statRow("Currency", "💎", "OFF")
    statRow("Roll Speed", "⚡", "OFF")

    -- Dragging logic
    local dragging = false
    local dragStart, startPos

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    -- Minimize toggle
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        content.Visible = not minimized
        frame.Size = minimized and UDim2.new(0, 240, 0, 32) or UDim2.new(0, 240, 0, 310)
        minBtn.Text = minimized and "+" or "−"
    end)

    return statLabels
end

local function updateBoostLabel(lbl, boostType)
    local active = isBoostActive(boostType)
    lbl.Text = active and "ON" or "OFF"
    lbl.TextColor3 = active and Color3.fromRGB(100, 255, 140) or Color3.fromRGB(160, 80, 80)
end

local function startStatsUI()
    local labels = createStatsUI()
    if not labels then return end

    spawn(function()
        while true do
            pcall(function()
                local coins = getCurrentCoins()
                local goop = getCurrentGoop()
                local rebirths = getRebirthCount()
                local cost = getRebirthCost()
                local zone = getCurrentMaxZone()
                local uptime = tick() - Stats.sessionStart

                if labels["Coins"] then labels["Coins"].Text = fmtNum(coins) end
                if labels["Goop"] then labels["Goop"].Text = fmtNum(goop) end
                if labels["Rebirths"] then labels["Rebirths"].Text = fmtNum(rebirths) end
                if labels["Rebirth Cost"] then
                    labels["Rebirth Cost"].Text = fmtNum(cost)
                    labels["Rebirth Cost"].TextColor3 = goop >= cost
                        and Color3.fromRGB(100, 255, 140)
                        or Color3.fromRGB(255, 160, 80)
                end
                if labels["Zone"] then labels["Zone"].Text = tostring(zone) end
                if labels["Uptime"] then labels["Uptime"].Text = fmtUptime(uptime) end

                if labels["Rolls"] then labels["Rolls"].Text = fmtNum(Stats.sessionRolls) end
                if labels["Rebirths Done"] then labels["Rebirths Done"].Text = fmtNum(Stats.sessionRebirths) end
                if labels["Upgrades Bought"] then labels["Upgrades Bought"].Text = fmtNum(Stats.sessionUpgrades) end
                if labels["Zones Unlocked"] then labels["Zones Unlocked"].Text = fmtNum(Stats.sessionZones) end

                if labels["Status"] then labels["Status"].Text = "⚡ " .. Stats.currentAction end

                if labels["Luck"] then updateBoostLabel(labels["Luck"], "luck") end
                if labels["Ultra Luck"] then updateBoostLabel(labels["Ultra Luck"], "ultraLuck") end
                if labels["Currency"] then updateBoostLabel(labels["Currency"], "currency") end
                if labels["Roll Speed"] then updateBoostLabel(labels["Roll Speed"], "rollSpeed") end
            end)
            wait(1)
        end
    end)
end

