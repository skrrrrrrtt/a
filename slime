local function getGameplayFolder()
    local networker = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker
    if not networker then return nil end

    local remotes = networker._remotes
    if not remotes then return nil end

    for _, child in ipairs(remotes:GetChildren()) do
        if child.Name:match("^Gameplay%d+$") then
            local workspaceFolder = workspace:FindFirstChild(child.Name)
            if workspaceFolder then
                return workspaceFolder, child.Name
            end
        end
    end
    return nil
end

local function findFirstEnemyRootPart(enemiesFolder)
    for _, enemy in pairs(enemiesFolder:GetChildren()) do
        if enemy:IsA("Model") then
            local enemyRoot = enemy.PrimaryPart
                or enemy:FindFirstChild("HumanoidRootPart")
                or enemy:FindFirstChild("RootPart")
                or enemy:FindFirstChild("SlimeBody")
                or enemy:FindFirstChild("Torso")
                or enemy:FindFirstChild("UpperTorso")

            if not enemyRoot then
                for _, descendant in ipairs(enemy:GetDescendants()) do
                    if descendant:IsA("BasePart") then
                        enemyRoot = descendant
                        break
                    end
                end
            end

            if enemyRoot then
                return enemyRoot
            end
        elseif enemy:IsA("BasePart") then
            return enemy
        end
    end
    return nil
end

-- Teleport to enemy
local function teleportToEnemy()
    if not getgenv().Config["Teleport To Enemies"] then
        return
    end

    local player = game:GetService("Players").LocalPlayer
    if not player then
        return
    end

    local character = player.Character or player.CharacterAdded:Wait()
    if not character then
        return
    end

    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("RootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then
        return
    end

    local gameplay, gameplayName = getGameplayFolder()
    if not gameplay then
        return
    end

    local enemiesFolder = gameplay:FindFirstChild("Enemies")
    if not enemiesFolder then
        return
    end

    local enemyRoot = findFirstEnemyRootPart(enemiesFolder)
    if not enemyRoot then
        return
    end

    local heightOffset = 5
    local targetPosition = enemyRoot.Position + Vector3.new(0, heightOffset, -2)
    rootPart.CFrame = CFrame.new(targetPosition, enemyRoot.Position)
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.Velocity = Vector3.new(0, 0, 0)
end

-- Loot teleport
local function getLootItems()
    local lootItems = {}
    local lootFolder = workspace:FindFirstChild("Loot")
    if not lootFolder then return lootItems end
    
    for _, item in pairs(lootFolder:GetChildren()) do
        if item:IsA("BasePart") then
            table.insert(lootItems, {pos = item.Position})
        elseif item:IsA("Model") then
            local part = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
            if part then
                table.insert(lootItems, {pos = part.Position})
            end
        end
    end
    return lootItems
end

local function teleportToLoot()
    local threshold = getgenv().Config["Tp Loot"]
    if threshold == false or type(threshold) ~= "number" then return end
    
    local lootItems = getLootItems()
    if #lootItems >= threshold then
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        local currentPos = root.Position
        local nearest = nil
        local nearestDist = math.huge
        for _, loot in ipairs(lootItems) do
            local dist = (loot.pos - currentPos).magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearest = loot
            end
        end
        if nearest then
            local targetPos = Vector3.new(nearest.pos.X, nearest.pos.Y + 1, nearest.pos.Z)
            root.CFrame = CFrame.new(targetPos)
            print("[Loot] Teleported! Count:", #lootItems)
        end
    end
end

