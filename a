-- Crypto Trader v9 | Street Life Remastered

local LP = game:GetService("Players").LocalPlayer

local BUY_BELOW  = 5000
local SELL_ABOVE = 8000

local holding    = false
local boughtAt   = 0

local PhoneUI      = LP:WaitForChild("PlayerGui"):WaitForChild("PhoneUI")
local CryptoFrame  = PhoneUI:WaitForChild("CryptoFrame")
local CurrencyFrame = PhoneUI:WaitForChild("CurrencyFrame")

-- exact labels from dump
local CryptoCurrent = CurrencyFrame:WaitForChild("CryptoCurrent") -- "$4860"
local BTCBalance    = CryptoFrame:WaitForChild("BTCBalance")       -- "BTC Balance: 0"
local Countdown     = CryptoFrame:WaitForChild("Countdown")        -- "125s"
local BuyBtn        = CryptoFrame:WaitForChild("Buy")
local SellBtn       = CryptoFrame:WaitForChild("Sell")

local function getPrice()
    local n = tonumber((CryptoCurrent.Text:gsub("[%$,]", "")))
    return n
end

local function getBTCBal()
    return tonumber(BTCBalance.Text:match("(%d+)$")) or 0
end

local function clickBtn(btn)
    pcall(function() btn:FireButton1Click() end)
end

local function buy(price)
    clickBtn(BuyBtn)
    task.wait(0.5)
    if getBTCBal() > 0 then
        holding  = true
        boughtAt = price
        print(string.format("[BTC] ✅ Bought @ $%d", price))
    else
        print("[BTC] ⚠️ Buy failed")
    end
end

local function sell(price)
    clickBtn(SellBtn)
    task.wait(0.5)
    if getBTCBal() == 0 then
        print(string.format("[BTC] 💰 Sold @ $%d | Profit: +$%d", price, price - boughtAt))
        holding  = false
        boughtAt = 0
    else
        print("[BTC] ⚠️ Sell failed")
    end
end

-- react instantly when price changes
local lastPrice = nil
CryptoCurrent:GetPropertyChangedSignal("Text"):Connect(function()
    local price = getPrice()
    if not price or price == lastPrice then return end
    lastPrice = price
    print(string.format("[BTC] Price changed -> $%d | CD: %s", price, Countdown.Text))

    -- sync holding with real balance
    local bal = getBTCBal()
    if bal > 0 and not holding then holding = true boughtAt = price end
    if bal == 0 and holding then holding = false boughtAt = 0 end

    if not holding and price <= BUY_BELOW then
        buy(price)
    elseif holding and price >= SELL_ABOVE then
        sell(price)
    else
        if not holding then
            print(string.format("[BTC] $%d too high, want below $%d", price, BUY_BELOW))
        else
            print(string.format("[BTC] Holding @ $%d | bought $%d | target $%d | P&L $%d",
                price, boughtAt, SELL_ABOVE, price - boughtAt))
        end
    end
end)

-- initial check
task.spawn(function()
    task.wait(1)
    local price = getPrice()
    if not price then
        print("[BTC] Open Phone > Crypto once to load prices")
        repeat task.wait(1) price = getPrice() until price
    end

    lastPrice = price
    local bal = getBTCBal()
    if bal > 0 then holding = true boughtAt = price end

    print(string.format("[BTC] Ready | Price: $%d | Balance: %d BTC | Buy<%d | Sell>%d",
        price, bal, BUY_BELOW, SELL_ABOVE))

    if not holding and price <= BUY_BELOW then
        buy(price)
    elseif holding and price >= SELL_ABOVE then
        sell(price)
    end
end)

print("[BTC] Trader v9 loaded")
