    rootPart.Anchored = true
    task.wait(0.3)
    rootPart.CFrame = CFrame.new(chest:GetPivot().Position + Vector3.new(0, 3, 0))

    _G.Teleporting = false
    return true
end

local function Scan()
    if _G.IsScanning then return end
    _G.IsScanning = true

    updateStatus("Scanning backrooms...")
    
    local function TPtoSpawn()
        local character = getCharacter()
        local activeInstance = InstancingCmds.Get()
        if character and activeInstance then
            local spawnLocation = CollectionService:GetTagged("DeepSpawnLocation")[1]
            if spawnLocation and spawnLocation:IsA("BasePart") and not enterPosition then
                enterPosition = spawnLocation.Position
            end
            
            local pos = enterPosition + Vector3.new(0, 3, 0)
            
            Network.Fire("RequestStreaming", pos)
            task.delay(0.25, function()
                if character.Parent and InstancingCmds.IsInInstance("Backrooms") then
                    character:PivotTo(CFrame.new(pos))
                end
            end)
        end
    end
    
    TPtoSpawn()
    
    local function scanRooms()
        for _, room in ipairs(GeneratedBackrooms:GetChildren()) do
            if room.Name == "Walls" then
                room:Destroy()
            end
            
            if room:GetAttribute("DeepRoom") ~= false then
                local roomUID = room:GetAttribute("RoomUID")
                if roomUID then
                    local exists = false
                    for _, r in ipairs(_G.ScannedRooms) do
                        if r.uid == roomUID then
                            exists = true
                            break
                        end
                    end
                    
                    if not exists then
                        table.insert(_G.ScannedRooms, {
                            uid = roomUID,
                            Id = room:GetAttribute("RoomID"),
                            Model = room,
                            Position = room:GetPivot().Position
                        })
                        updateRooms(#_G.ScannedRooms)
                    end
                end
            end
        end
    end
    
    scanRooms()
    
    while true do
        if #_G.ScannedRooms >= 400 then
            break
        end
        
        if _G.Teleporting then
            task.wait(0.1)
            continue
        end
        
        local room = nil
        for _, r in ipairs(_G.ScannedRooms) do
            if not _G.VistedRooms[r.uid] then
                room = r
                break
            end
        end
        
        if not room then
            break
        end
        
        _G.VistedRooms[room.uid] = true
        ScanTeleport(room.Model)
        scanRooms()
        task.wait(0.1)
    end
    
    _G.IsScanning = false
    updateStatus("Scan complete")
    TPtoSpawn()
end

task.spawn(function()
    while true do
        task.wait(0.3)
        
        if not _G.AutoMiniBoss then continue end
        if _G.IsScanning or _G.Teleporting then continue end
        
        local character = getCharacter()
        if not character then continue end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then continue end
        
        if _G.MiniBossState == "scanning" then
            updateStatus("Looking for mini boss room...")
            updateInfo("Searching " .. #_G.ScannedRooms .. " scanned rooms")
            
            local bossRoom = findMiniBossChestRoom()
            if bossRoom then
                _G.MiniBossTargetRoom = bossRoom
                _G.MiniBossState = "found_room"
                _G.MiniBossRetryCount = 0
            else
                _G.MiniBossRetryCount = _G.MiniBossRetryCount + 1
                if _G.MiniBossRetryCount > 3 then
                    serverHop("No boss room found")
                    task.wait(5)
                    _G.MiniBossRetryCount = 0
                else
                    updateInfo("Retry " .. _G.MiniBossRetryCount .. "/3")
                    task.wait(2)
                end
            end
            
        elseif _G.MiniBossState == "found_room" then
            if areDoorsLocked(_G.MiniBossTargetRoom.Model) then
                _G.MiniBossState = "teleporting_to_door"
                updateInfo("Doors are locked")
            else
                _G.MiniBossState = "teleporting_to_chest"
                updateInfo("Doors already unlocked")
            end
            
        elseif _G.MiniBossState == "teleporting_to_door" then
            updateStatus("Teleporting to door...")
            updateInfo("Moving to locked door")
            if TeleportToDoor(_G.MiniBossTargetRoom.Model) then
                _G.MiniBossState = "unlocking"
                task.wait(0.5)
            else
                task.wait(1)
            end
            
        elseif _G.MiniBossState == "unlocking" then
            updateStatus("Unlocking doors...")
            updateInfo("Using Deep Backrooms Crayon Key")
            if UnlockRoom(_G.MiniBossTargetRoom.uid) then
                _G.MiniBossState = "teleporting_to_chest"
                task.wait(0.5)
            else
                updateInfo("No key found!")
                serverHop("No Crayon Key")
                task.wait(5)
            end
            
        elseif _G.MiniBossState == "teleporting_to_chest" then
            updateStatus("Looking for chest...")
            updateInfo("Searching for Daydream Mimic Chest")
            local chest = findMiniBossChest(_G.MiniBossTargetRoom.Model)
            
            if chest then
                _G.MiniBossChest = chest
                _G.MiniBossRetryCount = 0
                if TeleportToChest(chest) then
                    _G.MiniBossState = "breaking"
                    task.wait(0.5)
                else
                    task.wait(1)
                end
            else
                _G.MiniBossRetryCount = _G.MiniBossRetryCount + 1
                if _G.MiniBossRetryCount > 10 then
                    serverHop("Chest not spawning")
                    task.wait(5)
                    _G.MiniBossRetryCount = 0
                else
                    updateInfo("Waiting for chest... " .. _G.MiniBossRetryCount .. "/10")
                    task.wait(2)
                end
            end
            
        elseif _G.MiniBossState == "breaking" then
            updateStatus("Breaking mini boss chest!")
            updateInfo("Dealing damage with pets")
            
            if not _G.MiniBossChest or not _G.MiniBossChest.Parent then
                _G.MiniBossState = "chest_broken"
                continue
            end
            
            local bUID = _G.MiniBossChest:GetAttribute("BreakableUID")
            local bPos = _G.MiniBossChest:GetPivot().Position
            
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid:MoveTo(bPos) end
            
            pcall(function()
                Network.UnreliableFire("Breakables_PlayerDealDamage", bUID)
            end)
            
            for _, pet in pairs(PlayerPet.GetByPlayer(localPlayer)) do
                if pet.cpet then
                    pcall(function() pet:SetTarget(_G.MiniBossChest) end)
                end
            end
            
        elseif _G.MiniBossState == "chest_broken" then
            updateStatus("Chest broken!")
            updateInfo("Finding new server...")
            serverHop("Chest broken!")
            task.wait(5)
            _G.MiniBossState = "scanning"
            _G.MiniBossTargetRoom = nil
            _G.MiniBossChest = nil
            _G.MiniBossRetryCount = 0
        end
    end
end)

