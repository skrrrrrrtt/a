local function findMiniBossChestRoom()
    for _, r in ipairs(_G.ScannedRooms) do
        if r.Id == "GameMastersStage" then
            return r
        end
    end
    return nil
end

local function findMiniBossChest(roomModel)
    local breakables = workspace:FindFirstChild("__THINGS")
    if not breakables then return nil end
    local breakablesFolder = breakables:FindFirstChild("Breakables")
    if not breakablesFolder then return nil end
    
    local roomPos = roomModel:GetPivot().Position
    
    for _, b in ipairs(breakablesFolder:GetChildren()) do
        if b:GetAttribute("BreakableID") == "Daydream Mimic Chest2" then
            if (b:GetPivot().Position - roomPos).Magnitude < 150 then
                return b
            end
        end
    end
    return nil
end

local function areDoorsLocked(roomModel)
    local LockedDoors = roomModel:FindFirstChild("LockedDoors")
    if not LockedDoors then return false end
    for _, child in ipairs(LockedDoors:GetChildren()) do
        local Lock = child:FindFirstChild("Lock")
        if Lock and Lock.Transparency < 0.5 then
            return true
        end
    end
    return false
end

local function getLockPosition(roomModel)
    local LockedDoors = roomModel:FindFirstChild("LockedDoors")
    if not LockedDoors then return nil end
    for _, child in ipairs(LockedDoors:GetChildren()) do
        local Lock = child:FindFirstChild("Lock")
        if Lock and Lock.Transparency < 0.5 then
            return Lock:GetPivot()
        end
    end
    return nil
end

local function UnlockRoom(roomUID)
    local character = getCharacter()
    if not character then return false end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    local roomModel = nil
    for _, rm in ipairs(GeneratedBackrooms:GetChildren()) do
        if rm:GetAttribute("RoomUID") == roomUID then
            roomModel = rm
            break
        end
    end
    if not roomModel then return false end
    
    local LockedDoors = roomModel:FindFirstChild("LockedDoors")
    if not LockedDoors then return true end
    
    for _, child in ipairs(LockedDoors:GetChildren()) do
        local Lock = child:FindFirstChild("Lock")
        if Lock and Lock.Transparency < 0.5 then
            rootPart:PivotTo(Lock:GetPivot())
            task.wait(0.3)
        end
    end
    
    if not areDoorsLocked(roomModel) then return true end
    
    local keyItem = MiscItem("Deep Backrooms Crayon Key")
    if keyItem and keyItem:HasAny() then
        local activeInstance = InstancingCmds.Get()
        if activeInstance then
            activeInstance:FireCustom("AbstractRoom_FireServer", roomUID, "UnlockDoors")
            task.wait(0.5)
            return not areDoorsLocked(roomModel)
        end
    end
    return false
end

-- PROPER teleport function for scanning (with forcefield and proper timing)
local function ScanTeleport(roomModel)
    if _G.Teleporting then return false end
    _G.Teleporting = true

    local character = getCharacter()
    if not character then _G.Teleporting = false return false end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then _G.Teleporting = false return false end

    local pos = roomModel:GetPivot().Position
    Network.Fire("RequestStreaming", pos)

    local forceField = Instance.new("ForceField")
    forceField.Visible = false
    forceField.Parent = character

    task.delay(5, function()
        rootPart.Anchored = false
        if forceField and forceField.Parent then 
            forceField:Destroy() 
        end
    end)

    rootPart.Anchored = true
    task.wait(0.3)

    local targetObj = roomModel:FindFirstChild("Sign")
        or roomModel:FindFirstChild("Backrooms Egg")
        or roomModel:FindFirstChild("EggPedestal")
        or roomModel:FindFirstChildWhichIsA("BasePart", true)
    
    if targetObj then
        if targetObj:IsA("BasePart") then
            if targetObj.CanCollide then
                character:MoveTo(targetObj.Position)
            else
                rootPart.CFrame = CFrame.new(targetObj.Position + Vector3.new(0, 5, 0))
            end
        elseif targetObj:IsA("Model") then
            if targetObj.PrimaryPart then
                if targetObj.PrimaryPart.CanCollide then
                    character:MoveTo(targetObj.PrimaryPart.Position)
                else
                    rootPart.CFrame = CFrame.new(targetObj.PrimaryPart.Position + Vector3.new(0, 5, 0))
                end
            end
        elseif targetObj.WorldPivot then
            rootPart.CFrame = targetObj.WorldPivot
        end
    end

    _G.Teleporting = false
    return true
end

local function TeleportToDoor(roomModel)
    if _G.Teleporting then return false end
    _G.Teleporting = true

    local character = getCharacter()
    if not character then _G.Teleporting = false return false end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then _G.Teleporting = false return false end

    Network.Fire("RequestStreaming", roomModel:GetPivot().Position)

    local forceField = Instance.new("ForceField")
    forceField.Visible = false
    forceField.Parent = character
    task.delay(5, function()
        rootPart.Anchored = false
        if forceField.Parent then forceField:Destroy() end
    end)

    rootPart.Anchored = true
    task.wait(0.3)

    local lockCFrame = getLockPosition(roomModel)
    if lockCFrame then
        rootPart.CFrame = lockCFrame
    else
        local sign = roomModel:FindFirstChild("Sign")
        rootPart.CFrame = sign and sign:GetPivot() or roomModel:GetPivot()
    end

    _G.Teleporting = false
    return true
end

local function TeleportToChest(chest)
    if _G.Teleporting then return false end
    _G.Teleporting = true

    local character = getCharacter()
    if not character then _G.Teleporting = false return false end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then _G.Teleporting = false return false end

    Network.Fire("RequestStreaming", chest:GetPivot().Position)

    local forceField = Instance.new("ForceField")
    forceField.Visible = false
    forceField.Parent = character
    task.delay(5, function()
        rootPart.Anchored = false
        if forceField.Parent then forceField:Destroy() end
