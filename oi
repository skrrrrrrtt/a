-- ============================================================
-- STEP 1: Center + load
-- ============================================================
local function getRoughCenter()
    local sum = Vector3.new(0, 0, 0)
    local count = 0
    for _, v in ipairs(root:GetChildren()) do
        local part = v:FindFirstChildWhichIsA("BasePart", true)
        if part then
            sum += part.Position
            count += 1
        end
    end
    if count == 0 then return Vector3.new(0, 1600, 0) end
    return sum / count
end

setStatus("⟳  Teleporting to center...", Color3.fromRGB(160, 120, 220))
local center = getRoughCenter()
hrp.CFrame = CFrame.new(center.X, center.Y + 5, center.Z)

setStatus("⟳  Waiting for chunks to load...", Color3.fromRGB(160, 120, 220))
task.wait(5)

-- ============================================================
-- STEP 2: Measure bounds
-- ============================================================
setStatus("⟳  Measuring bounds...", Color3.fromRGB(160, 120, 220))

local bMin = Vector3.new(math.huge, math.huge, math.huge)
local bMax = Vector3.new(-math.huge, -math.huge, -math.huge)

for _, v in ipairs(root:GetDescendants()) do
    if v:IsA("BasePart") then
        local p = v.Position
        local s = v.Size / 2
        bMin = Vector3.new(math.min(bMin.X, p.X - s.X), math.min(bMin.Y, p.Y - s.Y), math.min(bMin.Z, p.Z - s.Z))
        bMax = Vector3.new(math.max(bMax.X, p.X + s.X), math.max(bMax.Y, p.Y + s.Y), math.max(bMax.Z, p.Z + s.Z))
    end
end

if bMin.X == math.huge then
    warn("[Scanner] Fallback bounds used.")
    bMin = Vector3.new(-5412, 1500, -2442)
    bMax = Vector3.new(-3724, 1600, -934)
end

bMin = bMin - Vector3.new(PAD, 0, PAD)
bMax = bMax + Vector3.new(PAD, 0, PAD)

local FLY_Y = bMin.Y + FLY_Y_OFFSET

-- ============================================================
-- STEP 3: Scan for miniboss only
-- ============================================================
local foundBossRoom = nil

local function scanForMiniboss()
    for _, room in ipairs(root:GetChildren()) do
        if room.Name == "MiniBossRoom" then
            local part = room:FindFirstChildWhichIsA("BasePart", true)
            if part then
                local roomUID = room:GetAttribute("RoomUID")
                local chestUID = room:GetAttribute("BossChestUID")
                local breakZone = room:FindFirstChild("BREAK_ZONE", true)
                local breakPos = breakZone and breakZone.Position or part.Position

                foundBossRoom = {
                    room = room,
                    roomUID = roomUID,
                    chestUID = chestUID,
                    position = part.Position,
                    breakPos = breakPos
                }
                return true
            end
        end
    end
    return false
end

-- Build snake path
local waypoints = {}
local rowIndex = 0

for x = bMin.X, bMax.X, STEP do
    local zStart, zEnd, zStep
    if rowIndex % 2 == 0 then
        zStart, zEnd, zStep = bMin.Z, bMax.Z, STEP
    else
        zStart, zEnd, zStep = bMax.Z, bMin.Z, -STEP
    end
    for z = zStart, zEnd, zStep do
        table.insert(waypoints, Vector3.new(x, FLY_Y, z))
    end
    rowIndex += 1
end

setStatus(string.format("⟳  Scanning %d waypoints...", #waypoints), Color3.fromRGB(160, 120, 220))

-- ============================================================
-- STEP 4: Fly + scan
-- ============================================================
local waypointIndex = 1
local done = false

local conn = RunService.Heartbeat:Connect(function(dt)
    if done or waypointIndex > #waypoints then
        done = true
        return
    end

    local target = waypoints[waypointIndex]
    local current = hrp.Position
    local direction = (target - current)
    local dist = direction.Magnitude
    local moveStep = FLY_SPEED * dt

    if dist <= moveStep then
        hrp.CFrame = CFrame.new(target)
        waypointIndex += 1
        local pct = waypointIndex / #waypoints
        setProgress(pct)
        setStatus(string.format("⟳  Scanning... %d%%", math.floor(pct * 100)), Color3.fromRGB(160, 120, 220))
    else
        local newPos = current + direction.Unit * moveStep
        hrp.CFrame = CFrame.new(newPos, newPos + direction.Unit)
    end

    -- Scan every frame
    if not foundBossRoom then
        scanForMiniboss()
    end
end)

repeat task.wait(0.5) until done or foundBossRoom
conn:Disconnect()

-- ============================================================
-- STEP 5: Handle found miniboss
-- ============================================================
