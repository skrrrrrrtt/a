-- STEP 7: Go to BREAK_ZONE and wait for chest to spawn
-- ============================================================
setStatus("⟶  Moving to BREAK_ZONE...", Color3.fromRGB(160, 120, 220))
humanoid:MoveTo(foundBossRoom.breakPos)
humanoid.MoveToFinished:Wait()

setStatus("⟳  Waiting for chest to spawn...", Color3.fromRGB(160, 120, 220))

-- Keep refreshing chest UID if not set yet
local chestUID = foundBossRoom.chestUID
local t0 = tick()
while not chestUID and tick() - t0 < 10 do
    task.wait(POLL_INTERVAL)
    chestUID = foundBossRoom.room:GetAttribute("BossChestUID")
end

if not chestUID then
    setStatus("✗  Chest UID not assigned!", Color3.fromRGB(220, 80, 80))
    return
end

-- Get chest model
local chest = nil
t0 = tick()
while not chest and tick() - t0 < 10 do
    task.wait(0.2)
    chest = BreakableCmds.Get(chestUID)
end

if not chest then
    setStatus("✗  Chest model not found!", Color3.fromRGB(220, 80, 80))
    return
end

setStatus("⟳  Waiting for chest to walk to zone...", Color3.fromRGB(160, 120, 220))

-- Wait for chest to arrive at break zone (distance < 14 from source code)
local waitCount = 0
repeat
    task.wait(0.5)
    if chest and chest.Parent then
        local chestPos = chest:GetPivot().Position
        local targetPos = foundBossRoom.room:GetAttribute("BossChestTarget")
        if targetPos then
            local dist = (chestPos - targetPos).Magnitude
            if dist < 14 then break end
        end
    end
    waitCount += 1
    if waitCount > 40 then
        setStatus("⚠  Chest taking too long, proceeding anyway...", Color3.fromRGB(220, 160, 60))
        break
    end
until false

task.wait(1)

-- ============================================================
-- STEP 8: Interact with chest to break it (Auto-Tap & Priority)
-- ============================================================
setStatus("⚔  Breaking chests (Auto-Tap & Priority)...", Color3.fromRGB(220, 100, 60))

local interactRemote = game.ReplicatedStorage:FindFirstChild("BreakableInteract", true)
    or game.ReplicatedStorage:FindFirstChild("Interact", true)
    or game.ReplicatedStorage:FindFirstChild("BreakCmds", true)

local dealDamageRemote = nil
pcall(function()
    dealDamageRemote = game:GetService("ReplicatedStorage").Network:FindFirstChild("Breakables_PlayerDealDamage")
end)

-- Main Attack Loop
task.spawn(function()
    while task.wait(0.1) do
        local targetUID = chestUID
        local targetChest = chest

        -- Scan for spawned sub-boss rooms (MiniBossRoom)
        local foundSubChest = false
        for _, room in ipairs(root:GetChildren()) do
            if room.Name == "MiniBossRoom" then
                local subUID = room:GetAttribute("BossChestUID")
                -- If it's a valid chest and NOT the main chest we originally targeted
                if subUID and subUID ~= chestUID then
                    local subChest = BreakableCmds.Get(subUID)
                    if subChest and subChest.Parent then
                        targetUID = subUID
                        targetChest = subChest
                        foundSubChest = true
                        break
                    end
                end
            end
        end

        if targetChest and targetChest.Parent then
            local tPos = targetChest:GetPivot().Position
            
            -- Move into range if needed
            if (hrp.Position - tPos).Magnitude > INTERACT_RANGE then
                hrp.CFrame = CFrame.new(tPos)
            end

            -- Fire Proximity/Interact
            if interactRemote and interactRemote:IsA("RemoteEvent") then
                interactRemote:FireServer(targetUID)
            else
                local prompt = targetChest:FindFirstChildOfClass("ProximityPrompt", true)
                if prompt then
                    fireproximityprompt(prompt)
                end
            end

            -- Auto-Tap
            if dealDamageRemote then
                dealDamageRemote:FireServer(targetUID)
            end
        end
    end
end)

setStatus("✓  Auto-farming active! Collecting drops & breaking chests...", Color3.fromRGB(80, 220, 120))
