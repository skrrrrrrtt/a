local lp = game.Players.LocalPlayer
local char = lp.Character
local hrp = char.HumanoidRootPart
local hum = char:FindFirstChildOfClass("Humanoid")
local RunService = game:GetService("RunService")
local RS = game:GetService("ReplicatedStorage")
local genBackrooms = workspace.__THINGS.__INSTANCE_CONTAINER.Active.Backrooms.GeneratedBackrooms

-- egg name lookup
local eggsFolder = RS.__DIRECTORY.Eggs["Backrooms Update 2"]
local multiToEgg = {}
for _, egg in pairs(eggsFolder:GetChildren()) do
    local multi = tonumber(egg.Name:match("(%d+)x$"))
    local eggName = egg.Name:match("%| (.+) %d+x$")
    if multi and eggName and not multiToEgg[multi] then
        multiToEgg[multi] = eggName
    end
end

-- found eggs table
local found = {}
local foundKeys = {} -- to avoid duplicates

local function tryAddRoom(room)
    local roomID = room:GetAttribute("RoomID") or ""
    local multi = room:GetAttribute("EggMultiplier")
    if not roomID:lower():find("egg") or not multi then return end

    local key = roomID .. "_" .. tostring(multi) .. "_" .. tostring(room)
    if foundKeys[key] then return end

    -- wait a bit for EggModel to load
    local eggModel = room:FindFirstChild("EggModel", true)
    if not eggModel then
        task.delay(0.5, function()
            eggModel = room:FindFirstChild("EggModel", true)
            if not eggModel then return end
            local part = eggModel:FindFirstChildWhichIsA("BasePart")
            if not part then return end
            foundKeys[key] = true
            local eggName = multiToEgg[multi] or "Unknown"
            table.insert(found, {
                name = eggName, multi = multi,
                part = part, deep = room:GetAttribute("DeepRoom"),
                roomID = roomID, room = room
            })
            print("[+] " .. eggName .. " [" .. multi .. "x]")
        end)
        return
    end

    local part = eggModel:FindFirstChildWhichIsA("BasePart")
    if not part then return end
    foundKeys[key] = true
    local eggName = multiToEgg[multi] or "Unknown"
    table.insert(found, {
        name = eggName, multi = multi,
        part = part, deep = room:GetAttribute("DeepRoom"),
        roomID = roomID, room = room
    })
    print("[+] " .. eggName .. " [" .. multi .. "x]")
end

-- scan already loaded rooms
for _, room in pairs(genBackrooms:GetChildren()) do
    pcall(tryAddRoom, room)
end

-- watch for new rooms loading
local roomWatcher = genBackrooms.ChildAdded:Connect(function(room)
    task.wait(0.3) -- let attributes load
    pcall(tryAddRoom, room)
end)

-- noclip + fly setup
hum.PlatformStand = true
local noclip = RunService.Stepped:Connect(function()
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end)

-- get bounds
local minX, maxX, minZ, maxZ, sumY, countY = math.huge, -math.huge, math.huge, -math.huge, 0, 0
for _, room in pairs(genBackrooms:GetChildren()) do
    local base = room:FindFirstChild("Baseplate")
    if base and base:IsA("BasePart") then
        local p = base.Position
        minX = math.min(minX, p.X)
        maxX = math.max(maxX, p.X)
        minZ = math.min(minZ, p.Z)
        maxZ = math.max(maxZ, p.Z)
        sumY = sumY + p.Y
        countY = countY + 1
    end
end

-- expand bounds slightly to catch edge rooms
minX = minX - 100
maxX = maxX + 100
minZ = minZ - 100
maxZ = maxZ + 100
local flyY = (countY > 0 and sumY/countY or hrp.Position.Y) + 8
local stepSize = 50 -- tighter grid to ensure everything loads
local waitPerStep = 0.06

-- status UI
local sg = Instance.new("ScreenGui")
sg.Name = "SweepUI"
sg.Parent = game:GetService("CoreGui")
local frame = Instance.new("Frame", sg)
frame.Size = UDim2.new(0, 380, 0, 65)
frame.Position = UDim2.new(0.5, -190, 0, 10)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.BorderSizePixel = 0
Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)

local lbl = Instance.new("TextLabel", frame)
lbl.Size = UDim2.new(1,-10,0.5,0)
lbl.Position = UDim2.new(0,5,0,4)
lbl.BackgroundTransparency = 1
lbl.TextColor3 = Color3.fromRGB(255,200,0)
lbl.Font = Enum.Font.GothamBold
lbl.TextSize = 13
lbl.Text = "🔍 Exploring backrooms..."
lbl.TextXAlignment = Enum.TextXAlignment.Left

local lbl2 = Instance.new("TextLabel", frame)
lbl2.Size = UDim2.new(1,-10,0.5,0)
lbl2.Position = UDim2.new(0,5,0.5,0)
lbl2.BackgroundTransparency = 1
lbl2.TextColor3 = Color3.fromRGB(100,220,100)
lbl2.Font = Enum.Font.Gotham
lbl2.TextSize = 12
lbl2.Text = "Eggs found: 0"
lbl2.TextXAlignment = Enum.TextXAlignment.Left

local stopped = false
local stopBtn = Instance.new("TextButton", frame)
stopBtn.Size = UDim2.new(0,70,0,28)
stopBtn.Position = UDim2.new(1,-75,0.5,-14)
stopBtn.BackgroundColor3 = Color3.fromRGB(180,30,30)
stopBtn.TextColor3 = Color3.new(1,1,1)
stopBtn.Font = Enum.Font.GothamBold
stopBtn.TextSize = 12
stopBtn.Text = "STOP"
stopBtn.BorderSizePixel = 0
Instance.new("UICorner", stopBtn).CornerRadius = UDim.new(0,4)
stopBtn.MouseButton1Click:Connect(function() stopped = true end)

-- snake path
local waypoints = {}
local row = 0
local z = minZ
while z <= maxZ do
    local xStep = (row % 2 == 0) and stepSize or -stepSize
    local xStart = (row % 2 == 0) and minX or maxX
    local xEnd = (row % 2 == 0) and maxX or minX
    local x = xStart
    repeat
        table.insert(waypoints, Vector3.new(x, flyY, z))
        x = x + xStep
    until (xStep > 0 and x > xEnd) or (xStep < 0 and x < xEnd)
    z = z + stepSize
    row = row + 1
end

print("flying " .. #waypoints .. " waypoints | stepSize=" .. stepSize)

for i, wp in pairs(waypoints) do
    if stopped then break end
    hrp.CFrame = CFrame.new(wp)
    task.wait(waitPerStep)
    if i % 15 == 0 then
        local pct = math.floor(i/#waypoints*100)
        lbl.Text = "🔍 " .. pct .. "% | rooms: " .. #genBackrooms:GetChildren()
        lbl2.Text = "🥚 Eggs found: " .. #found
    end
end

roomWatcher:Disconnect()
noclip:Disconnect()
hum.PlatformStand = false

-- wait a moment for any delayed additions
task.wait(1)

-- final sort
table.sort(found, function(a,b) return a.multi < b.multi end)

lbl.Text = "✅ Done! " .. #found .. " egg rooms found"
lbl2.Text = "Building UI..."
task.wait(1.5)
sg:Destroy()

print("=== FINAL EGG LIST ===")
for _, e in pairs(found) do
    print(e.name .. " [" .. e.multi .. "x] deep=" .. tostring(e.deep))
end

-- TP UI
local sg2 = Instance.new("ScreenGui")
sg2.Name = "BackroomEggTP"
sg2.ResetOnSpawn = false
sg2.Parent = game:GetService("CoreGui")

local main = Instance.new("Frame", sg2)
main.Size = UDim2.new(0, 330, 0, 460)
main.Position = UDim2.new(0.5, -165, 0.5, -230)
main.BackgroundColor3 = Color3.fromRGB(22,22,22)
main.BorderSizePixel = 0
main.Active = true
main.Draggable = true
Instance.new("UICorner", main).CornerRadius = UDim.new(0,8)

local titleBar = Instance.new("Frame", main)
titleBar.Size = UDim2.new(1,0,0,38)
titleBar.BackgroundColor3 = Color3.fromRGB(15,15,15)
titleBar.BorderSizePixel = 0
Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0,8)

local titleLbl = Instance.new("TextLabel", titleBar)
titleLbl.Size = UDim2.new(1,-40,1,0)
titleLbl.Position = UDim2.new(0,10,0,0)
titleLbl.BackgroundTransparency = 1
titleLbl.TextColor3 = Color3.fromRGB(255,200,0)
titleLbl.Font = Enum.Font.GothamBold
titleLbl.TextSize = 13
titleLbl.TextXAlignment = Enum.TextXAlignment.Left
titleLbl.Text = "🟡 Backroom Eggs — " .. #found .. " rooms"

local closeBtn = Instance.new("TextButton", titleBar)
closeBtn.Size = UDim2.new(0,28,0,28)
closeBtn.Position = UDim2.new(1,-32,0,5)
closeBtn.BackgroundColor3 = Color3.fromRGB(180,30,30)
closeBtn.TextColor3 = Color3.new(1,1,1)
closeBtn.Text = "X"
closeBtn.Font = Enum.Font.GothamBold
closeBtn.TextSize = 12
closeBtn.BorderSizePixel = 0
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0,4)
closeBtn.MouseButton1Click:Connect(function() sg2:Destroy() end)

local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1,-10,1,-48)
scroll.Position = UDim2.new(0,5,0,43)
scroll.BackgroundTransparency = 1
scroll.ScrollBarThickness = 4
scroll.BorderSizePixel = 0
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.CanvasSize = UDim2.new(0,0,0,0)
Instance.new("UIListLayout", scroll).Padding = UDim.new(0,4)

if #found == 0 then
    local empty = Instance.new("TextLabel", scroll)
    empty.Size = UDim2.new(1,-8,0,40)
    empty.BackgroundTransparency = 1
    empty.TextColor3 = Color3.fromRGB(180,180,180)
    empty.Text = "No egg rooms found"
    empty.Font = Enum.Font.Gotham
    empty.TextSize = 12
end

for _, egg in pairs(found) do
    local col
    if egg.multi >= 50 then col = Color3.fromRGB(255,60,60)
    elseif egg.multi >= 20 then col = Color3.fromRGB(255,140,0)
    elseif egg.multi >= 10 then col = Color3.fromRGB(255,220,0)
    else col = Color3.fromRGB(80,210,80) end

    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1,-8,0,44)
    btn.BackgroundColor3 = Color3.fromRGB(38,38,38)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.BorderSizePixel = 0
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.Text = "    " .. egg.name .. (egg.deep and "  🔵" or "")
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,5)

    local accent = Instance.new("Frame", btn)
    accent.Size = UDim2.new(0,5,1,0)
    accent.BackgroundColor3 = col
    accent.BorderSizePixel = 0
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0,4)

    local multiTag = Instance.new("TextLabel", btn)
    multiTag.Size = UDim2.new(0,55,1,0)
    multiTag.Position = UDim2.new(1,-60,0,0)
    multiTag.BackgroundTransparency = 1
    multiTag.TextColor3 = col
    multiTag.Font = Enum.Font.GothamBold
    multiTag.TextSize = 14
    multiTag.Text = egg.multi .. "x"

    btn.MouseButton1Click:Connect(function()
        local c = lp.Character
        if not c or not c:FindFirstChild("HumanoidRootPart") then return end
        -- re-find fresh part
        local freshEggModel = egg.room:FindFirstChild("EggModel", true)
        local freshPart = freshEggModel and freshEggModel:FindFirstChildWhichIsA("BasePart")
        local target = freshPart or egg.part
        if not target or not target.Parent then
            btn.Text = "    [GONE] " .. egg.name
            btn.BackgroundColor3 = Color3.fromRGB(60,20,20)
            return
        end
        c.HumanoidRootPart.CFrame = target.CFrame + Vector3.new(0,5,0)
        btn.BackgroundColor3 = Color3.fromRGB(20,60,20)
        task.delay(1.5, function() btn.BackgroundColor3 = Color3.fromRGB(38,38,38) end)
    end)
end
