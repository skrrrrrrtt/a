-- Crypto Trader v2 | Street Life Remastered

local RS  = game:GetService("ReplicatedStorage")
local LP  = game:GetService("Players").LocalPlayer

local BUY_BELOW      = 5000
local SELL_ABOVE     = 8000
local CHECK_INTERVAL = 15

local holding  = false
local boughtAt = 0
local currentPrice = nil

local PhoneRemote = RS:WaitForChild("Remotes"):WaitForChild("Phone")
local Handler = LP:WaitForChild("PlayerGui"):WaitForChild("PhoneUI"):WaitForChild("Handler")

-- listen to what server sends back (price updates come from here)
Handler.OnClientEvent:Connect(function(...)
    local args = {...}
    -- print raw so we can see the structure
    print("[Crypto] Handler fired:", table.unpack(args))
    for _, v in ipairs(args) do
        if type(v) == "number" and v >= 1000 and v <= 50000 then
            currentPrice = v
            print(string.format("[Crypto] Price updated: $%d", currentPrice))
        end
    end
end)

local function openCryptoPage()
    -- fires the phone to open crypto, which triggers server to send back price
    PhoneRemote:FireServer("Crypto", "Open")
    task.wait(1)
end

local function buy(price)
    print(string.format("[Crypto] BUYING at $%d", price))
    PhoneRemote:FireServer("Crypto", "Purchase", price)
    holding = true
    boughtAt = price
end

local function sell(price)
    local profit = price - boughtAt
    print(string.format("[Crypto] SELLING at $%d | Profit: $%d", price, profit))
    PhoneRemote:FireServer("Crypto", "Sell", price)
    holding = false
    boughtAt = 0
end

task.spawn(function()
    print("[Crypto] Trader v2 started")
    while true do
        -- poke the phone to get a fresh price from server
        openCryptoPage()
        task.wait(2) -- wait for Handler to fire back with price

        if not currentPrice then
            print("[Crypto] No price yet, retrying...")
            task.wait(CHECK_INTERVAL)
            continue
        end

        print(string.format("[Crypto] Price: $%d | Holding: %s | BoughtAt: $%d", currentPrice, tostring(holding), boughtAt))

        if not holding then
            if currentPrice <= BUY_BELOW then
                buy(currentPrice)
            else
                print(string.format("[Crypto] Too expensive ($%d), waiting for dip below $%d", currentPrice, BUY_BELOW))
            end
        else
            if currentPrice >= SELL_ABOVE then
                sell(currentPrice)
            else
                print(string.format("[Crypto] Holding... waiting for $%d (now $%d, bought $%d)", SELL_ABOVE, currentPrice, boughtAt))
            end
        end

        task.wait(CHECK_INTERVAL)
    end
end)
