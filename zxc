-- get positions and sort
local positions = getRoomPositions()
local sorted = sortNearest(positions, hrp.Position)

-- add midpoints between far rooms so streaming catches everything
local waypoints = {}
for i, pos in pairs(sorted) do
    local flyPos = Vector3.new(pos.X, pos.Y + 8, pos.Z)
    table.insert(waypoints, flyPos)
    -- if next room is far, add midpoint
    if sorted[i+1] then
        local nextPos = sorted[i+1]
        local dist = (pos - nextPos).Magnitude
        if dist > 200 then
            local mid = pos:Lerp(nextPos, 0.5)
            table.insert(waypoints, Vector3.new(mid.X, pos.Y + 8, mid.Z))
        end
    end
end

print("flying " .. #waypoints .. " waypoints (room to room)")
lbl.Text = "🔍 Flying room to room..."

for i, wp in pairs(waypoints) do
    if stopped then break end
    hrp.CFrame = CFrame.new(wp)
    task.wait(0.08) -- pause at each room to let it stream
    if i % 5 == 0 then
        lbl.Text = "🔍 " .. math.floor(i/#waypoints*100) .. "% | rooms: " .. #genBackrooms:GetChildren()
        lbl2.Text = "🥚 Eggs: " .. #found
    end
end

