-- ================================================
-- CACHE MANAGER
-- Watches for AdvancedDigsite to appear/disappear
-- and updates AB/AC without any per-frame polling
-- ================================================
local cacheConnections = {}

local function ClearCache()
    for _, c in ipairs(cacheConnections) do
        pcall(function() c:Disconnect() end)
    end
    cacheConnections = {}
    AB = nil
    AC = nil
end

local function SetupCache(digsite)
    ClearCache()
    local imp = digsite:FindFirstChild("Important")
    if not imp then return end

    AB = imp:FindFirstChild("ActiveBlocks")
    AC = imp:FindFirstChild("ActiveChests")

    -- If Important children appear later
    table.insert(cacheConnections, imp.ChildAdded:Connect(function(child)
        if child.Name == "ActiveBlocks" then AB = child end
        if child.Name == "ActiveChests"  then AC = child end
    end))
    table.insert(cacheConnections, imp.ChildRemoved:Connect(function(child)
        if child.Name == "ActiveBlocks" then AB = nil end
        if child.Name == "ActiveChests"  then AC = nil end
    end))
end

