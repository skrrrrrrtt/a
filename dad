-- ================================================
-- FARMING  — single loop, cached AB/AC
-- Priority: Purple (always) → Chest → Row
-- ================================================
local function FarmPurple()
    if not AB then return false end
    for _,part in ipairs(AB:GetChildren()) do
        if part:IsA("BasePart") and part.BrickColor==BrickColor.new("Royal purple") then
            currentTarget="🟣 PURPLE"
            part.Name="TargetBlock"
            repeat
                TP(part.Position)
                FireDig("DigBlock", part:GetAttribute("Coord"))
                DigsTotal=DigsTotal+1
                task.wait(DIG_RATE)
            until not AB or not AB:FindFirstChild("TargetBlock")
            return true
        end
    end
    return false
end

local function FarmChest()
    if not AC then return false end
    local best,bestD=nil,math.huge
    for _,c in ipairs(AC:GetChildren()) do
        if c:IsA("Model") and c:FindFirstChild("Top") then
            local d=(HRP.Position-c.Top.Position).Magnitude
            if d<bestD then best=c; bestD=d end
        end
    end
    if not best then return false end
    currentTarget="📦 CHEST"
    local t0=tick()
    repeat
        TP(best.Top.Position)
        FireDig("DigChest", best:GetAttribute("Coord"))
        DigsTotal=DigsTotal+1
        task.wait(DIG_RATE)
        if tick()-t0>3 then pcall(function() best:Destroy() end); break end
    until not best.Parent
    return true
end

local function FarmRow()
    if not AB then return end
    local tgt=TargetPositions[math.random(1,#TargetPositions)]
    local nums=string.split(tgt,","); local tx=tonumber(nums[1])
    local best={}; local hy=-math.huge
    for _,part in ipairs(AB:GetChildren()) do
        if part:IsA("BasePart")
            and part.BrickColor~=BrickColor.new("Really black")
            and part.BrickColor~=BrickColor.new("Royal purple") then
            local coord=part:GetAttribute("Coord")
            if coord then
                local cn=string.split(tostring(coord),",")
                local cx,cy=tonumber(cn[1]),tonumber(cn[2])
                if cx==tx then
                    if cy>hy then best={part}; hy=cy
                    elseif cy==hy then table.insert(best,part) end
                end
            end
        end
    end
    if #best>0 then
        local sel=best[math.random(1,#best)]
        currentTarget="⛏ ROW "..tgt
        sel.Name="TargetBlock"
        repeat
            TP(sel.Position)
            FireDig("DigBlock", sel:GetAttribute("Coord"))
            DigsTotal=DigsTotal+1
            task.wait(DIG_RATE)
        until not AB or not AB:FindFirstChild("TargetBlock")
    end
end

-- THE MAIN LOOP — only one tight loop in the whole script
task.spawn(function()
    while task.wait(DIG_RATE) do
        if not RUNNING or not AB then continue end
        if not FarmPurple() then
            if not FarmChest() then
                FarmRow()
            end
        end
    end
end)

