-- // Live Monitor Function
task.spawn(function()
    while true do
        local Save = GetSave()
        if Save then
            local Inventory = Save.Inventory
            
            for _, itemData in pairs(TrackedItems) do
                local count = 0
                
                if itemData.ID == "Diamonds" then
                    count = Save.Diamonds or 0
                else
                    -- Search inventory for matches
                    for _, v in pairs(Inventory) do
                        if v.id == itemData.ID then
                            count = count + (v._am or 1)
                        end
                    end
                end
                
                if Rows[itemData.Name] then
                    Rows[itemData.Name].Text = string.format("%s: %s", itemData.Name, FormatNumber(count))
                end
            end
        end
        task.wait(1) -- Update every second
    end
end)

