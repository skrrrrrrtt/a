        -- Watch for AdvancedDigsite appearing
        Active.ChildAdded:Connect(function(child)
            if child.Name == "AdvancedDigsite" then
                task.wait(0.5) -- let it load
                SetupCache(child)
            end
        end)
        Active.ChildRemoved:Connect(function(child)
            if child.Name == "AdvancedDigsite" then ClearCache() end
        end)
        -- Already there?
        local ads = Active:FindFirstChild("AdvancedDigsite")
        if ads then SetupCache(ads) end
    end

    -- Wait for __THINGS and Active to exist
    local things = Workspace:WaitForChild("__THINGS", 30)
    if not things then return end
    local container = things:WaitForChild("__INSTANCE_CONTAINER", 30)
    if not container then return end
    local Active = container:WaitForChild("Active", 30)
    if not Active then return end
    watchActive(Active)
end)

