local function SendWebhook()
    if not WebhookEnabled then return end
    if WEBHOOK_URL=="YOUR_WEBHOOK_URL_HERE" or WEBHOOK_URL=="" then return end
    local body=HttpService:JSONEncode({embeds={{
        title="🪣 Digsite Farm Report",color=0x00DC64,
        fields={
            {name="Session",       value=FormatTime(os.time()-SessionStart),inline=true},
            {name="Digs",          value=tostring(DigsTotal),    inline=true},
            {name="Chests",        value=tostring(ChestsBroken), inline=true},
            {name="Buckets",       value=tostring(BucketAmount), inline=true},
            {name="Magic Bucket",  value=tostring(MagicBucketAM),inline=true},
            {name="Huge Potions",  value=tostring(hugeamount),   inline=true},
            {name="Mailed",        value=tostring(PotionsSent),  inline=true},
            {name="Diamonds",      value=tostring(DiamondsAmount),inline=true},
        },
        footer={text="Digsite Farm v4.0 • "..os.date("!%Y-%m-%d %H:%M UTC")}
    }}})
    pcall(function() game:HttpPost(WEBHOOK_URL,body,false,"application/json") end)
end
