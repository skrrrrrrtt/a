local function getOwnedFilePath()
    return "SlimeRNG_" .. player.Name:gsub("[^%w_%-]","_") .. "_upgrades.json"
end
local OWNED_FILE = getOwnedFilePath()
local ownedUpgrades = {}
local ownedUpgradesLookup = {}

local function loadOwnedUpgrades()
    local ok, data = pcall(readfile, OWNED_FILE)
    if ok and data and data ~= "" then
        local ok2, decoded = pcall(function() return httpService:JSONDecode(data) end)
        if ok2 and type(decoded) == "table" then
            ownedUpgrades = decoded
            ownedUpgradesLookup = {}
            for _, id in ipairs(ownedUpgrades) do ownedUpgradesLookup[id] = true end
            return true
        end
    end
    ownedUpgrades = {}; ownedUpgradesLookup = {}
    return false
end

local function saveOwnedUpgrade(id)
    if ownedUpgradesLookup[id] then return end
    table.insert(ownedUpgrades, id)
    ownedUpgradesLookup[id] = true
    pcall(function() writefile(OWNED_FILE, httpService:JSONEncode(ownedUpgrades)) end)
end

local function isUpgradeOwned(id)      return ownedUpgradesLookup[id] == true end
local function isUpgradeBlacklisted(id)
    for _, b in ipairs(getgenv().UpgradeBlacklist) do if id == b then return true end end
    return false
end

