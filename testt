            {name="Ultra Luck",key="ultraLuck"},
            {name="Currency",  key="currency"},
            {name="Roll Spd",  key="rollSpeed"},
        }
        local bRefs = {}
        for i, bd in ipairs(boostDefs) do
            local row = Instance.new("Frame", card)
            row.Size=UDim2.new(1,-16, 0, 20)
            row.Position=UDim2.new(0,8,0, 30+(i-1)*26)
            row.BackgroundTransparency=1

            local dot = Instance.new("Frame", row)
            dot.Size=UDim2.new(0,8,0,8); dot.Position=UDim2.new(0,0,0.5,-4)
            dot.BackgroundColor3=BAD; dot.BorderSizePixel=0
            Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)

            local nameLbl = Instance.new("TextLabel", row)
            nameLbl.Size=UDim2.new(0.55,0,1,0); nameLbl.Position=UDim2.new(0,14,0,0)
            nameLbl.BackgroundTransparency=1; nameLbl.Text=bd.name
            nameLbl.TextColor3=TXT; nameLbl.TextSize=13; nameLbl.Font=Enum.Font.Gotham
            nameLbl.TextXAlignment=Enum.TextXAlignment.Left

            local stLbl = Instance.new("TextLabel", row)
            stLbl.Size=UDim2.new(0.42,0,1,0); stLbl.Position=UDim2.new(0.58,0,0,0)
            stLbl.BackgroundTransparency=1; stLbl.Text="OFF"
            stLbl.TextColor3=BAD; stLbl.TextSize=13; stLbl.Font=Enum.Font.Code
            stLbl.TextXAlignment=Enum.TextXAlignment.Right

            bRefs[bd.key] = {dot=dot, lbl=stLbl}
        end
        refs["boosts"] = bRefs
    end

    local goldC   = Color3.fromRGB(255, 200, 60)
    local tealC   = Color3.fromRGB(0, 210, 160)
    local blueC   = Color3.fromRGB(60, 140, 255)
    local greenC  = Color3.fromRGB(55, 220, 130)
    local purpC   = Color3.fromRGB(160, 90, 255)
    local pinkC   = Color3.fromRGB(255, 80, 160)
    local orangeC = Color3.fromRGB(255, 140, 40)
    local cyanC   = Color3.fromRGB(40, 200, 255)

    makeCard("COINS",            "coins",  1, goldC)
    makeCard("GOOP",             "goop",   2, tealC)
    makeCard("REBIRTHS",         "rbs",    3, blueC)
    makeCard("ZONE",             "zone",   4, greenC)
    makeCard("SESSION ROLLS",    "rolls",  5, purpC)
    makeCard("SESSION REBIRTHS", "srbs",   6, pinkC)
    makeCard("UPGRADES BOUGHT",  "supg",   7, orangeC)
    makeCard("ZONES UNLOCKED",   "szon",   8, cyanC)
    makeCard("REBIRTH COST",     "rbcost", 9,  Color3.fromRGB(255,100,100))
    makeCard("ROLLS / MIN",      "rpm",    10, Color3.fromRGB(100,255,200))
    makeCard("GOOP %",           "gooppct",11, Color3.fromRGB(80,200,80))
    makeBoostCard(12)

    local rollHistory = {}
    local function getRPM()
        local now = tick()
        table.insert(rollHistory, now)
        while rollHistory[1] and (now - rollHistory[1]) > 60 do
            table.remove(rollHistory, 1)
        end
        return #rollHistory
    end

    spawn(function()
        while true do
            pcall(function()
                local coins   = getCurrentCoins()
                local goop    = getCurrentGoop()
                local rbs     = getRebirthCount()
                local rbcost  = getRebirthCost()
                local zone    = getCurrentMaxZone()
                local uptime  = tick() - Stats.startTime

                refs["coins"].val.Text = fmt(coins)
                refs["goop"].val.Text  = fmt(goop)
                refs["rbs"].val.Text   = fmt(rbs)
                refs["rbs"].sub.Text   = "cost: " .. fmt(rbcost)
                refs["zone"].val.Text  = tostring(zone)

                refs["rolls"].val.Text = fmt(Stats.rolls)
                refs["srbs"].val.Text  = fmt(Stats.rebirths)
                refs["supg"].val.Text  = fmt(Stats.upgrades)
                refs["szon"].val.Text  = fmt(Stats.zones)

                refs["rbcost"].val.Text = fmt(rbcost)
                local canRebirth = goop >= rbcost
                refs["rbcost"].val.TextColor3 = canRebirth and GOOD or VAL
                refs["rbcost"].sub.Text = canRebirth and "READY!" or (fmt(goop).."/"..fmt(rbcost))
                refs["rbcost"].strip.BackgroundColor3 = canRebirth and GOOD or BAD
                refs["rbcost"].sf.BackgroundColor3    = canRebirth and GOOD or BAD

                local rpm = getRPM()
                refs["rpm"].val.Text = tostring(rpm)
                refs["rpm"].sub.Text = "last 60s"

                local goopPct = rbcost > 0 and math.min(100, math.floor(goop/rbcost*100)) or 0
                refs["gooppct"].val.Text = goopPct .. "%"
                refs["gooppct"].sub.Text = fmt(goop) .. " / " .. fmt(rbcost)
                refs["gooppct"].val.TextColor3 = goopPct >= 100 and GOOD or VAL

                statusLbl.Text  = Stats.action
                uptimeLbl.Text  = "up  " .. fmtTime(uptime)

                local bmap = {luck="luck",ultraLuck="ultraLuck",currency="currency",rollSpeed="rollSpeed"}
                if refs["boosts"] then
                    for k, btype in pairs(bmap) do
                        local br = refs["boosts"][btype]
                        if br then
                            local on = isBoostActive(btype)
                            br.dot.BackgroundColor3 = on and GOOD or BAD
                            br.lbl.Text             = on and "ON" or "OFF"
                            br.lbl.TextColor3       = on and GOOD or DIM
                        end
                    end
                end
            end)
            wait(1)
        end
    end)

    spawn(function()
        while true do
            liveDot.BackgroundColor3 = GOOD; wait(0.8)
            liveDot.BackgroundColor3 = CARD; wait(0.3)
        end
    end)
end

