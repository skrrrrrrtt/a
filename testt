local API_URL         = "https://53e3820d-f079-40c3-9121-e74105ff7255-00-rvt1fnaihvtv.pike.replit.dev/api/stats"  -- ← change this
local REPORT_INTERVAL = 30

local function execRequest(url, body)
    local req = (syn and syn.request)
             or (http and http.request)
             or (request)
    req({
        Url     = url,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = body,
    })
end

local function safe(fallback, fn, ...)
    local ok, v = pcall(fn, ...)
    return (ok and v ~= nil) and v or fallback
end

local function sendUpdate()
    local coins  = safe(0,         getCurrentCoins)
    local goop   = safe(0,         getCurrentGoop)
    local rbCost = safe(999999999, getRebirthCost)

    local payload = httpService:JSONEncode({
        playerName     = player.Name,
        coins          = coins,
        goop           = goop,
        rebirths       = safe(0, getRebirthCount),
        maxZone        = safe(1, getCurrentMaxZone),
        rollsSession   = Stats.rolls,
        upgradesBought = Stats.upgrades,
        zonesUnlocked  = Stats.zones,
        currentAction  = Stats.action,
        uptimeSeconds  = tick() - Stats.startTime,
        rebirthCost    = rbCost,
        canRebirth     = (goop >= rbCost),
        boosts = {
            luck      = safe(false, isBoostActive, "luck"),
            ultraLuck = safe(false, isBoostActive, "ultraLuck"),
            currency  = safe(false, isBoostActive, "currency"),
            rollSpeed = safe(false, isBoostActive, "rollSpeed"),
        },
        config = {
            claimRewards      = safe(false, function() return getgenv().Config["Claim Rewards"]        end),
            autoRebirth       = safe(false, function() return getgenv().Config["Auto Rebirth"]         end),
            autoRoll          = safe(false, function() return getgenv().Config["Auto Roll"]            end),
            rollIntervalS     = safe(0.4,   function() return getgenv().Config["Roll Interval(S)"]    end),
            teleportToEnemies = safe(false, function() return getgenv().Config["Teleport To Enemies"]  end),
            autoBuyZones      = safe(false, function() return getgenv().Config["Auto Buy Zones"]       end),
            autoBuyUpgrades   = safe(false, function() return getgenv().Config["Auto Buy Upgrades"]    end),
            autoEquipBest     = safe(false, function() return getgenv().Config["Auto Equip Best"]      end),
            deleteUnnecessary = safe(false, function() return getgenv().Config["Delete Unnecessary"]   end),
            autoUseBoosts     = safe(false, function() return getgenv().Config["Auto Use Boosts"]      end),
        },
    })

    local ok, err = pcall(execRequest, API_URL, payload)
    if not ok then
        warn("[SlimeMonitor] POST failed:", err)
    else
        print("[SlimeMonitor] Sent ✓ (" .. player.Name .. ")")
    end
end

task.spawn(function()
    print("[SlimeMonitor] Reporter started → " .. API_URL)
    while true do
        pcall(sendUpdate)
        task.wait(REPORT_INTERVAL)
    end
end)
