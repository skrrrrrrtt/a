    if isUpgradeBlacklisted(id) or isUpgradeOwned(id) then return false end
    local cost = 0
    for _, item in ipairs(upgradesWithCost) do if item[1]==id then cost=item[2]; break end end
    if coins < cost then return false end
    local remote = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.UpgradeService.RemoteFunction
    local ok, result = pcall(function() return remote:InvokeServer("requestUnlock", id) end)
    if ok and result == true then saveOwnedUpgrade(id); return true end
    return false
end

