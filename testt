local function getGameplayFolder()
    local net = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker
    if not net then return nil end
    local rem = net._remotes
    if not rem then return nil end
    for _, child in ipairs(rem:GetChildren()) do
        if child.Name:match("^Gameplay%d+$") then
            local wf = workspace:FindFirstChild(child.Name)
            if wf then return wf, child.Name end
        end
    end
end
local function findFirstEnemyRootPart(folder)
    for _, enemy in pairs(folder:GetChildren()) do
        if enemy:IsA("Model") then
            local root = enemy.PrimaryPart or enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("RootPart")
                      or enemy:FindFirstChild("SlimeBody") or enemy:FindFirstChild("Torso") or enemy:FindFirstChild("UpperTorso")
            if not root then
                for _, d in ipairs(enemy:GetDescendants()) do
                    if d:IsA("BasePart") then root = d; break end
                end
            end
            if root then return root end
        elseif enemy:IsA("BasePart") then return enemy end
    end
end
local function teleportToEnemy()
    if not getgenv().Config["Teleport To Enemies"] then return end
    local char = player.Character or player.CharacterAdded:Wait()
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("RootPart") or char:FindFirstChild("Torso")
    if not root then return end
    local gp = getGameplayFolder()
    if not gp then return end
    local ef = gp:FindFirstChild("Enemies")
    if not ef then return end
    local er = findFirstEnemyRootPart(ef)
    if not er then return end
    root.CFrame = CFrame.new(er.Position + Vector3.new(0,5,-2), er.Position)
    root.AssemblyLinearVelocity = Vector3.zero
    root.Velocity = Vector3.zero
end
local function getLootItems()
    local items = {}
    local lf = workspace:FindFirstChild("Loot")
    if not lf then return items end
    for _, item in pairs(lf:GetChildren()) do
        if item:IsA("BasePart") then table.insert(items, {pos=item.Position})
        elseif item:IsA("Model") then
            local p = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
            if p then table.insert(items, {pos=p.Position}) end
        end
    end
    return items
end
local function teleportToLoot()
    local thr = getgenv().Config["Tp Loot"]
    if type(thr) ~= "number" then return end
    local items = getLootItems()
    if #items < thr then return end
    local char = player.Character; if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
    local nearest, nd = nil, math.huge
    for _, l in ipairs(items) do
        local d = (l.pos - root.Position).magnitude
        if d < nd then nd=d; nearest=l end
    end
    if nearest then root.CFrame = CFrame.new(nearest.pos + Vector3.new(0,1,0)) end
end

