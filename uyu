    {Class = "Pet",      Item = "Huge Cataclysm Bear",   Name = "Huge Cataclysm Bear"},
}

repeat task.wait() until not LocalPlayer.PlayerGui:FindFirstChild("__INTRO")

local Save
local ok, res = pcall(function() return require(ReplicatedStorage.Library.Client.Save) end)
if ok then Save = res else warn("[Monitor] Save failed: " .. tostring(res)) return end

local prevCounts = {}

-- // AVATAR
local function getAvatarThumbnail(userId)
    local ok, response = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=" .. userId .. "&size=420x420&format=Png"
        ))
    end)
    if ok and response and response.data and response.data[1] then
        return response.data[1].imageUrl
    end
    warn("[Monitor] Failed to fetch avatar")
    return nil
end

-- // FORMAT
local function fmtComma(n)
    local s = tostring(math.floor(tonumber(n) or 0))
    return s:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

local function fmtDelta(current, prev)
    if prev == nil then
        return fmtComma(current)
    end
    local delta = current - prev
    local sign = delta >= 0 and "+" or "-"
    return fmtComma(current) .. "\n" .. sign .. fmtComma(math.abs(delta)) .. "/h"
end

-- // GET COUNTS
local function getCounts()
    local counts = {}
    local ok, root = pcall(function() return Save.Get() end)
    if not ok or not root then return counts end

    local inv = root.Inventory or {}

    for _, entry in ipairs(GINVENTORY_COUNTS) do
        local key = entry.Class .. ":" .. entry.Item
        counts[key] = 0

        if entry.Class == "Currency" then
            local cur = inv["Currency"] or root["Currency"] or {}
            if cur[entry.Item] then
                counts[key] = tonumber(cur[entry.Item]) or 0
            else
                for _, v in pairs(cur) do
                    if type(v) == "table" and v.id == entry.Item then
                        counts[key] = tonumber(v._am or 0) or 0
                    end
                end
            end

        elseif entry.Class == "Misc" then
            local classData = inv["Misc"] or {}
            for _, item in pairs(classData) do
                if item.id == entry.Item then
                    counts[key] += tonumber(item._am or 1) or 1
                end
            end

        elseif entry.Class == "Pet" then
            local classData = inv["Pet"] or {}
            for _, item in pairs(classData) do
                if item.id == entry.Item then
                    counts[key] += 1
                end
            end
        end
    end

    return counts
end

-- // SEND WEBHOOK
local function sendWebhook(counts, isFirst, avatarUrl)
    local fields = {}

    -- account field
    table.insert(fields, {
        name = "👤 In Account",
        value = "```" .. LocalPlayer.Name .. "```",
        inline = true
    })

    -- inventory fields
    for _, entry in ipairs(GINVENTORY_COUNTS) do
        local key = entry.Class .. ":" .. entry.Item
        local current = counts[key] or 0
        local prev = isFirst and nil or prevCounts[key]
        table.insert(fields, {
            name = entry.Name or entry.Item,
            value = "```" .. fmtDelta(current, prev) .. "```",
            inline = true
        })
    end

    local webhookData = {
        username = LocalPlayer.Name .. "'s Monitor",
        avatar_url = avatarUrl,
        embeds = {{
            title = "📊 " .. LocalPlayer.Name .. "'s Inventory Report",
            color = 0xFAA61A,
            fields = fields,
            thumbnail = { url = avatarUrl },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            footer = { text = "Next update in 1 hour" }
        }}
    }

    local ok, err = pcall(function()
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(webhookData)
        })
    end)

    if ok then
        print("[Monitor] Sent - " .. LocalPlayer.Name)
    else
        warn("[Monitor] Failed: " .. tostring(err))
    end
end

-- // MAIN
local avatarUrl = getAvatarThumbnail(LocalPlayer.UserId)

local isFirst = true
while true do
    local counts = getCounts()
    sendWebhook(counts, isFirst, avatarUrl)

    for _, entry in ipairs(GINVENTORY_COUNTS) do
        local key = entry.Class .. ":" .. entry.Item
        prevCounts[key] = counts[key]
    end

    isFirst = false
    task.wait(INTERVAL)
end
