-- // CONFIG
local WEBHOOK_URL = "https://discord.com/api/webhooks/1440202664389640242/RR2NiQ4WqbtRy4zH9YmmQcdW4YgPCqz22HCBnW-XVd0nNvH1WklGYX_eDjoyQyF8ruoU"
local INTERVAL = 60 * 60

getgenv().GINVENTORY_COUNTS = {
    {Class = "Currency", Item = "RngCoins2",             Name = "RNG Coins"},
    {Class = "Currency", Item = "Diamonds",              Name = "Diamonds Left"},
    {Class = "Misc",     Item = "Lucky Dice V2",         Name = "Lucky Dice V2"},
    {Class = "Misc",     Item = "Lucky Dice II V2",      Name = "Lucky Dice II V2"},
    {Class = "Misc",     Item = "Mega Lucky Dice V2",    Name = "Mega Lucky Dice V2"},
    {Class = "Misc",     Item = "Mega Lucky Dice II V2", Name = "Mega Lucky Dice II V2"},
    {Class = "Pet",      Item = "Huge Nebula Lion",      Name = "Huge Nebula Lion"},
