local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local request = (syn and syn.request)
    or (http and http.request)
    or http_request
    or request

if not request then
    warn("[API] ❌ Your executor has no 'request' function.")
    return
end

local player = Players.LocalPlayer
if not player then
    Players:GetPropertyChangedSignal("LocalPlayer"):Wait()
    player = Players.LocalPlayer
end
print("[API] ✅ LocalPlayer:", player.Name)

local API = "https://aa20e0ba-9d87-49cd-90b6-bbc8be591d9d-00-3ah7eo8d8lkix.kirk.replit.dev/api"
local KEY = "mysecretkey"

-- Grab the save table once per send
local function getSave()
    local ok, save = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client").Save).Get()
    end)
    if not ok or type(save) ~= "table" then return nil end
    return save
end

-- Sum a currency by id (Diamonds, VoidTicket, etc.)
local function getCurrency(save, currencyId)
    if not save or not save.Inventory or not save.Inventory.Currency then return 0 end
    for _, item in pairs(save.Inventory.Currency) do
        if item.id == currencyId then
            return item._am or item.am or 0
        end
    end
    return 0
end

-- Count pets whose id starts with a given prefix ("Huge ", "Titanic ")
local function countPetsByPrefix(save, prefix)
    if not save or not save.Inventory or not save.Inventory.Pets then return 0 end
    local count = 0
    for _, pet in pairs(save.Inventory.Pets) do
        local id = pet.id or pet.Id or ""
        if type(id) == "string" and string.sub(id, 1, #prefix) == prefix then
            -- pets may have a quantity field (.am or _am), default to 1
            count = count + (pet.am or pet._am or 1)
        end
    end
    return count
end

local function sendData()
    local save = getSave()
    if not save then
        warn("[API] ❌ Could not read save data — Library.Client.Save not found?")
        return
    end

    local diamonds    = getCurrency(save, "Diamonds")
    local voidTickets = getCurrency(save, "VoidTicket")  -- try "VoidTicket"
    if voidTickets == 0 then voidTickets = getCurrency(save, "Void Ticket") end
    if voidTickets == 0 then voidTickets = getCurrency(save, "VoidTickets") end

    local huges    = countPetsByPrefix(save, "Huge ")
    local titanics = countPetsByPrefix(save, "Titanic ")

    local data = {
        Username           = player.Name,
        Server             = game.JobId ~= "" and game.JobId or "studio-test",
        DiamondsValue      = diamonds,
        VoidTicketsValue   = voidTickets,
        HugeList           = huges,
        TitanicList        = titanics,
        InstaplantValue    = 0,
        SeedbagValue       = 0,
        DiamondsSeedValue  = 0,
    }

    local ok, response = pcall(request, {
        Url = API .. "/update",
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json",
            ["Authorization"] = KEY
        },
        Body = HttpService:JSONEncode(data)
    })

    if not ok then
        warn("[API] ❌ Request error:", response)
        return
    end

    local code = response and response.StatusCode or "?"
    print(string.format("[API] sent | gems=%s void=%s huges=%s titanics=%s | HTTP %s",
        tostring(diamonds), tostring(voidTickets), tostring(huges), tostring(titanics), tostring(code)))
end

print("[API] Starting loop, sending every 10s...")
while true do
    sendData()
    task.wait(10)
end
