local Client = game.ReplicatedStorage.Library.Client
local SaveMod = require(Client.Save)
local Network = require(Client.Network)
local HttpService = game:GetService("HttpService")

-- Fetch RAP table from Big Games API
local rapTable = {}
local function fetchRAP()
    local ok, res = pcall(function()
        return request({ Url = "https://ps99.biggamesapi.io/api/rap", Method = "GET" })
    end)
    if ok and res and res.StatusCode == 200 then
        local decoded = HttpService:JSONDecode(res.Body)
        if decoded and decoded.data then
            rapTable = {}
            for _, entry in ipairs(decoded.data) do
                -- key: "id|pt|sh" or just "id" for base items
                local key = entry.configData and entry.configData.id or entry.id
                local pt = entry.configData and entry.configData.pt
                local sh = entry.configData and entry.configData.sh
                local fullKey = key
                if pt then fullKey = fullKey .. "|pt=" .. tostring(pt) end
                if sh then fullKey = fullKey .. "|sh=" .. tostring(sh) end
                rapTable[fullKey] = entry.value
            end
            print("✅ RAP table loaded: " .. tostring(#decoded.data) .. " entries")
        end
    else
        warn("❌ Failed to fetch RAP table")
    end
end

local function getRAP(id, pt, sh)
    local key = tostring(id)
    if pt then key = key .. "|pt=" .. tostring(pt) end
    if sh then key = key .. "|sh=" .. tostring(sh) end
    -- Try full key first, then fallback to base id only
    return rapTable[key] or rapTable[tostring(id)] or 0
end

-- Initial fetch, then refresh every 5 minutes
fetchRAP()
task.spawn(function()
    while true do
        task.wait(300)
        fetchRAP()
    end
end)

while true do
    -- Unlock loop
    while not (SaveMod.Get()["SecretRooms"] and SaveMod.Get()["SecretRooms"]["Treehouse Merchant"]) do
        Network.Invoke("SecretRoom_Unlock", "Treehouse Merchant")
        task.wait(0.5)
    end

    Network.Invoke("Instancing_PlayerEnterInstance", "TreehouseMerchant")
    task.wait(1)

    local SecretRoom = SaveMod.Get()["SecretRooms"]["Treehouse Merchant"]

    if type(SecretRoom) == "table" then
        local bestRAP = -math.huge
        local bestIndex = nil

        print("====== 🌳 Treehouse Merchant Items ======")

        for i, v in pairs(SecretRoom) do
            local data = v.data
            local rap = getRAP(data.id, data.pt, data.sh)

            print(string.format("[SLOT %d] %s | pt=%s sh=%s | RAP: %d",
                i,
                tostring(data.id),
                tostring(data.pt or "none"),
                tostring(data.sh or false),
                rap
            ))

            if rap > bestRAP then
                bestRAP = rap
                bestIndex = i
            end
        end

        print("=========================================")

        if bestIndex and bestRAP > 0 then
            print(string.format("✅ Best: SLOT %d (%s) → RAP %d", bestIndex, SecretRoom[bestIndex].data.id, bestRAP))
            Network.Invoke("TreehouseMerchant_Purchase", bestIndex)
        else
            warn("❌ No RAP data matched, skipping purchase.")
        end
    else
        warn("❌ SecretRoom data invalid.")
    end

    task.wait(4)
end
