-- Helper: Format Numbers
local function fmt(n)
    if n >= 1e6 then return string.format("%.1fM", n/1e6):gsub("%.", ",")
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3):gsub("%.", ",")
    end
    return tostring(math.floor(n))
end

