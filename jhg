local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local lp = Players.LocalPlayer
local plantRemote = ReplicatedStorage:WaitForChild("GameEvents"):WaitForChild("Plant_RE")

repeat task.wait() until game:IsLoaded()

-- // CONFIG
local ENABLED = true
local PLANT_DELAY = 0.2

local WANTED_SEEDS = {
    "Easter Candy Carrot",
    "Easter Chocolate Berry",
    "Easter Gumball",
    "Easter Liquorice",
    "Easter Sugar Melon",
    "Easter Chocolate Coconut",
    "Easter Gummy Cactus",
    "Easter Sour Lemon",
    "Easter Eggfruit",
}

local wantedSet = {}
for _, name in ipairs(WANTED_SEEDS) do
    wantedSet[name:lower()] = name -- lowercase key, original value
end

-- // Get player position
local function getPos()
    local char = lp.Character or lp.CharacterAdded:Wait()
    local root = char:FindFirstChild("HumanoidRootPart")
    return root and root.Position or Vector3.zero
end

-- // Extract base seed name from tool name
-- "Easter Candy Carrot Seed [X7]" -> "Easter Candy Carrot"
local function getBaseName(toolName)
    return toolName:match("^(.-) Seed") or toolName:match("^(.-) %[")
end

-- // Get all wanted seeds from backpack
local function getSeeds()
    local found = {}
    for _, tool in ipairs(lp.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local base = getBaseName(tool.Name)
            if base and wantedSet[base:lower()] then
                table.insert(found, { tool = tool, baseName = wantedSet[base:lower()] })
            end
        end
    end
    return found
end

-- // Equip tool
local function equipTool(tool)
    pcall(function()
        local char = lp.Character
        if not char then return end
        char.Humanoid:UnequipTools()
        task.wait(0.1)
        tool.Parent = char
        local t = 0
        while not char:FindFirstChild(tool.Name) and t < 2 do
            task.wait(0.1)
            t += 0.1
        end
    end)
end

-- // Main loop
print("Auto Plant started | P = toggle")

local CurrentlyPlanting = false

task.spawn(function()
    while true do
        task.wait(0.5)
        if not ENABLED or CurrentlyPlanting then continue end

        local seeds = getSeeds()
        if #seeds == 0 then
            task.wait(3)
            continue
        end

        CurrentlyPlanting = true
        for _, data in ipairs(seeds) do
            if not ENABLED then break end

            local tool = data.tool
            local baseName = data.baseName

            if not tool or not tool:IsDescendantOf(lp.Backpack) then continue end

            equipTool(tool)
            task.wait(0.3)

            local char = lp.Character
            while ENABLED and char and char:FindFirstChild(tool.Name) do
                plantRemote:FireServer(getPos(), baseName)
                task.wait(PLANT_DELAY)
                -- re-check seeds still exist
                if not lp.Backpack:FindFirstChild(tool.Name) and not (char and char:FindFirstChild(tool.Name)) then
                    break
                end
            end
        end
        CurrentlyPlanting = false
    end
end)

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.P then
        ENABLED = not ENABLED
        print("Auto Plant: " .. (ENABLED and "ON" or "OFF"))
    end
end)
