local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer
local char = lp.Character
local hrp = char:FindFirstChild("HumanoidRootPart")
local hum = char:FindFirstChildOfClass("Humanoid")

-- debug: print all eggs in directory first
local eggsFolder = RS.__DIRECTORY.Eggs["Backrooms Update 2"]
print("=== DIRECTORY EGGS ===")
for _, egg in pairs(eggsFolder:GetChildren()) do
    print(egg.Name)
end

-- build lookup: multiplier -> egg name
-- format: "1 | Backrooms Smile Egg 1x"
-- we want: 1 -> "Backrooms Smile Egg"
local multiToEgg = {}
for _, egg in pairs(eggsFolder:GetChildren()) do
    local multi = tonumber(egg.Name:match("(%d+)x$"))
    -- extract egg name between "| " and " Nx"
    local eggName = egg.Name:match("%| (.+) %d+x$")
    if multi and eggName then
        -- store all eggs per multiplier (there can be multiple)
        if not multiToEgg[multi] then multiToEgg[multi] = {} end
        -- avoid duplicates
        local exists = false
        for _, v in pairs(multiToEgg[multi]) do
            if v == eggName then exists = true break end
        end
        if not exists then
            table.insert(multiToEgg[multi], eggName)
        end
        print("MAPPED: " .. multi .. "x -> " .. eggName)
    else
        print("FAILED TO PARSE: " .. egg.Name)
    end
end

-- sweep
if not hrp then warn("no hrp") return end
hum.PlatformStand = true

local noclip = RunService.Stepped:Connect(function()
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end)

local center = hrp.Position
local range = 1500
local stepSize = 60
local flyY = center.Y + 5

local waypoints = {}
local row = 0
local z = center.Z - range
while z <= center.Z + range do
    local xStep = (row % 2 == 0) and stepSize or -stepSize
    local xStart = (row % 2 == 0) and center.X - range or center.X + range
    local xEnd = (row % 2 == 0) and center.X + range or center.X - range
    local x = xStart
    repeat
        table.insert(waypoints, Vector3.new(x, flyY, z))
        x = x + xStep
    until (xStep > 0 and x > xEnd) or (xStep < 0 and x < xEnd)
    z = z + stepSize
    row = row + 1
end

-- status UI
local sg = Instance.new("ScreenGui")
sg.Name = "SweepUI"
sg.Parent = game:GetService("CoreGui")
local frame = Instance.new("Frame", sg)
frame.Size = UDim2.new(0, 320, 0, 60)
frame.Position = UDim2.new(0.5, -160, 0, 10)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.BorderSizePixel = 0
Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)
local lbl = Instance.new("TextLabel", frame)
lbl.Size = UDim2.new(1,0,1,0)
lbl.BackgroundTransparency = 1
lbl.TextColor3 = Color3.fromRGB(255,200,0)
lbl.Font = Enum.Font.GothamBold
lbl.TextSize = 13
lbl.Text = "Sweeping 0%"

print("Sweeping " .. #waypoints .. " waypoints...")

for i, wp in pairs(waypoints) do
    hrp.CFrame = CFrame.new(wp)
    task.wait(0.04)
    if i % 30 == 0 then
        lbl.Text = "Sweeping " .. math.floor(i/#waypoints*100) .. "% (" .. i .. "/" .. #waypoints .. ")"
    end
end

noclip:Disconnect()
hum.PlatformStand = false
lbl.Text = "Scanning eggs..."
task.wait(1)

-- scan all rooms
local backrooms = workspace.__THINGS.__INSTANCE_CONTAINER.Active.Backrooms.GeneratedBackrooms
local found = {}

print("=== ALL EGG ROOMS ===")
for _, room in pairs(backrooms:GetChildren()) do
    local roomID = room:GetAttribute("RoomID") or ""
    local multi = room:GetAttribute("EggMultiplier")
    local deepRoom = room:GetAttribute("DeepRoom")

    if roomID:lower():find("egg") then
        local eggModel = room:FindFirstChild("EggModel", true)
        local part = eggModel and eggModel:FindFirstChildWhichIsA("BasePart")

        -- get egg names from lookup
        local names = multiToEgg[multi]
        local nameStr = names and table.concat(names, "/") or ("Unknown")

        print(string.format("ROOM: %s | Multi: %s | Deep: %s | EggModel: %s | Names: %s",
            roomID,
            tostring(multi),
            tostring(deepRoom),
            tostring(eggModel ~= nil),
            nameStr
        ))

        if part then
            table.insert(found, {
                name = nameStr,
                multi = multi or 0,
                deep = deepRoom,
                part = part,
                roomID = roomID
            })
        end
    end
end

table.sort(found, function(a,b) return (a.multi or 0) < (b.multi or 0) end)
lbl.Text = "Found " .. #found .. " egg rooms!"
task.wait(2)
sg:Destroy()

print("=== FINAL EGG LIST ===")
for _, e in pairs(found) do
    print(string.format("[%s] %s [%dx] deep=%s", e.roomID, e.name, e.multi, tostring(e.deep)))
end

