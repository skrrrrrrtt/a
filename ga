-- Crypto Trader | Street Life Remastered

local RS     = game:GetService("ReplicatedStorage")
local LP     = game:GetService("Players").LocalPlayer

local BUY_BELOW  = 5000   -- buy if price <= this
local SELL_ABOVE = 8000   -- sell if price >= this
local CHECK_INTERVAL = 10 -- check every 10s

local holding    = false
local boughtAt   = 0

local function firePhone(...)
    RS.Remotes.Phone:FireServer(...)
end

local function getPrice()
    -- buy 1 unit then instantly sell to read the real price from remote response
    -- instead we read it from PhoneUI
    local ok, price = pcall(function()
        local phoneUI = LP.PlayerGui:WaitForChild("PhoneUI", 5)
        for _, v in ipairs(phoneUI:GetDescendants()) do
            if (v:IsA("TextLabel") or v:IsA("TextBox")) and v.Name:lower():find("crypto") or v.Parent and v.Parent.Name:lower():find("crypto") then
                local num = v.Text:match("%$?(%d[%d,]+)")
                if num then return tonumber(num:gsub(",", "")) end
            end
        end
        -- fallback: search all text for a plausible crypto price (1000-20000 range)
        for _, v in ipairs(phoneUI:GetDescendants()) do
            if v:IsA("TextLabel") then
                local num = v.Text:match("%$?(%d[%d,]+)")
                if num then
                    local n = tonumber(num:gsub(",", ""))
                    if n and n >= 1000 and n <= 20000 then return n end
                end
            end
        end
    end)
    return ok and price or nil
end

local function buy()
    print(string.format("[Crypto] Buying at $%d...", boughtAt))
    firePhone("Crypto", "Purchase", 1)
    holding = true
end

local function sell(price)
    print(string.format("[Crypto] Selling at $%d | Profit: ~$%d", price, price - boughtAt))
    firePhone("Crypto", "Sell", 1)
    holding = false
    boughtAt = 0
end

-- hook namecall to spy real price from any phone fire
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local args = {...}
    if getnamecallmethod() == "FireServer" and self == RS.Remotes.Phone then
        if args[1] == "Crypto" then
            local amt = tonumber(args[3])
            if amt then
                print(string.format("[Crypto] Remote fired: %s | $%d", tostring(args[2]), amt))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- main loop
task.spawn(function()
    print("[Crypto] Trader started")
    while true do
        local price = getPrice()

        if not price then
            print("[Crypto] Can't read price — open Phone app in-game")
            task.wait(CHECK_INTERVAL)
            continue
        end

        print(string.format("[Crypto] Price: $%d | Holding: %s", price, tostring(holding)))

        if not holding then
            if price <= BUY_BELOW then
                boughtAt = price
                buy()
            else
                print(string.format("[Crypto] Price too high ($%d > $%d), waiting...", price, BUY_BELOW))
            end
        else
            if price >= SELL_ABOVE then
                sell(price)
            else
                print(string.format("[Crypto] Holding... need $%d, currently $%d", SELL_ABOVE, price))
            end
        end

        task.wait(CHECK_INTERVAL)
    end
end)
