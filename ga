-- get bounds
local minX, maxX, minZ, maxZ, sumY, countY = math.huge, -math.huge, math.huge, -math.huge, 0, 0
for _, room in pairs(genBackrooms:GetChildren()) do
    local base = room:FindFirstChild("Baseplate")
    if base and base:IsA("BasePart") then
        local p = base.Position
        minX = math.min(minX, p.X - 150)
        maxX = math.max(maxX, p.X + 150)
        minZ = math.min(minZ, p.Z - 150)
        maxZ = math.max(maxZ, p.Z + 150)
        sumY = sumY + p.Y
        countY = countY + 1
    end
end
local flyY = (countY > 0 and sumY/countY or hrp.Position.Y) + 8

-- PHASE 1: fly room to room (nearest neighbor)
local function getRoomPositions()
    local positions = {}
    for _, room in pairs(genBackrooms:GetChildren()) do
        local base = room:FindFirstChild("Baseplate")
        if base and base:IsA("BasePart") then
            table.insert(positions, base.Position)
        end
    end
    return positions
end

local function sortNearest(positions, startPos)
    local sorted = {}
    local remaining = {table.unpack(positions)}
    local current = startPos
    while #remaining > 0 do
        local nearestIdx, nearestDist = 1, math.huge
        for i, pos in pairs(remaining) do
            local d = (pos - current).Magnitude
            if d < nearestDist then nearestDist = d nearestIdx = i end
        end
        table.insert(sorted, remaining[nearestIdx])
        current = remaining[nearestIdx]
        table.remove(remaining, nearestIdx)
    end
    return sorted
end

local roomPositions = sortNearest(getRoomPositions(), hrp.Position)
print("Phase 1: visiting " .. #roomPositions .. " rooms")

for i, pos in pairs(roomPositions) do
    if stopped then break end
    hrp.CFrame = CFrame.new(Vector3.new(pos.X, flyY, pos.Z))
    task.wait(0.15) -- wait at each room to stream
    if i % 3 == 0 then
        lbl.Text = "🔍 Phase 1: " .. math.floor(i/#roomPositions*100) .. "% | rooms: " .. #genBackrooms:GetChildren()
        lbl2.Text = "🥚 Eggs: " .. #found
    end
end

-- update bounds after phase 1 (new rooms may have loaded)
for _, room in pairs(genBackrooms:GetChildren()) do
    local base = room:FindFirstChild("Baseplate")
    if base and base:IsA("BasePart") then
        local p = base.Position
        minX = math.min(minX, p.X - 150)
        maxX = math.max(maxX, p.X + 150)
        minZ = math.min(minZ, p.Z - 150)
        maxZ = math.max(maxZ, p.Z + 150)
    end
end

-- PHASE 2: grid sweep to catch any missed rooms
if not stopped then
    lbl.Text = "🔍 Phase 2: Grid sweep..."
    local stepSize = 120
    local waypoints = {}
    local row = 0
    local z = minZ
    while z <= maxZ do
        local xStep = (row % 2 == 0) and stepSize or -stepSize
        local xStart = (row % 2 == 0) and minX or maxX
        local xEnd = (row % 2 == 0) and maxX or minX
        local x = xStart
        repeat
            table.insert(waypoints, Vector3.new(x, flyY, z))
            x = x + xStep
        until (xStep > 0 and x > xEnd) or (xStep < 0 and x < xEnd)
        z = z + stepSize
        row = row + 1
    end

    print("Phase 2: " .. #waypoints .. " grid waypoints")

    for i, wp in pairs(waypoints) do
        if stopped then break end
        hrp.CFrame = CFrame.new(wp)
        task.wait(0.04)
        if i % 10 == 0 then
            lbl.Text = "🔍 Phase 2: " .. math.floor(i/#waypoints*100) .. "% | rooms: " .. #genBackrooms:GetChildren()
            lbl2.Text = "🥚 Eggs: " .. #found
        end
    end
end

-- PHASE 3: revisit any new rooms found during grid sweep
if not stopped then
    lbl.Text = "🔍 Phase 3: Final pass..."
    local newPositions = sortNearest(getRoomPositions(), hrp.Position)
    -- only visit rooms we havent been to
    local visited = {}
    for _, pos in pairs(roomPositions) do
        visited[tostring(math.floor(pos.X)) .. "_" .. tostring(math.floor(pos.Z))] = true
    end
    local toVisit = {}
    for _, pos in pairs(newPositions) do
        local key = tostring(math.floor(pos.X)) .. "_" .. tostring(math.floor(pos.Z))
        if not visited[key] then
            table.insert(toVisit, pos)
        end
    end
    print("Phase 3: " .. #toVisit .. " new rooms to visit")
    for i, pos in pairs(toVisit) do
        if stopped then break end
        hrp.CFrame = CFrame.new(Vector3.new(pos.X, flyY, pos.Z))
        task.wait(0.15)
    end
end

