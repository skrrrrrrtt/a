-- CONFIG
local INTERACT_RANGE = 15
local POLL_INTERVAL = 0.5

-- REFS
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local hrp = lp.Character and lp.Character:WaitForChild("HumanoidRootPart")
local root = workspace.__THINGS.__INSTANCE_CONTAINER.Active.Backrooms.GeneratedBackrooms
local BreakableCmds = require(game.ReplicatedStorage.Library.Client.BreakableCmds)

-- Find the miniboss room
local function getMiniBossRoom()
    for _, room in ipairs(root:GetChildren()) do
        if room:GetAttribute("BossChestUID") then
            return room
        end
    end
    return nil
end

-- Wait for boss to be defeated (BossDefeatedAt set by server)
print("[Chest] Waiting for miniboss room...")
local bossRoom = nil
repeat
    task.wait(POLL_INTERVAL)
    bossRoom = getMiniBossRoom()
until bossRoom ~= nil
print("[Chest] Found miniboss room: " .. bossRoom.Name)

print("[Chest] Waiting for boss to be defeated...")
repeat
    task.wait(POLL_INTERVAL)
until bossRoom:GetAttribute("BossDefeatedAt") ~= nil
print("[Chest] Boss defeated! Heading to chest...")

-- Get chest object
local chestUID = bossRoom:GetAttribute("BossChestUID")
local chest = BreakableCmds.Get(chestUID)

if not chest then
    warn("[Chest] Chest not found via BreakableCmds")
    return
end

-- Walk to chest
local function walkTo(pos)
    local humanoid = lp.Character:FindFirstChildOfClass("Humanoid")
    humanoid:MoveTo(pos)
    humanoid.MoveToFinished:Wait()
end

local chestPos = chest:GetPivot().Position
print("[Chest] Walking to chest...")
walkTo(chestPos)

-- Wait until in range then interact
repeat task.wait(0.1) until (hrp.Position - chestPos).Magnitude <= INTERACT_RANGE

-- Fire the interact remote
local interactRemote = game.ReplicatedStorage:FindFirstChild("BreakableInteract", true)
    or game.ReplicatedStorage:FindFirstChild("Interact", true)

if interactRemote and interactRemote:IsA("RemoteEvent") then
    interactRemote:FireServer(chestUID)
    print("[Chest] Interact fired!")
else
    -- Fallback: try clicking via proximity prompt
    local prompt = chest:FindFirstChildOfClass("ProximityPrompt", true)
    if prompt then
        fireproximityprompt(prompt)
        print("[Chest] ProximityPrompt fired!")
    else
        warn("[Chest] No interact remote or prompt found. Check ReplicatedStorage remotes manually.")
    end
end
