-- CONFIG
local STEP = 120        -- grid step between scan points
local SCAN_RADIUS = 80  -- how close to "nearby" for egg detection
local TRAVEL_Y = 1600   -- teleport height
local WAIT_TIME = 0.15  -- wait per step for chunks to load

-- REFS
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local hrp = lp.Character and lp.Character:WaitForChild("HumanoidRootPart")
local root = workspace.__THINGS.__INSTANCE_CONTAINER.Active.Backrooms.GeneratedBackrooms

-- STEP 1: Detect map bounds dynamically
print("[Scanner] Detecting map bounds...")
local min = Vector3.new(math.huge, math.huge, math.huge)
local max = Vector3.new(-math.huge, -math.huge, -math.huge)

for _, v in ipairs(workspace:GetDescendants()) do
    if v:IsA("BasePart") then
        local p = v.Position
        local s = v.Size / 2
        min = Vector3.new(math.min(min.X, p.X - s.X), math.min(min.Y, p.Y - s.Y), math.min(min.Z, p.Z - s.Z))
        max = Vector3.new(math.max(max.X, p.X + s.X), math.max(max.Y, p.Y + s.Y), math.max(max.Z, p.Z + s.Z))
    end
end

local mapSize = max - min
print(string.format("[Scanner] Map bounds: Min(%.0f, %.0f, %.0f) Max(%.0f, %.0f, %.0f)", min.X, min.Y, min.Z, max.X, max.Y, max.Z))
print(string.format("[Scanner] Map size: %.0f x %.0f x %.0f", mapSize.X, mapSize.Y, mapSize.Z))

-- STEP 2: Helper to detect egg type in a room
local function getEggType(room)
    if room:FindFirstChild("smile_08", true) then
        return "Backrooms Smile Egg"
    elseif room:FindFirstChild("flower_02", true) then
        return "Backrooms Flower Egg"
    elseif room:FindFirstChild("scribble_02", true) then
        return "Backrooms Scribble Egg"
    elseif room:FindFirstChild("spiral", true) then
        return "Backrooms Swirl Egg"
    end
    return "Unknown Egg"
end

-- STEP 3: Scan nearby rooms relative to current position
local found = {}

local function scanNearbyRooms()
    local pos = hrp.Position
    for _, room in ipairs(root:GetChildren()) do
        if room:GetAttribute("EggMultiplier") then
            -- Find a representative part to check distance
            local part = room:FindFirstChildWhichIsA("BasePart", true)
            if part then
                local dist = (part.Position - pos).Magnitude
                if dist <= SCAN_RADIUS then
                    local mult = room:GetAttribute("EggMultiplier")
                    local eggType = getEggType(room)
                    local key = eggType .. " " .. tostring(mult) .. "x"
                    if not found[key] then
                        found[key] = true
                        print(string.format("[Scanner] Found: %s (dist: %.0f)", key, dist))
                    end
                end
            end
        end
    end
end

-- STEP 4: Travel grid across detected map bounds & scan
print("[Scanner] Starting grid travel...")
local steps = 0

for x = min.X, max.X, STEP do
    for z = min.Z, max.Z, STEP do
        hrp.CFrame = CFrame.new(x, TRAVEL_Y, z)
        task.wait(WAIT_TIME)
        scanNearbyRooms()
        steps += 1
    end
end

print(string.format("[Scanner] Travel complete. Visited %d grid points.", steps))

-- STEP 5: Output results
local out = {}
for k in pairs(found) do
    table.insert(out, k)
end
table.sort(out)

local result = table.concat(out, "\n")
if result == "" then
    result = "No eggs found."
end

setclipboard(result)
print("[Scanner] Results copied to clipboard:\n" .. result)
