-- ══════════════════════════════════════════════════════════════
--  Slime RNG Web Reporter
--  Paste this BELOW your existing bot script (after all functions
--  are defined). It sends your stats to the web monitor every 30s.
--
--  SETUP:
--    1. Set MONITOR_URL to your site's URL (see Setup Guide page)
--    2. Enable HTTP Requests in Roblox Studio game settings
--    3. Run the script in your executor
-- ══════════════════════════════════════════════════════════════

local MONITOR_URL    = "https://53e3820d-f079-40c3-9121-e74105ff7255-00-rvt1fnaihvtv.pike.replit.dev/api/stats"  -- ← change this
local REPORT_INTERVAL = 30  -- seconds between each POST

-- ── internal helpers ────────────────────────────────────────
local _httpService = game:GetService("HttpService")
local _players     = game:GetService("Players")
local _player      = _players.LocalPlayer

local _sessionRolls     = 0
local _sessionUpgrades  = 0
local _sessionZones     = 0
local _sessionStart     = tick()
local _currentAction    = "starting up"

-- Hook into Stats global if the main script exposes it
local function _getRolls()
    if getgenv().Stats and type(getgenv().Stats.rolls) == "number" then
        return getgenv().Stats.rolls
    end
    return _sessionRolls
end
local function _getUpgrades()
    if getgenv().Stats and type(getgenv().Stats.upgrades) == "number" then
        return getgenv().Stats.upgrades
    end
    return _sessionUpgrades
end
local function _getZones()
    if getgenv().Stats and type(getgenv().Stats.zones) == "number" then
        return getgenv().Stats.zones
    end
    return _sessionZones
end
local function _getAction()
    if getgenv().Stats and type(getgenv().Stats.action) == "string" then
        return getgenv().Stats.action
    end
    return _currentAction
end

-- ── safe wrappers (in case the main script isn't loaded) ────
local function safeGetCoins()
    local ok, v = pcall(getCurrentCoins)
    return (ok and v) or 0
end
local function safeGetGoop()
    local ok, v = pcall(getCurrentGoop)
    return (ok and v) or 0
end
local function safeGetRebirths()
    local ok, v = pcall(getRebirthCount)
    return (ok and v) or 0
end
local function safeGetMaxZone()
    local ok, v = pcall(getCurrentMaxZone)
    return (ok and v) or 1
end
local function safeGetRebirthCost()
    local ok, v = pcall(getRebirthCost)
    return (ok and v) or 999999999
end
local function safeCanRebirth()
    local ok, v = pcall(canAffordRebirth)
    return (ok and v) or false
end
local function safeBoostActive(bt)
    local ok, v = pcall(isBoostActive, bt)
    return (ok and v) or false
end
local function safeConfig(key, default)
    if getgenv().Config and getgenv().Config[key] ~= nil then
        return getgenv().Config[key]
    end
    return default
end

-- ── report function ──────────────────────────────────────────
local function sendStats()
    local payload = {
        playerName    = _player.Name,
        coins         = safeGetCoins(),
        goop          = safeGetGoop(),
        rebirths      = safeGetRebirths(),
        maxZone       = safeGetMaxZone(),
        rollsSession  = _getRolls(),
        upgradesBought = _getUpgrades(),
        zonesUnlocked = _getZones(),
        currentAction = _getAction(),
        uptimeSeconds = tick() - _sessionStart,
        rebirthCost   = safeGetRebirthCost(),
        canRebirth    = safeCanRebirth(),
        boosts = {
            luck      = safeBoostActive("luck"),
            ultraLuck = safeBoostActive("ultraLuck"),
            currency  = safeBoostActive("currency"),
            rollSpeed = safeBoostActive("rollSpeed"),
        },
        config = {
            claimRewards      = safeConfig("Claim Rewards", false),
            autoRebirth       = safeConfig("Auto Rebirth", false),
            autoRoll          = safeConfig("Auto Roll", false),
            rollIntervalS     = safeConfig("Roll Interval(S)", 0.4),
            teleportToEnemies = safeConfig("Teleport To Enemies", false),
            autoBuyZones      = safeConfig("Auto Buy Zones", false),
            autoBuyUpgrades   = safeConfig("Auto Buy Upgrades", false),
            autoEquipBest     = safeConfig("Auto Equip Best", false),
            deleteUnnecessary = safeConfig("Delete Unnecessary", false),
            autoUseBoosts     = safeConfig("Auto Use Boosts", false),
        },
    }

    local ok, err = pcall(function()
        local json = _httpService:JSONEncode(payload)
        _httpService:PostAsync(
            MONITOR_URL,
            json,
            Enum.HttpContentType.ApplicationJson,
            false
        )
    end)
    if not ok then
        warn("[SlimeMonitor] Failed to send stats: " .. tostring(err))
    else
        print("[SlimeMonitor] Stats sent for " .. _player.Name)
    end
end

-- ── start reporting loop ─────────────────────────────────────
task.spawn(function()
    print("[SlimeMonitor] Reporter started. Sending to: " .. MONITOR_URL)
    while true do
        sendStats()
        task.wait(REPORT_INTERVAL)
    end
end)

print("[SlimeMonitor] Loaded. Will report every " .. REPORT_INTERVAL .. "s.")
