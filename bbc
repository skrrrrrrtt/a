-- =========================
-- LIVE INVENTORY TRACKER
-- =========================
task.spawn(function()
    while true do
        local save = SaveMod.Get()

        if save and save.Inventory then
            local inv = save.Inventory

            local counts = {
                ["Diamonds"] = save.Diamonds or 0,
                ["Spring Egg Token"] = 0,
                ["Spring Bluebell Token"] = 0,
                ["Spring Red Tulip Token"] = 0,
                ["Spring Pink Rose Token"] = 0,
                ["Spring Yellow Sunflower Token"] = 0,
                ["Huge Dawn Phoenix"] = 0,
                ["Huge Diamond Chick"] = 0,
                ["Titanic Diamond Chick"] = 0,
            }

            for class, items in pairs(inv) do
                for _, v in pairs(items) do
                    local id = v.id

                    -- TOKENS
                    if id == "Spring Egg" then counts["Spring Egg Token"] += 1 end
                    if id == "Spring Bluebell" then counts["Spring Bluebell Token"] += 1 end
                    if id == "Spring Red Tulip" then counts["Spring Red Tulip Token"] += 1 end
                    if id == "Spring Pink Rose" then counts["Spring Pink Rose Token"] += 1 end
                    if id == "Spring Sunflower" then counts["Spring Yellow Sunflower Token"] += 1 end

                    -- PETS
                    if id == "Huge Dawn Phoenix" then counts["Huge Dawn Phoenix"] += 1 end
                    if id == "Huge Diamond Chick" then counts["Huge Diamond Chick"] += 1 end
                    if id == "Titanic Diamond Chick" then counts["Titanic Diamond Chick"] += 1 end
                end
            end

            -- UPDATE UI
            for name, val in pairs(counts) do
                if Rows[name] then
                    Rows[name].label.Text = name .. ": " .. tostring(val)
                end
            end
        end

        task.wait(2)
    end
end)
