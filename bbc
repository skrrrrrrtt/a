repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

repeat task.wait() until not LocalPlayer.PlayerGui:FindFirstChild("__INTRO")

-- =========================
-- LIBRARY
-- =========================
local Library = game.ReplicatedStorage:WaitForChild("Library")
local Client = Library.Client
local SaveMod = require(Client.Save)

local function GetAsset(Id, pt)
    local data = require(Library.Directory.Pets)[Id]
    return string.gsub(data and (pt == 1 and data.goldenThumbnail or data.thumbnail) or "14976456685", "rbxassetid://", "")
end

local function GetImage(Id, pt)
    return "https://biggamesapi.io/image/" .. GetAsset(Id, pt)
end

