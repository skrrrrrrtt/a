local MONITOR_URL    = "https://53e3820d-f079-40c3-9121-e74105ff7255-00-rvt1fnaihvtv.pike.replit.dev/api/stats"  -- ← change this
local REPORT_INTERVAL = 30  -- seconds

local _http   = game:GetService("HttpService")
local _player = game:GetService("Players").LocalPlayer
local _t0     = tick()

local function safeCall(fn, ...) local ok, v = pcall(fn, ...); return ok and v or nil end

task.spawn(function()
    while true do
        local coins  = safeCall(getCurrentCoins)  or 0
        local goop   = safeCall(getCurrentGoop)   or 0
        local rb     = safeCall(getRebirthCount)  or 0
        local zone   = safeCall(getCurrentMaxZone) or 1
        local rbcost = safeCall(getRebirthCost)   or 999999999

        local payload = _http:JSONEncode({
            playerName     = _player.Name,
            coins          = coins,
            goop           = goop,
            rebirths       = rb,
            maxZone        = zone,
            rollsSession   = (getgenv().Stats and getgenv().Stats.rolls)    or 0,
            upgradesBought = (getgenv().Stats and getgenv().Stats.upgrades) or 0,
            zonesUnlocked  = (getgenv().Stats and getgenv().Stats.zones)    or 0,
            currentAction  = (getgenv().Stats and getgenv().Stats.action)   or "running",
            uptimeSeconds  = tick() - _t0,
            rebirthCost    = rbcost,
            canRebirth     = goop >= rbcost,
            boosts = {
                luck      = safeCall(isBoostActive, "luck")      or false,
                ultraLuck = safeCall(isBoostActive, "ultraLuck") or false,
                currency  = safeCall(isBoostActive, "currency")  or false,
                rollSpeed = safeCall(isBoostActive, "rollSpeed") or false,
            },
            config = {
                claimRewards      = getgenv().Config["Claim Rewards"]      or false,
                autoRebirth       = getgenv().Config["Auto Rebirth"]       or false,
                autoRoll          = getgenv().Config["Auto Roll"]          or false,
                rollIntervalS     = getgenv().Config["Roll Interval(S)"]   or 0.4,
                teleportToEnemies = getgenv().Config["Teleport To Enemies"] or false,
                autoBuyZones      = getgenv().Config["Auto Buy Zones"]     or false,
                autoBuyUpgrades   = getgenv().Config["Auto Buy Upgrades"]  or false,
                autoEquipBest     = getgenv().Config["Auto Equip Best"]    or false,
                deleteUnnecessary = getgenv().Config["Delete Unnecessary"] or false,
                autoUseBoosts     = getgenv().Config["Auto Use Boosts"]    or false,
            },
        })

        pcall(function()
            _http:PostAsync(MONITOR_URL, payload, Enum.HttpContentType.ApplicationJson, false)
        end)
        task.wait(REPORT_INTERVAL)
    end
end)
