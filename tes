local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Find working request function
local request = (syn and syn.request)
    or (http and http.request)
    or http_request
    or request

if not request then
    warn("[API] ❌ No request function")
    return
end

local player = Players.LocalPlayer or Players:GetPropertyChangedSignal("LocalPlayer"):Wait()

local API = "https://aa20e0ba-9d87-49cd-90b6-bbc8be591d9d-00-3ah7eo8d8lkix.kirk.replit.dev/api"
local KEY = "mysecretkey"

-- get diamonds safely
local function getDiamonds()
    local ok, result = pcall(function()
        local save = require(
            ReplicatedStorage:WaitForChild("Library")
            :WaitForChild("Client").Save
        ).Get()

        for _, item in pairs(save.Inventory.Currency) do
            if item.id == "Diamonds" then
                return item._am or 0
            end
        end

        return 0
    end)

    if not ok then
        warn("[API] getDiamonds error:", result)
        return 0
    end

    return result
end

-- send to API
local function sendData()
    local diamonds = getDiamonds()

    local data = {
        Username = player.Name,
        DiamondsValue = diamonds,
        Server = game.JobId ~= "" and game.JobId or "studio-test",
        VoidTicketsValue = 0,
        HugeList = 0,
        TitanicList = 0, -- ✅ added
        InstaplantValue = 0,
        SeedbagValue = 0,
        DiamondsSeedValue = 0
    }

    local ok, response = pcall(request, {
        Url = API .. "/update",
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json",
            ["Authorization"] = KEY
        },
        Body = HttpService:JSONEncode(data)
    })

    if not ok then
        warn("[API] Request failed:", response)
        return
    end

    if response and response.StatusCode then
        print(string.format(
            "[API] Sent → diamonds=%s | HTTP %s",
            tostring(diamonds),
            tostring(response.StatusCode)
        ))
    else
        print("[API] Sent → diamonds=" .. tostring(diamonds))
    end
end

-- loop
while true do
    sendData()
    task.wait(10)
end
