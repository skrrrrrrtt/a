-- ============================================
-- MAIN LOOPS
-- ============================================
local startTime = os.time()
local cachedRap = 0

-- RAP updater (every 5 min to avoid rate limiting)
task.spawn(function()
    while true do
        cachedRap = GetRAP()
        wait(300)
    end
end)

-- Timer + GUI update loop
task.spawn(function()
    while task.wait(1) do
        local elapsed = os.time() - startTime
        local h = math.floor(elapsed / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = elapsed % 60
        Online.Text = string.format("%02d:%02d:%02d", h, m, s)
        BucketLabel.Text = "Bucket: " .. tostring(BucketAmount)
        MagicBucketLabel.Text = "Magic Bucket: " .. tostring(MagicBucketAmount)

        local totalRap = cachedRap * MagicBucketAmount
        if totalRap >= 1e6 then
            RapLabel.Text = string.format("RAP: %s ea | Total: %.2fM", tostring(cachedRap), totalRap / 1e6)
        elseif totalRap >= 1e3 then
            RapLabel.Text = string.format("RAP: %s ea | Total: %.2fK", tostring(cachedRap), totalRap / 1e3)
        else
            RapLabel.Text = string.format("RAP: %s ea | Total: %s", tostring(cachedRap), tostring(totalRap))
        end
    end
end)

-- Webhook loop (send immediately first, then every 1 hour)
task.spawn(function()
    wait(10) -- small delay to let inventory load
    while true do
        local elapsed = os.time() - startTime
        pcall(SendWebhook, elapsed)
        wait(WEBHOOK_INTERVAL)
    end
end)
