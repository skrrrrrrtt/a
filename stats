    Labels[item.ID] = Label
end

-- // Logic & Loops
ToggleBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

RunService.Heartbeat:Connect(function()
    -- Timer Logic
    local diff = os.time() - StartTime
    TimerLabel.Text = string.format("%02d:%02d:%02d", math.floor(diff/3600), math.floor(diff%3600/60), math.floor(diff%60))
    
    -- Inventory Logic
    local Save = PlayerSave.Get()
    if Save and Save.Inventory then
        for _, info in pairs(TrackedItems) do
            local val = 0
            if info.ID == "Diamonds" then
                val = Save.Diamonds or 0
            else
                for cat, items in pairs(Save.Inventory) do
                    for _, data in pairs(items) do
                        if data.id == info.ID then val = val + (data._am or 1) end
                    end
                end
            end
            if Labels[info.ID] then Labels[info.ID].Text = info.Name .. ": " .. fmt(val) end
        end
    end
end)
