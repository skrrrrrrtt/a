-- ============================================
-- INVENTORY TRACKING
-- ============================================
local BucketAmount = 0
local MagicBucketAmount = 0

local function GetItemInfo(ItemsClass, ItemsName)
    local Table = {}
    local success, Inventory = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Library"):WaitForChild("Client").Save).Get().Inventory
    end)
    if not success or not Inventory or not Inventory[ItemsClass] then return Table end
    for UID, Item in pairs(Inventory[ItemsClass]) do
        if table.find(ItemsName, Item.id) then
            table.insert(Table, { uid = UID, data = Item })
        end
    end
    return Table
end

local function UpdateInventory()
    while true do
        pcall(function()
            local buckets = GetItemInfo("Misc", {"Bucket"})
            BucketAmount = 0
            for _, info in pairs(buckets) do
                if info.data._am then
                    BucketAmount = BucketAmount + info.data._am
                end
            end

            local magicBuckets = GetItemInfo("Misc", {"Bucket O' Magic"})
            MagicBucketAmount = 0
            for _, info in pairs(magicBuckets) do
                if info.data._am then
                    MagicBucketAmount = MagicBucketAmount + info.data._am
                end
            end
        end)
        wait(2)
    end
end

task.spawn(UpdateInventory)

-- ============================================
-- RAP LOOKUP
-- ============================================
local function GetRAP()
    local bucketRap = 0
    local magicBucketRap = 0

    pcall(function()
        local response = game:HttpGet("https://ps99.biggamesapi.io/api/rap")
        local data = HttpService:JSONDecode(response)
        if data and data.status == "ok" and data.data then
            for _, item in ipairs(data.data) do
                if item.category == "Misc" then
                    if item.configData and item.configData.id == "Bucket O' Magic" then
                        magicBucketRap = item.value or 0
                    end
                end
            end
        end
    end)

    return magicBucketRap
end

-- ============================================
-- DISCORD WEBHOOK
-- ============================================
local function SendWebhook(elapsed)
    local h = math.floor(elapsed / 3600)
    local m = math.floor((elapsed % 3600) / 60)
    local s = elapsed % 60
    local uptimeStr = string.format("%02d:%02d:%02d", h, m, s)

    local magicBucketRap = GetRAP()
    local totalMagicRap = magicBucketRap * MagicBucketAmount

    local function formatNumber(n)
        if n >= 1e9 then
            return string.format("%.2fB", n / 1e9)
        elseif n >= 1e6 then
            return string.format("%.2fM", n / 1e6)
        elseif n >= 1e3 then
            return string.format("%.2fK", n / 1e3)
        end
        return tostring(n)
    end

    local data = {
        ["embeds"] = {{
            ["title"] = "📊 Inventory Report",
            ["color"] = 16776960,
            ["fields"] = {
                {
                    ["name"] = "🪣 Bucket",
                    ["value"] = tostring(BucketAmount),
                    ["inline"] = true
                },
                {
                    ["name"] = "✨ Bucket O' Magic",
                    ["value"] = tostring(MagicBucketAmount),
                    ["inline"] = true
                },
                {
                    ["name"] = "💎 Magic Bucket RAP",
                    ["value"] = formatNumber(magicBucketRap) .. " each\n" .. formatNumber(totalMagicRap) .. " total",
                    ["inline"] = true
                },
                {
                    ["name"] = "⏱️ Uptime",
                    ["value"] = uptimeStr,
                    ["inline"] = false
                },
                {
                    ["name"] = "👤 Player",
                    ["value"] = LocalPlayer.Name .. " (" .. LocalPlayer.DisplayName .. ")",
                    ["inline"] = false
                }
            },
            ["footer"] = {
                ["text"] = "RAP data from ps99.biggamesapi.io"
            },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }

    pcall(function()
        local jsonBody = HttpService:JSONEncode(data)
        local headers = {["Content-Type"] = "application/json"}

        if syn and syn.request then
            syn.request({ Url = WEBHOOK_URL, Method = "POST", Headers = headers, Body = jsonBody })
        elseif http and http.request then
            http.request({ Url = WEBHOOK_URL, Method = "POST", Headers = headers, Body = jsonBody })
        elseif request then
            request({ Url = WEBHOOK_URL, Method = "POST", Headers = headers, Body = jsonBody })
        elseif http_request then
            http_request({ Url = WEBHOOK_URL, Method = "POST", Headers = headers, Body = jsonBody })
        end
    end)
end

