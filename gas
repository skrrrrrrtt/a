-- ============================================================
-- STEP 5: Boss chest auto-handler (runs after scan)
-- ============================================================
if bossCount == 0 then
    print("[Chest] No MiniBossRooms found.")
    return
end

task.spawn(function()
    for _, data in pairs(foundBossRooms) do
        local bossRoom = data.room
        local chestUID = data.uid

        local respawnTS = bossRoom:GetAttribute("RespawnTimestamp")
        local serverTime = workspace:GetServerTimeNow()
        if respawnTS and respawnTS > serverTime then
            local waitTime = respawnTS - serverTime
            setStatus(string.format("⏳  Respawn timer: %.0fs...", waitTime), Color3.fromRGB(220, 160, 60))
            task.wait(waitTime + 1)
        end

        setStatus("⟶  Moving to BREAK_ZONE...", Color3.fromRGB(160, 120, 220))
        humanoid:MoveTo(data.breakPos)
        humanoid.MoveToFinished:Wait()

        if not chestUID then
            setStatus("⟳  Waiting for BossChestUID...", Color3.fromRGB(160, 120, 220))
            repeat
                task.wait(POLL_INTERVAL)
                chestUID = bossRoom:GetAttribute("BossChestUID")
            until chestUID ~= nil
        end

        setStatus("⚔  Waiting for boss defeat...", Color3.fromRGB(220, 100, 60))
        repeat task.wait(POLL_INTERVAL) until bossRoom:GetAttribute("BossDefeatedAt") ~= nil
        setStatus("✓  Boss defeated! Getting chest...", Color3.fromRGB(80, 220, 120))

        local chest = nil
        local t0 = tick()
        repeat
            task.wait(0.1)
            chest = BreakableCmds.Get(chestUID)
        until chest ~= nil or tick() - t0 > 5

        if not chest then
            setStatus("✗  Chest not found, skipping.", Color3.fromRGB(220, 80, 80))
            continue
        end

        setStatus("⟳  Waiting for chest to reach zone...", Color3.fromRGB(160, 120, 220))
        repeat
            task.wait(0.2)
            local chestPos = chest:GetPivot().Position
            local targetPos = bossRoom:GetAttribute("BossChestTarget")
            if not targetPos then break end
        until (chest:GetPivot().Position - bossRoom:GetAttribute("BossChestTarget")).Magnitude < 14

        local chestPos = chest:GetPivot().Position
        humanoid:MoveTo(chestPos)
        humanoid.MoveToFinished:Wait()

        repeat
            task.wait(0.1)
            chestPos = chest:GetPivot().Position
        until (hrp.Position - chestPos).Magnitude <= INTERACT_RANGE

        local interactRemote = game.ReplicatedStorage:FindFirstChild("BreakableInteract", true)
            or game.ReplicatedStorage:FindFirstChild("Interact", true)
            or game.ReplicatedStorage:FindFirstChild("BreakCmds", true)

        if interactRemote and interactRemote:IsA("RemoteEvent") then
            interactRemote:FireServer(chestUID)
            setStatus("✓  Chest opened!", Color3.fromRGB(80, 220, 120))
        else
            local prompt = chest:FindFirstChildOfClass("ProximityPrompt", true)
            if prompt then
                fireproximityprompt(prompt)
                setStatus("✓  Chest prompt fired!", Color3.fromRGB(80, 220, 120))
            else
                setStatus("✗  No interact method found — spy the remote.", Color3.fromRGB(220, 80, 80))
            end
        end

        task.wait(2)
    end

    setStatus("✓  All boss rooms handled!", Color3.fromRGB(80, 220, 120))
end)
