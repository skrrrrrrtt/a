local function findRoomDataByUID(roomUID)
    for _, roomData in ipairs(_G.ScannedRooms) do
        if roomData.uid == roomUID then return roomData end
    end
    return nil
end

local function findRoomModelByUID(roomUID)
    for _, roomModel in ipairs(GeneratedBackrooms:GetChildren()) do
        if roomModel:GetAttribute("RoomUID") == roomUID then return roomModel end
    end
    return nil
end

local function UnlockRoom(roomUID)
    local character = getCharacter()
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local roomModel = findRoomModelByUID(roomUID)
    if not roomModel then return end
    
    local LockedDoors = roomModel:FindFirstChild("LockedDoors")
    if not LockedDoors then return end
    
    local isLocked = false
    for _, child in ipairs(LockedDoors:GetChildren()) do
        local Lock = child:FindFirstChild("Lock")
        if Lock and Lock.Transparency < 0.5 then
            rootPart:PivotTo(Lock:GetPivot())
            task.wait(0.3)
            isLocked = true
            break
        end
    end
    
    if not isLocked then 
        _G.BossDoorUnlocked = true
        return 
    end
    
    local keyItem = MiscItem("Deep Daydream Key") or MiscItem("Backrooms Crayon Key") or MiscItem("Deep Backrooms Crayon Key")
    if keyItem and keyItem:HasAny() then
        local activeInstance = InstancingCmds.Get()
        if activeInstance then
            activeInstance:FireCustom("AbstractRoom_FireServer", roomUID, "UnlockDoors")
            _G.BossDoorUnlocked = true
        end
    end
end

local function TeleportToRoom(roomModel, ignore)
    if _G.Teleporting then return end
    _G.Teleporting = true
    
    local character = getCharacter()
    if not character then _G.Teleporting = false; return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then _G.Teleporting = false; return end
    
    local roomUID = roomModel:GetAttribute("RoomUID")
    local roomId = roomModel:GetAttribute("RoomID")
    local roomData = findRoomDataByUID(roomUID)
    if not roomData then
        warn("NO ROOM DATA")
        _G.Teleporting = false
        return
    end
    
    local pos = roomModel:GetPivot().Position
    Network.Fire("RequestStreaming", pos)
    
    local forceField = Instance.new("ForceField")
    forceField.Visible = false
    forceField.Parent = character
    
    task.delay(1, function()
        if rootPart then rootPart.Anchored = false end
        if forceField and forceField.Parent then forceField:Destroy() end
    end)
    
    rootPart.Anchored = true
    task.wait(0.3)
    
    if (not ignore) and (roomId == "DeepLockedEggRoom" or roomId == "GameMastersOffice" or roomId == "GameMastersStage") then
        setStatus("Unlocking Door...")
        UnlockRoom(roomUID)
    end
    
    local offset = Vector3.new(0, 5, 0)
    local targetObj = nil
    local isBossRoom = (roomId == "GameMastersStage" or roomId == "GameMastersOffice")
    
    if isBossRoom then
        targetObj = roomModel:FindFirstChild("BREAK_ZONE")
        if targetObj then
            offset = Vector3.new(0, 3, 0)
        else
            targetObj = roomModel:FindFirstChild("Sign") or roomModel:FindFirstChildWhichIsA("BasePart", true)
        end
    else
        targetObj = roomModel:FindFirstChild("Sign") 
            or roomModel:FindFirstChild("Backrooms Egg") 
            or roomModel:FindFirstChild("EggPedestal") 
            or roomModel:FindFirstChild("BREAK_ZONE")
            or roomModel:FindFirstChildWhichIsA("BasePart", true)
    end
    
    if targetObj ~= nil then
        if targetObj:IsA("BasePart") then
            if targetObj.CanCollide and not isBossRoom then
                character:MoveTo(targetObj.Position)
            else
                rootPart.CFrame = CFrame.new(targetObj.Position + offset)
            end
        elseif targetObj:IsA("Model") then
            if targetObj.PrimaryPart then
                if targetObj.PrimaryPart.CanCollide and not isBossRoom then
                    character:MoveTo(targetObj.PrimaryPart.Position)
                else
                    rootPart.CFrame = CFrame.new(targetObj.PrimaryPart.Position + offset)
                end
            end
        elseif targetObj.WorldPivot then
            rootPart.CFrame = targetObj.WorldPivot
        end
    end
    
    _G.Teleporting = false
end

local function Scan()
    if _G.IsScanning then return end
    _G.IsScanning = true
    setStatus("Scanning for Rooms...")
    
    local function TPtoSpawn()
        local character = getCharacter()
        local activeInstance = InstancingCmds.Get()
        if character and activeInstance then
            if typeof(enterPosition) ~= "Vector3" then
                local spawnRoom = GeneratedBackrooms:WaitForChild("DeepSpawnRoom", 5)
                if spawnRoom then
                    local spawnLocation = spawnRoom:FindFirstChild("DEEP_SPAWN_LOCATION")
                    if spawnLocation then
                        enterPosition = spawnLocation.Position
                    end
                end
            end
            if enterPosition then
                local pos = enterPosition + Vector3.new(0, 3, 0)
                Network.Fire("RequestStreaming", pos)
                task.delay(0.25, function()
                    if character.Parent then
                        local isInInstance = true
                        pcall(function()
                            isInInstance = InstancingCmds.IsInInstance("Backrooms")
                        end)
                        if isInInstance then
                            character:PivotTo(CFrame.new(pos))
                        end
                    end
                end)
            end
        end
    end
    
    TPtoSpawn()
    
    local foundBoss = false
    local foundCoin = false
    
    for _, r in ipairs(_G.ScannedRooms) do
        if r.Id == "GameMastersStage" or r.Id == "GameMastersOffice" then foundBoss = true end
        if string.match(r.Id, "DeepCoinRoom") then foundCoin = true end
    end
    
    local function run()
        for _, room in ipairs(GeneratedBackrooms:GetChildren()) do
            if room.Name == "Walls" then room:Destroy() end
            
            if room:GetAttribute("DeepRoom") ~= false then
                local roomUID = room:GetAttribute("RoomUID")
                if roomUID then
                    local existing = nil
                    for _, r in ipairs(_G.ScannedRooms) do
                        if r.uid == roomUID then existing = r; break end
                    }
                    local roomId = room:GetAttribute("RoomID")
                    local roomCFrame = room:GetPivot()
                    if not existing then
                        local roomData = {
                            uid = roomUID,
                            Id = roomId,
                            Model = room,
                            CFrame = roomCFrame,
                            Position = roomCFrame.Position
                        }
                        table.insert(_G.ScannedRooms, roomData)
                        setStatus("Scanned " .. #_G.ScannedRooms .. " rooms...")
                        
                        if roomId == "GameMastersStage" or roomId == "GameMastersOffice" then
                            warn("FOUND SPECIAL ROOM: " .. roomId)
                            foundBoss = true
                        end
                        if string.match(roomId, "DeepCoinRoom") then
                            foundCoin = true
                        end
                    end
                end
            end
        end
    end
    
    -- Only need keys if FARM_KEYS is ON and we don't have a key and door is locked
    local needKeys = FARM_KEYS and (not _G.BossDoorUnlocked) and (not hasKey())
    
    while true do
        if #_G.ScannedRooms >= 400 then break end
        if _G.Teleporting == true then task.wait(0.1); continue end
        
        local character = getCharacter()
        if not character then task.wait(0.1); continue end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then task.wait(0.1); continue end
        
        run()
        
        -- Stop scanning if we found boss, AND (if we need keys, we also found the coin room)
        if foundBoss and ((not needKeys) or (needKeys and foundCoin)) then
            setStatus("Found required rooms! Stopping Scan...")
            _G.IsScanning = false
            return true
        end
        
        local room = nil
        for _, r in ipairs(_G.ScannedRooms) do
            if not _G.VistedRooms[r.uid] then
                room = r
                break
            end
        end
        
        if not room then break end
        
        _G.VistedRooms[room.uid] = true
        setStatus("Exploring new room...")
        TeleportToRoom(room.Model, true)
        task.wait(0.1)
    end
    
    _G.IsScanning = false
    return foundBoss
end

local function canDoAction()
    return (not _G.IsScanning) and (not _G.Teleporting)
end

-- Auto Farm Keys Loop
task.spawn(function()
    while true do
        task.wait(0.5)
        if not _G.FarmingKeys then continue end
        if not canDoAction() then continue end
        
        local character = getCharacter()
        if not character then continue end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then continue end
        
        -- Stop farming if door is already unlocked, we have a key, or config is disabled
        if _G.BossDoorUnlocked or hasKey() or not FARM_KEYS then
            setStatus("Got key/disabled farming! Going to Boss Room...")
            _G.FarmingKeys = false
            _G.AutoMiniBoss = true
            continue
        end
        
        local targetRoom = nil
        for _, r in ipairs(_G.ScannedRooms) do
            if string.match(r.Id, "DeepCoinRoom") then
                targetRoom = r
                break
            end
        end
        
        if targetRoom then
            local roomModel = targetRoom.Model
            local pos = targetRoom.Position
            local breakZone = roomModel:FindFirstChild("BREAK_ZONE")
            if breakZone then pos = breakZone:GetPivot().Position end
            
            local isInRoom = (rootPart.Position - pos).Magnitude <= 130
            if not isInRoom then
                setStatus("Teleporting to Breakable Room to farm keys...")
                TeleportToRoom(roomModel, true)
                task.wait(2) -- Wait for pets to load
            else
                local activePets = PlayerPet.GetByPlayer(localPlayer)
                if #activePets == 0 then
                    setStatus("Waiting for pets to spawn...")
                    continue
                end
                
                local targetBreakable = nil
                local breakables = workspace.__THINGS.Breakables:GetChildren()
                for _, b in ipairs(breakables) do
                    local bPos = b:GetPivot().Position
                    if (bPos - pos).Magnitude < 130 then
                        local bHealth = b:GetAttribute("Health") or 0
                        if bHealth > 0 then
                            targetBreakable = b
                            break
                        end
                    end
                end
                
                if targetBreakable then
                    setStatus("Farming Keys... (0/1)")
                    
                    local bUID = targetBreakable:GetAttribute("BreakableUID")
                    local bPos = targetBreakable:GetPivot().Position
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid then humanoid:MoveTo(bPos) end
                    Network.UnreliableFire("Breakables_PlayerDealDamage", bUID)
                    for _, pet in pairs(activePets) do
                        if pet.cpet then pet:SetTarget(targetBreakable) end
                    end
                else
                    setStatus("Waiting for breakables to respawn in Coin Room...")
                end
            end
        else
            setStatus("No Coin Room found. Server hopping...")
            serverHop("No Coin Room. Hopping...")
            task.wait(5)
        end
    end
end)

