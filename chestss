        for _, r in ipairs(_G.ScannedRooms) do
            if r.Id == "GameMastersStage" or r.Id == "GameMastersOffice" then
                targetRoom = r
                break
            end
        end
        
        if targetRoom then
            local roomModel = targetRoom.Model
            local pos = targetRoom.Position
            local breakZone = roomModel:FindFirstChild("BREAK_ZONE")
            if breakZone then pos = breakZone:GetPivot().Position end
            
            local isInRoom = (rootPart.Position - pos).Magnitude <= 130
            if not isInRoom then
                setStatus("Teleporting to Boss Room...")
                TeleportToRoom(roomModel, false)
                task.wait(2) -- Wait for pets to load
            else
                local activePets = PlayerPet.GetByPlayer(localPlayer)
                if #activePets == 0 then
                    setStatus("Waiting for pets to spawn...")
                    continue
                end
                
                local targetBreakable = nil
                local breakables = workspace.__THINGS.Breakables:GetChildren()
                
                -- Original logic: Prioritize Chest2 first
                for _, b in ipairs(breakables) do
                    local bId = b:GetAttribute("BreakableID")
                    if bId == "Daydream Mimic Chest2" then
                        local bPos = b:GetPivot().Position
                        if (bPos - pos).Magnitude < 130 then
                            targetBreakable = b
                            break
                        end
                    end
                end
                
                -- Then check for Boss2
                if not targetBreakable then
                    for _, b in ipairs(breakables) do
                        local bId = b:GetAttribute("BreakableID")
                        if bId == "Daydream Mimic Boss2" then
                            local bPos = b:GetPivot().Position
                            if (bPos - pos).Magnitude < 130 then
                                targetBreakable = b
                                break
                            end
                        end
                    end
                end
                
                if targetBreakable then
                    noBossTimer = 0
                    setStatus("Attacking: " .. tostring(targetBreakable:GetAttribute("BreakableID")))
                    
                    local bUID = targetBreakable:GetAttribute("BreakableUID")
                    local bPos = targetBreakable:GetPivot().Position
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid then humanoid:MoveTo(bPos) end
                    Network.UnreliableFire("Breakables_PlayerDealDamage", bUID)
                    for _, pet in pairs(activePets) do
                        if pet.cpet then pet:SetTarget(targetBreakable) end
                    end
                else
                    noBossTimer = noBossTimer + 0.5
                    setStatus("Waiting for Boss to respawn... (" .. math.floor(noBossTimer) .. "s)")
                    if noBossTimer > 120 then
                        setStatus("Boss took too long to respawn. Server hopping...")
                        serverHop("Boss didn't respawn. Hopping...")
                        task.wait(5)
                    end
                end
            end
        else
            setStatus("Boss Room lost. Restarting scan...")
            _G.AutoMiniBoss = false
            _G.IsScanning = false
        end
    end
end)

