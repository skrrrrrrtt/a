--  INVENTORY WATCHER
-- ──────────────────────────────────────────────────────────
local function watchInventory(stats)
    local prevSnapshot = {}

    local function snapInventory()
        -- try DataService inventory key
        local inv = dsGet("inventory", nil)
        if type(inv)~="table" then inv = dsGet("items", nil) end
        if type(inv)~="table" then inv = dsGet("pets",  nil) end
        return inv
    end

    local function flattenSnapshot(inv)
        local out = {}
        if type(inv)~="table" then return out end
        for k, v in pairs(inv) do
            -- could be array or dict
            if type(v)=="table" then
                local id = tostring(v.id or v.name or k)
                local cnt = tonumber(v.count or v.quantity or v.amount or 1) or 1
                out[id] = (out[id] or 0) + cnt
            elseif type(v)=="number" then
                out[tostring(k)] = v
            end
        end
        return out
    end

    -- also watch for item-obtained remote events
    local function hookRemotes()
        for _, child in pairs(RS.Packages._Index["leifstout_networker@0.3.1"].networker._remotes:GetChildren()) do
            if child.Name:lower():find("inventory") or child.Name:lower():find("item") then
                local re = child:FindFirstChildWhichIsA("RemoteEvent")
                if re then
                    re.OnClientEvent:Connect(function(method, data)
                        if type(method)=="string" and (method:lower():find("add") or method:lower():find("obtain") or method:lower():find("give")) then
                            if type(data)=="table" then
                                local val = estimateItemValue(data)
                                if val >= getgenv().Config["Webhook Threshold"] then
                                    local name = tostring(data.id or data.name or data.type or "Unknown Item")
                                    stats.rares = stats.rares + 1
                                    table.insert(stats.rareLog, 1, {name=name, value=val, time=timestamp()})
                                    if #stats.rareLog > 8 then table.remove(stats.rareLog) end
                                    sendRareAlert(name, val)
                                    print("[RARE] Got:", name, "~", fmt(val))
                                end
                            end
                        end
                    end)
                end
            end
        end
    end
    pcall(hookRemotes)

    -- polling fallback
    spawn(function()
        local init = snapInventory()
        if init then prevSnapshot = flattenSnapshot(init) end
        while true do
            wait(5)
            pcall(function()
                local current = snapInventory()
                if not current then return end
                local flat = flattenSnapshot(current)
                for id, count in pairs(flat) do
                    local prev = prevSnapshot[id] or 0
                    if count > prev then
                        -- new item detected
                        local itemData = {id=id, name=id}
                        local val = estimateItemValue(itemData)
                        if val >= getgenv().Config["Webhook Threshold"] then
                            stats.rares = stats.rares + 1
                            table.insert(stats.rareLog, 1, {name=id, value=val, time=timestamp()})
                            if #stats.rareLog > 8 then table.remove(stats.rareLog) end
                            sendRareAlert(id, val, "qty: "..(count-prev))
                            print("[RARE] Detected:", id, "~", fmt(val))
                        end
                    end
                end
                prevSnapshot = flat
            end)
        end
    end)
end


