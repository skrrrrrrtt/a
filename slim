--  ITEM VALUE TABLE  (Slime RNG rarity estimates)
-- ──────────────────────────────────────────────────────────
local ITEM_VALUES = {
    -- by rarity tag in item name / type
    basic    = 0,
    big      = 50000,        -- 50K
    huge     = 50000000,     -- 50M
    shiny    = 25000000,     -- 25M
    inverted = 500000000,    -- 500M
    -- composite
    shinybig      = 2500000,
    shinyhuge     = 2500000000,
    invertedBig   = 25000000,
    invertedHuge  = 5000000000,
}

local function estimateItemValue(itemData)
    -- itemData: table with fields like {id, name, type, rarity, ...}
    if type(itemData) ~= "table" then return 0 end
    local name = tostring(itemData.id or itemData.name or itemData.type or ""):lower()
    -- check composite first
    if name:find("inverted") and name:find("huge") then return ITEM_VALUES.invertedHuge end
    if name:find("shiny")    and name:find("huge") then return ITEM_VALUES.shinyhuge    end
    if name:find("inverted") and name:find("big")  then return ITEM_VALUES.invertedBig  end
    if name:find("shiny")    and name:find("big")  then return ITEM_VALUES.shinybig     end
    -- single rarity
    if name:find("inverted") then return ITEM_VALUES.inverted end
    if name:find("shiny")    then return ITEM_VALUES.shiny    end
    if name:find("huge")     then return ITEM_VALUES.huge     end
    if name:find("big")      then return ITEM_VALUES.big      end
    -- explicit value field
    if itemData.value and type(itemData.value)=="number" then return itemData.value end
    if itemData.rap   and type(itemData.rap)=="number"   then return itemData.rap   end
    return 0
end

