local function findEnemyRoot(folder)
    for _, e in pairs(folder:GetChildren()) do
        if e:IsA("Model") then
            local r = e.PrimaryPart or e:FindFirstChild("HumanoidRootPart") or e:FindFirstChild("RootPart")
                   or e:FindFirstChild("SlimeBody") or e:FindFirstChild("Torso")
            if not r then
                for _, d in ipairs(e:GetDescendants()) do
                    if d:IsA("BasePart") then r=d; break end
                end
            end
            if r then return r end
        elseif e:IsA("BasePart") then return e end
    end
end

