-- ──────────────────────────────────────────────────────────
local webhookQueue  = {}
local webhookBusy   = false
local RATE_LIMIT    = 2.5  -- seconds between sends

local function colorFromValue(v)
    if v >= 1e9  then return 16711918 end   -- gold
    if v >= 1e8  then return 16753920 end   -- orange
    if v >= 5e7  then return 5763719  end   -- green
    return 3447003                           -- blue
end

local function queueWebhook(payload)
    table.insert(webhookQueue, payload)
end

local function webhookWorker()
    while true do
        if #webhookQueue > 0 and not webhookBusy then
            webhookBusy = true
            local payload = table.remove(webhookQueue, 1)
            local url = getgenv().Config["Webhook URL"]
            if url and url ~= "YOUR_WEBHOOK_URL_HERE" then
                pcall(function()
                    local reqFn = (syn and syn.request) or (http and http.request) or request
                    reqFn({
                        Url     = url,
                        Method  = "POST",
                        Headers = {["Content-Type"]="application/json"},
                        Body    = HttpService:JSONEncode(payload),
                    })
                end)
            end
            wait(RATE_LIMIT)
            webhookBusy = false
        else
            wait(0.5)
        end
    end
end

