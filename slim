-- ──────────────────────────────────────────────────────────
local function startAutoRebirth(stats)
    spawn(function()
        while true do
            if getgenv().Config["Auto Rebirth"] and getGoop() >= getRebirthCost() then
                stats.action = "rebirthing"
                invoke("RebirthService", "requestRebirth")
                stats.rebirths = stats.rebirths + 1
                wait(1)
            else
                local g,c = getGoop(), getRebirthCost()
                local pct = c>0 and math.floor(g/c*100) or 0
                stats.action = "saving goop  "..fmt(g).."/"..fmt(c).."  ("..pct.."%)"
                wait(0.5)
            end
        end
    end)
end

local rollTimes = {}   -- for RPM
local function startAutoRoll(stats)
    spawn(function()
        local r = getRemote("RollService")
        while true do
            if getgenv().Config["Auto Roll"] and r then
                pcall(function() r:InvokeServer("requestRoll") end)
                stats.rolls = stats.rolls + 1
                -- track for RPM
                local now = tick()
                table.insert(rollTimes, now)
                while rollTimes[1] and (now-rollTimes[1]) > 60 do table.remove(rollTimes,1) end

                stats.action = "rolling  ["..fmt(stats.rolls).."]"
                if getgenv().Config["Auto Equip Best"] then
                    pcall(function() invoke("InventoryService","requestEquipBest") end)
                end
            end
            wait(getgenv().Config["Roll Interval(S)"] or 0.35)
        end
    end)
end

local function startAutoClaim(stats)
    spawn(function()
        local types = {"basic","big","huge","shiny","inverted"}
        while true do
            if getgenv().Config["Claim Rewards"] then
                stats.action = "claiming rewards"
                for _, t in ipairs(types) do invoke("IndexService","requestClaimReward",t) end
                fire("LikeGroupService","requestConfirmPrompt")
            end
            wait(30)
        end
    end)
end

local function startAutoUpgrade(stats)
    loadCache()
    spawn(function()
        while true do
            if getgenv().Config["Auto Buy Upgrades"] then
                local coins = getCoins()
                for _, item in ipairs(upgradesWithCost) do
                    local id = item[1]
                    if not isBlacklisted(id) and not isOwned(id) and coins >= item[2] then
                        if tryBuyUpgrade(id, coins) then
                            stats.upgrades = stats.upgrades + 1
                            stats.action = "bought  "..id
                            coins = getCoins()
                            wait(0.15)
                        end
                    end
                end
            end
            wait(2)
        end
    end)
end

local function startAutoBuyZones(stats)
    spawn(function()
        while true do
            if getgenv().Config["Auto Buy Zones"] then
                local cur = getMaxZone()
                local nxt = cur + 1
                local price = getZonePrice(nxt)
                local coins = getCoins()
                if price and coins >= price then
                    local ok = pcall(function()
                        local r = getRemote("ZonesService")
                        if r then r:InvokeServer("requestPurchaseZone") end
                    end)
                    if ok then
                        stats.zones = stats.zones + 1
                        stats.action = "unlocked zone "..nxt
                        wait(0.5)
                        teleportToZone(getMaxZone())
                    end
                end
            end
            wait(0.5)
        end
    end)
end

local function startTeleportLoop(stats)
    spawn(function()
        local lastZoneTP = 0
        while true do
            teleportToEnemy()
            teleportToLoot()
            if tick()-lastZoneTP > 30 then
                local z = getMaxZone()
                if z > 1 then teleportToZone(z) end
                lastZoneTP = tick()
            end
            wait(1)
        end
    end)
end

local function startAutoBoost(stats)
    if not getgenv().Config["Auto Use Boosts"] then return end
    spawn(function()
        while true do
            for _, bt in ipairs(boostTypes) do
                useBoostIfNeeded(bt, stats)
                wait(0.3)
            end
            wait(30)
        end
    end)
end

local function claimOffline()
    if G.offlineClaimed then return end
    pcall(function() invoke("OfflineEarningsService","requestClaim") end)
    G.offlineClaimed = true
end

local function startOptimization()
    if not getgenv().Config["Delete Unnecessary"] then return end
    local function del()
        for _, child in pairs(WS:GetChildren()) do
            if child.Name:match("^Gameplay%d+$") then
                local sl = child:FindFirstChild("Slimes")
                if sl then pcall(function() sl:Destroy() end) end
            end
        end
        for _, n in ipairs({"Leaderboards","Zones"}) do
            local f = WS:FindFirstChild(n)
            if f then pcall(function() f:Destroy() end) end
        end
    end
    del()
    spawn(function() while true do wait(5); del() end end)
end

