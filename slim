                -- session
                refs["rolls"].Text = fmt(stats.rolls)
                refs["srbs"].Text  = fmt(stats.rebirths)
                refs["supg"].Text  = fmt(stats.upgrades)
                refs["szon"].Text  = fmt(stats.zones)
                refs["rares"].Text = fmt(stats.rares)

                -- RPM
                local rpm = #rollTimes
                refs["rpm"].Text  = tostring(rpm)

                -- rebirth cost card
                local canRB = goop >= rbcost
                refs["rbcost"].Text         = fmt(rbcost)
                refs["rbcost"].TextColor3   = canRB and GOOD or VAL
                refs["rbcostsub"].Text      = canRB and "READY  ↑" or (fmt(goop).." / "..fmt(rbcost))
                refs["rbcostsub"].TextColor3= canRB and GOOD or DIM

                -- goop bar
                local pct = rbcost>0 and math.min(1, goop/rbcost) or 0
                local pctPrint = math.floor(pct*100)
                refs["progPct"].Text         = pctPrint.."%"
                refs["progPct"].TextColor3   = pct>=1 and GOOD or VAL
                refs["barFill"].Size         = UDim2.new(pct,0,1,0)
                refs["barFill"].BackgroundColor3 = pct>=1 and GOOD or TEAL
                refs["barSub"].Text          = fmt(goop).." / "..fmt(rbcost)

                -- top bar
                statusL.Text = stats.action
                metaL.Text   = "up "..fmtTime(uptime).."   zone "..zone

                -- boosts
                if refs["boosts"] then
                    for key, br in pairs(refs["boosts"]) do
                        local on = isBoostActive(key)
                        br.dot.BackgroundColor3 = on and (br.col or GOOD) or BAD
                        br.lbl.Text             = on and "ON" or "OFF"
                        br.lbl.TextColor3       = on and (br.col or GOOD) or DIM
                    end
                end

                -- feature dots
                if refs["feats"] then
                    for _, fr in ipairs(refs["feats"]) do
                        local on
                        if fr.cfgKey then
                            on = getgenv().Config[fr.cfgKey]
                        else
                            -- webhook check
                            on = getgenv().Config["Webhook URL"] ~= "YOUR_WEBHOOK_URL_HERE"
                        end
                        fr.dot.BackgroundColor3 = on and GOOD or BAD
                    end
                end

                -- rare log
                for i, ent in ipairs(refs["logEntries"]) do
                    local r = stats.rareLog[i]
                    if r then
                        ent.Text = r.time.."\n"..r.name.."\n~"..fmt(r.value)
                        ent.TextColor3 = GOLD
                    else
                        ent.Text="—"; ent.TextColor3=DIM
                    end
                end

                -- FPS (sampled every 15 frames to avoid overhead)
                fpsTick = fpsTick + 1
                if fpsTick >= 15 then
                    local dt = RunService.Heartbeat:Wait()
                    local fps = math.floor(1/math.max(dt,0.001))
                    refs["fps"].Text  = "FPS   "..fps
                    refs["ping"].Text = "PING  "..getPing().."ms"
                    fpsTick = 0
                end
            end)
            wait(1)
        end
    end)

    -- blink dot
    spawn(function()
        while true do
            liveDot.BackgroundColor3=GOOD; wait(0.85)
            liveDot.BackgroundColor3=CARD; wait(0.25)
        end
    end)
end

