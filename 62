-- Crypto Trader v3 | Street Life Remastered

local RS  = game:GetService("ReplicatedStorage")
local LP  = game:GetService("Players").LocalPlayer

local BUY_BELOW      = 5000
local SELL_ABOVE     = 8000
local CHECK_INTERVAL = 15

local holding      = false
local boughtAt     = 0
local currentPrice = nil

local PhoneRemote = RS:WaitForChild("Remotes"):WaitForChild("Phone")

-- catch price from server -> client
PhoneRemote.OnClientEvent:Connect(function(...)
    local args = {...}
    print("[Crypto] OnClientEvent:", table.unpack(args))
    for _, v in ipairs(args) do
        if type(v) == "number" and v >= 100 and v <= 100000 then
            currentPrice = v
            print(string.format("[Crypto] Price updated: $%d", currentPrice))
        end
        if type(v) == "table" then
            -- sometimes price is inside a table payload
            for k, val in pairs(v) do
                print(string.format("  [table] %s = %s", tostring(k), tostring(val)))
                if type(val) == "number" and val >= 100 and val <= 100000 then
                    currentPrice = val
                    print(string.format("[Crypto] Price from table: $%d", currentPrice))
                end
            end
        end
    end
end)

-- hook FireServer via namecall to also sniff outgoing args (price is in arg3)
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" and self == PhoneRemote then
        local args = {...}
        print("[Crypto] FireServer ->", table.unpack(args))
        -- arg3 is price when game fires crypto actions
        if args[1] == "Crypto" and type(args[3]) == "number" then
            currentPrice = args[3]
            print(string.format("[Crypto] Price snooped from outgoing fire: $%d", currentPrice))
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

local function triggerPriceRefresh()
    -- fire the actual actions the game uses to open crypto tab
    -- try common action names, one will stick
    for _, action in ipairs({"Crypto", "CryptoOpen", "OpenCrypto", "View"}) do
        pcall(function()
            PhoneRemote:FireServer("Crypto", action)
        end)
        task.wait(0.5)
        if currentPrice then break end
    end
end

local function buy(price)
    print(string.format("[Crypto] BUYING at $%d", price))
    PhoneRemote:FireServer("Crypto", "Purchase", price)
    holding = true
    boughtAt = price
end

local function sell(price)
    print(string.format("[Crypto] SELLING at $%d | Profit: +$%d", price, price - boughtAt))
    PhoneRemote:FireServer("Crypto", "Sell", price)
    holding = false
    boughtAt = 0
end

task.spawn(function()
    print("[Crypto] Trader v3 started — waiting for price...")

    -- wait for first price to come naturally (player opens phone)
    -- or force a refresh
    task.wait(3)
    triggerPriceRefresh()

    while true do
        if not currentPrice then
            print("[Crypto] Still no price — open the Phone > Crypto tab once manually")
            task.wait(CHECK_INTERVAL)
            triggerPriceRefresh()
            continue
        end

        print(string.format("[Crypto] ---- Price: $%d | Holding: %s | Bought at: $%d ----",
            currentPrice, tostring(holding), boughtAt))

        if not holding then
            if currentPrice <= BUY_BELOW then
                buy(currentPrice)
            else
                print(string.format("[Crypto] Too high ($%d > $%d), waiting for dip...", currentPrice, BUY_BELOW))
            end
        else
            if currentPrice >= SELL_ABOVE then
                sell(currentPrice)
            else
                print(string.format("[Crypto] Holding... want $%d, currently $%d (bought $%d)",
                    SELL_ABOVE, currentPrice, boughtAt))
            end
        end

        task.wait(CHECK_INTERVAL)
        triggerPriceRefresh()
    end
end)
