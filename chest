-- ============================================================
-- STEP 1: Room-by-room scanning (like reference script)
-- Instead of flying a snake path (which drifts downward),
-- we teleport to each room's position and use RequestStreaming
-- to load surrounding chunks, just like the reference script.
-- ============================================================
setStatus("⟳  Waiting for rooms to load...", Color3.fromRGB(160, 120, 220))

while #root:GetChildren() < 5 do
    task.wait(0.5)
end

local foundBossRoom = nil
local visitedRooms = {}
local scannedRooms = {}

-- Collect all rooms first
local function collectRooms()
    for _, room in ipairs(root:GetChildren()) do
        local roomUID = room:GetAttribute("RoomUID")
        if roomUID and not visitedRooms[roomUID] then
            local existing = false
            for _, r in ipairs(scannedRooms) do
                if r.uid == roomUID then
                    existing = true
                    break
                end
            end
            if not existing then
                table.insert(scannedRooms, {
                    uid = roomUID,
                    Id = room:GetAttribute("RoomID") or room.Name,
                    Model = room,
                    Position = room:GetPivot().Position
                })
            end
        end
    end
end

collectRooms()

hrp.Anchored = true
humanoid.PlatformStand = true

setStatus(string.format("⟳  Scanning %d rooms...", #scannedRooms), Color3.fromRGB(160, 120, 220))

-- ============================================================
-- STEP 2: Teleport room-by-room to find MiniBossRoom
-- ============================================================
local roomIdx = 0
local totalRooms = #scannedRooms

while not foundBossRoom do
    -- Get next unvisited room
    local room = nil
    for _, r in ipairs(scannedRooms) do
        if not visitedRooms[r.uid] then
            room = r
            break
        end
    end

    if not room then
        -- All visited, try collecting new rooms
        collectRooms()
        local hasNew = false
        for _, r in ipairs(scannedRooms) do
            if not visitedRooms[r.uid] then
                hasNew = true
                break
            end
        end
        if not hasNew then break end
        continue
    end

    visitedRooms[room.uid] = true
    roomIdx += 1

    -- Teleport to the room and request streaming (loads geometry around it)
    Network.Fire("RequestStreaming", room.Position)
    hrp.CFrame = CFrame.new(room.Position + Vector3.new(0, 3, 0))
    task.wait(SCAN_SPEED)

    local pct = roomIdx / math.max(totalRooms, 1)
    setProgress(pct)
    setStatus(string.format("⟳  Scanning... %d/%d rooms", roomIdx, #scannedRooms), Color3.fromRGB(160, 120, 220))

    -- Check if this room IS the MiniBossRoom
    if room.Id == "MiniBossRoom" then
        local roomModel = room.Model
        local breakZone = roomModel:FindFirstChild("BREAK_ZONE", true)
        local breakPos = breakZone and breakZone.Position or room.Position

        foundBossRoom = {
            room = roomModel,
            roomUID = room.uid,
            chestUID = roomModel:GetAttribute("BossChestUID"),
            position = room.Position,
            breakPos = breakPos
        }
        print("[Miniboss] FOUND MiniBossRoom at room #" .. roomIdx)
    end

    -- Re-scan for newly loaded rooms after each teleport
    collectRooms()
end

-- ============================================================
