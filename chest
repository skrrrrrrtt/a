for _, offset in ipairs({
    Vector3.new(500, 0, 0), Vector3.new(-500, 0, 0),
    Vector3.new(0, 0, 500), Vector3.new(0, 0, -500),
    Vector3.new(500, 0, 500), Vector3.new(-500, 0, -500),
