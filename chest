-- ============================================================
-- STEP 6: Auto-Tap Attack Loop
-- Uses the EXACT same method as the reference script:
-- Scans workspace.__THINGS.Breakables for models with
-- BreakableID == "Daydream Mimic Chest" (4 sub-chests, priority)
-- BreakableID == "Daydream Mimic Boss" (main boss, fallback)
-- Then fires Network.UnreliableFire("Breakables_PlayerDealDamage", bUID)
-- and sets pet targets via PlayerPet.SetTarget()
-- ============================================================
setStatus("⚔  Breaking chests (Auto-Tap & Priority)...", Color3.fromRGB(220, 100, 60))

local breakZonePos = foundBossRoom.breakPos

task.spawn(function()
    while task.wait(0.1) do
        -- Find the best target breakable (reference script method)
        local targetBreakable = nil
        local breakablesFolder = workspace.__THINGS:FindFirstChild("Breakables")
        if not breakablesFolder then continue end

        local breakables = breakablesFolder:GetChildren()

        -- PRIORITY 1: "Daydream Mimic Chest" (the 4 sub-chests)
        for _, b in ipairs(breakables) do
            local bId = b:GetAttribute("BreakableID")
            if bId == "Daydream Mimic Chest" then
                local bPos = b:GetPivot().Position
                if (bPos - breakZonePos).Magnitude < INTERACT_RANGE then
                    targetBreakable = b
                    break
                end
            end
        end

        -- PRIORITY 2: "Daydream Mimic Boss" (main boss chest, only if no sub-chests)
        if not targetBreakable then
            for _, b in ipairs(breakables) do
                local bId = b:GetAttribute("BreakableID")
                if bId == "Daydream Mimic Boss" then
                    local bPos = b:GetPivot().Position
                    if (bPos - breakZonePos).Magnitude < INTERACT_RANGE then
                        targetBreakable = b
                        break
                    end
                end
            end
        end

        -- Attack the target
        if targetBreakable then
            local bUID = targetBreakable:GetAttribute("BreakableUID")
            local bPos = targetBreakable:GetPivot().Position

            -- Walk toward the target
            if humanoid then
                humanoid:MoveTo(bPos)
            end

            -- Fire damage remote (exact same call as reference script)
            if bUID then
                Network.UnreliableFire("Breakables_PlayerDealDamage", bUID)
            end

            -- Force all pets to target this breakable (reference script does this!)
            pcall(function()
                local activePets = PlayerPet.GetByPlayer(lp)
                for _, pet in pairs(activePets) do
                    if pet.cpet then
                        pet:SetTarget(targetBreakable)
                    end
                end
            end)
        end
    end
end)

setStatus("✓  Auto-farming active! Collecting drops & breaking chests...", Color3.fromRGB(80, 220, 120))
