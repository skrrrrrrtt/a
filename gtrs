local function teleportToPosition(pos)
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") and pos then
        -- Offset Y by 3 studs so you don't get stuck inside the floor
        character.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    end
end

local function updateGUI()
    -- Clear old buttons
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local layoutOrder = 1
    
    -- Add Active Rooms
    for posKey, data in pairs(FoundRooms) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -5, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 13
        btn.TextWrapped = true
        
        -- Display name with multiplier
        local multiplierText = data.Multiplier and "x" .. data.Multiplier or "x?"
        btn.Text = "🥚 [Active] " .. data.Name .. "\n" .. multiplierText
        
        btn.LayoutOrder = layoutOrder
        layoutOrder += 1
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = btn
        
        btn.Parent = ScrollingFrame
        
        btn.MouseButton1Click:Connect(function()
            teleportToPosition(data.Position)
        end)
    end
    
    -- Add Remembered Rooms (Despawned)
    for posKey, data in pairs(RememberedPositions) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -5, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(60, 30, 30)
        btn.TextColor3 = Color3.fromRGB(255, 200, 200)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 13
        btn.TextWrapped = true
        
        -- Display name with multiplier
        local multiplierText = data.Multiplier and "x" .. data.Multiplier or "x?"
        btn.Text = "👻 [Saved] " .. data.Name .. "\n" .. multiplierText
        
        btn.LayoutOrder = layoutOrder
        layoutOrder += 1
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = btn
        
        btn.Parent = ScrollingFrame
        
        btn.MouseButton1Click:Connect(function()
            teleportToPosition(data.Position)
        end)
    end
    
    -- Update Canvas Size
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

-- ==========================================
-- CORE SCRIPT LOGIC
-- ==========================================

local function getGeneratedBackrooms()
    local things = Workspace:FindFirstChild("__THINGS")
    if not things then return nil end
    local container = things:FindFirstChild("__INSTANCE_CONTAINER")
    if not container then return nil end
    local active = container:FindFirstChild("Active")
    if not active then return nil end
    local backrooms = active:FindFirstChild("Backrooms")
    if not backrooms then return nil end
    return backrooms:FindFirstChild("GeneratedBackrooms")
end

local function getRoomCenter(room)
    if not room then return nil end
    if room:IsA("Model") then
        local totalX, totalY, totalZ = 0, 0, 0
        local count = 0
        for _, child in ipairs(room:GetDescendants()) do
            if child:IsA("BasePart") then
                totalX = totalX + child.Position.X
                totalY = totalY + child.Position.Y
                totalZ = totalZ + child.Position.Z
                count = count + 1
            end
        end
        if count > 0 then
            return Vector3.new(totalX / count, totalY / count, totalZ / count)
        end
        local pivot = room:GetPivot()
        if pivot then return pivot.Position end
    end
    if room:IsA("BasePart") then
        return room.Position
    end
    return nil
end

local function getPositionKey(pos)
    if not pos then return nil end
    return string.format("%.0f_%.0f_%.0f", pos.X, pos.Y, pos.Z)
end

-- Function to extract multiplier from room object
local function getMultiplier(obj)
    if not obj then return 1 end
    
    -- Try various possible locations for the multiplier
    local multiplier = 1
    
    -- Check direct child named "Multiplier"
    local multiplierObj = obj:FindFirstChild("Multiplier")
    if multiplierObj and multiplierObj:IsA("ValueBase") then
        return multiplierObj.Value
    end
    
    -- Check for IntValue children
    for _, child in ipairs(obj:GetChildren()) do
        if child:IsA("IntValue") and (child.Name == "Multiplier" or child.Name == "EggMultiplier" or child.Name == "Mult") then
            return child.Value
        end
    end
    
    -- Check for NumberValue children
    for _, child in ipairs(obj:GetChildren()) do
        if child:IsA("NumberValue") and (child.Name == "Multiplier" or child.Name == "EggMultiplier" or child.Name == "Mult") then
            return math.floor(child.Value)
        end
    end
    
    -- Check if it's stored in an attribute
    if obj:GetAttribute("Multiplier") then
        return obj:GetAttribute("Multiplier")
    end
    
    return 1 -- Default multiplier
end

local function scanForRooms()
    local generatedBackrooms = getGeneratedBackrooms()
    if not generatedBackrooms then return end
    
    local currentPositions = {}
    
    for _, obj in ipairs(generatedBackrooms:GetChildren()) do
        if TARGETS[obj.Name] then
            local pos = getRoomCenter(obj)
            if pos then
                local posKey = getPositionKey(pos)
                currentPositions[posKey] = true
                
                -- Extract multiplier from the room object
                local multiplier = getMultiplier(obj)
                
                if not FoundRooms[posKey] then
                    FoundRooms[posKey] = {
                        Object = obj,
                        Position = pos,
                        Name = obj.Name,
                        Multiplier = multiplier
                    }
                    IsDirty = true -- Mark GUI for update
                    print(string.format("room spawned %s | Multiplier: x%d | Position: %.0f, %.0f, %.0f", obj.Name, multiplier, pos.X, pos.Y, pos.Z))
                else
                    FoundRooms[posKey].Object = obj
                    FoundRooms[posKey].Position = pos
                    FoundRooms[posKey].Multiplier = multiplier
                end
            end
        end
    end
    
    for posKey, data in pairs(FoundRooms) do
        if not currentPositions[posKey] then
            local pos = data.Position
            if pos then
                RememberedPositions[posKey] = {
                    Position = pos,
                    Time = tick(),
                    Name = data.Name,
                    Multiplier = data.Multiplier
                }
                print(string.format("room despawned %s | Multiplier: x%d | Last Position: %.0f, %.0f, %.0f | Position Saved", data.Name, data.Multiplier or 1, pos.X, pos.Y, pos.Z))
            end
            FoundRooms[posKey] = nil
            IsDirty = true -- Mark GUI for update
        end
    end
    
    local currentTime = tick()
    for posKey, data in pairs(RememberedPositions) do
        if currentTime - data.Time > 300 then
            RememberedPositions[posKey] = nil
            IsDirty = true -- Mark GUI for update
        end
    end
    
    -- Only rebuild GUI if rooms changed
    if IsDirty then
        IsDirty = false
        updateGUI()
    end
end

local function watchGeneratedBackrooms(folder)
    if not folder then return end
    folder.ChildAdded:Connect(function(room)
        if TARGETS[room.Name] then
            task.wait(0.1)
            scanForRooms()
        end
    end)
    folder.ChildRemoved:Connect(function(room)
        if TARGETS[room.Name] then
            task.wait(0.1)
            scanForRooms()
        end
    end)
end

local function startActiveScanning()
    task.spawn(function()
        while task.wait(CONFIG.UPDATE_INTERVAL) do
            scanForRooms()
        end
    end)
end

local function initialize()
    local generatedBackrooms = getGeneratedBackrooms()
    if generatedBackrooms then
        print("Found GeneratedBackrooms")
        scanForRooms()
        watchGeneratedBackrooms(generatedBackrooms)
        startActiveScanning()
    else
        print("Waiting for GeneratedBackrooms")
        local function waitForFolder()
            local things = Workspace:FindFirstChild("__THINGS")
            if things then
                local container = things:FindFirstChild("__INSTANCE_CONTAINER")
                if container then
                    local active = container:FindFirstChild("Active")
                    if active then
                        local backrooms = active:FindFirstChild("Backrooms")
                        if backrooms then
                            backrooms.ChildAdded:Connect(function(child)
                                if child.Name == "GeneratedBackrooms" then
                                    task.wait(0.5)
                                    scanForRooms()
                                    watchGeneratedBackrooms(child)
                                    startActiveScanning()
                                end
                            end)
                        end
                    end
                end
            end
        end
        waitForFolder()
    end
end

initialize()
