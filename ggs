local function updateGUI()
    for _, child in ipairs(ScrollingFrame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    local layoutOrder = 1
    local eggCount = 0
    local doorCount = 0

    -- Section: Egg Rooms
    for posKey, data in pairs(FoundRooms) do
        eggCount += 1
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -5, 0, 40)
        btn.BackgroundColor3 = Color3.fromRGB(40, 70, 40)
        btn.TextColor3 = Color3.fromRGB(180, 255, 180)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 13
        btn.TextWrapped = true
        local multText = data.Multiplier and ("x" .. tostring(data.Multiplier)) or "x?"
        btn.Text = "🥚 " .. data.Name .. "  |  " .. multText
        btn.LayoutOrder = layoutOrder
        layoutOrder += 1

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = btn
        btn.Parent = ScrollingFrame

        btn.MouseButton1Click:Connect(function()
            teleportToPosition(data.Position)
        end)
    end

    -- Section: Locked Doors
    for posKey, data in pairs(FoundLockedDoors) do
        doorCount += 1
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -5, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(70, 40, 40)
        btn.TextColor3 = Color3.fromRGB(255, 160, 160)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 13
        btn.TextWrapped = true
        btn.Text = "🔒 " .. data.Name
        btn.LayoutOrder = layoutOrder
        layoutOrder += 1

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = btn
        btn.Parent = ScrollingFrame

        btn.MouseButton1Click:Connect(function()
            teleportToPosition(data.Position)
        end)
    end

    -- Empty state
    if eggCount == 0 and doorCount == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, -5, 0, 35)
        emptyLabel.BackgroundTransparency = 1
