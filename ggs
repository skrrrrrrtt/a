local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer
local backrooms = workspace.__THINGS.__INSTANCE_CONTAINER.Active.Backrooms.GeneratedBackrooms
local eggsFolder = RS.__DIRECTORY.Eggs["Backrooms Update 2"]

local multiToEgg = {}
for _, egg in pairs(eggsFolder:GetChildren()) do
    local multi = egg.Name:match("(%d+)x")
    local eggType = egg.Name:match("| (.+) %d+x")
    if multi and eggType then
        multiToEgg[tonumber(multi)] = eggType
    end
end

local char = lp.Character
local hrp = char and char:FindFirstChild("HumanoidRootPart")
local hum = char and char:FindFirstChildOfClass("Humanoid")
if not hrp then warn("no character") return end

hum.PlatformStand = true

local noclipConn = RunService.Stepped:Connect(function()
    for _, p in pairs(char:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end)

-- actual backrooms bounds from earlier
local minX, maxX = -4756, -3108
local minZ, maxZ = -2858, -1114
local flyY = 1620 -- room floor Y is 1607, fly just above
local stepSize = 80 -- tighter grid
local moveSpeed = 60 -- slow enough to render rooms

-- snake path
local waypoints = {}
local row = 0
local z = minZ
while z <= maxZ do
    local x = (row % 2 == 0) and minX or maxX
    local xEnd = (row % 2 == 0) and maxX or minX
    local xStep = (row % 2 == 0) and stepSize or -stepSize
    while (xStep > 0 and x <= maxX) or (xStep < 0 and x >= minX) do
        table.insert(waypoints, Vector3.new(x, flyY, z))
        x = x + xStep
    end
    z = z + stepSize
    row = row + 1
end

-- UI
local sg = Instance.new("ScreenGui")
sg.Name = "SweepUI"
sg.Parent = game:GetService("CoreGui")

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 320, 0, 80)
main.Position = UDim2.new(0.5, -160, 0, 10)
main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
main.BorderSizePixel = 0
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 8)

local lbl = Instance.new("TextLabel", main)
lbl.Size = UDim2.new(1, -10, 0, 35)
lbl.Position = UDim2.new(0, 5, 0, 5)
lbl.BackgroundTransparency = 1
lbl.TextColor3 = Color3.fromRGB(255, 200, 0)
lbl.Font = Enum.Font.GothamBold
lbl.TextSize = 13
lbl.Text = "Sweeping backrooms... 0%"

local stopBtn = Instance.new("TextButton", main)
stopBtn.Size = UDim2.new(0, 100, 0, 28)
stopBtn.Position = UDim2.new(0.5, -50, 0, 44)
stopBtn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
stopBtn.TextColor3 = Color3.new(1,1,1)
stopBtn.Font = Enum.Font.GothamBold
stopBtn.TextSize = 12
stopBtn.Text = "STOP"
stopBtn.BorderSizePixel = 0
Instance.new("UICorner", stopBtn).CornerRadius = UDim.new(0, 4)

local stopped = false
stopBtn.MouseButton1Click:Connect(function() stopped = true end)

print("Waypoints: " .. #waypoints)

-- teleport to backrooms first
hrp.CFrame = CFrame.new(Vector3.new(-3932, flyY, -1986))
task.wait(1)

-- fly through smoothly
for i, wp in pairs(waypoints) do
    if stopped then break end

    -- move step by step smoothly
    local startPos = hrp.Position
    local dist = (startPos - wp).Magnitude
    local steps = math.max(1, math.floor(dist / 10))
    for s = 1, steps do
        if stopped then break end
        hrp.CFrame = CFrame.new(startPos:Lerp(wp, s/steps))
        task.wait(10 / moveSpeed)
    end

    lbl.Text = string.format("Sweeping... %d%% (%d/%d)", math.floor(i/#waypoints*100), i, #waypoints)
end

if not stopped then
    lbl.Text = "Done! Scanning eggs..."
    task.wait(1.5)
end

noclipConn:Disconnect()
hum.PlatformStand = false

-- scan all egg rooms
local found = {}
for _, room in pairs(backrooms:GetChildren()) do
    local roomID = room:GetAttribute("RoomID")
    if roomID and roomID:lower():find("egg") then
        local multi = room:GetAttribute("EggMultiplier")
        local eggModel = room:FindFirstChild("EggModel", true)
        local part = eggModel and eggModel:FindFirstChildWhichIsA("BasePart")
        if part then
            local eggName = multiToEgg[multi] or ("Unknown " .. tostring(multi) .. "x")
            table.insert(found, {name = eggName, multi = multi or 0, part = part})
        end
    end
end

table.sort(found, function(a, b) return a.multi < b.multi end)
lbl.Text = "Found " .. #found .. " egg rooms!"

print("=== EGGS FOUND ===")
for _, e in pairs(found) do
    print(e.name .. " [" .. e.multi .. "x]")
end

task.wait(3)
sg:Destroy()

-- build TP UI after sweep
local sg2 = Instance.new("ScreenGui")
sg2.Name = "BackroomEggTP"
sg2.ResetOnSpawn = false
sg2.Parent = game:GetService("CoreGui")

local main2 = Instance.new("Frame", sg2)
main2.Size = UDim2.new(0, 300, 0, 420)
main2.Position = UDim2.new(0.5, -150, 0.5, -210)
main2.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
main2.BorderSizePixel = 0
main2.Active = true
main2.Draggable = true
Instance.new("UICorner", main2).CornerRadius = UDim.new(0, 8)

local title = Instance.new("TextLabel", main2)
title.Size = UDim2.new(1, 0, 0, 36)
title.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
title.TextColor3 = Color3.fromRGB(255, 200, 0)
title.Text = "🟡 Eggs Found: " .. #found
title.Font = Enum.Font.GothamBold
title.TextSize = 13
title.BorderSizePixel = 0
Instance.new("UICorner", title).CornerRadius = UDim.new(0, 8)

local closeBtn = Instance.new("TextButton", main2)
closeBtn.Size = UDim2.new(0, 28, 0, 28)
closeBtn.Position = UDim2.new(1, -32, 0, 4)
closeBtn.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
closeBtn.TextColor3 = Color3.new(1,1,1)
closeBtn.Text = "X"
closeBtn.Font = Enum.Font.GothamBold
closeBtn.TextSize = 13
closeBtn.BorderSizePixel = 0
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 4)
closeBtn.MouseButton1Click:Connect(function() sg2:Destroy() end)

local scroll = Instance.new("ScrollingFrame", main2)
scroll.Size = UDim2.new(1, -10, 1, -45)
scroll.Position = UDim2.new(0, 5, 0, 40)
scroll.BackgroundTransparency = 1
scroll.ScrollBarThickness = 4
scroll.BorderSizePixel = 0
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.CanvasSize = UDim2.new(0,0,0,0)
Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 4)

for _, egg in pairs(found) do
    local col
    if egg.multi >= 50 then col = Color3.fromRGB(255, 80, 80)
    elseif egg.multi >= 10 then col = Color3.fromRGB(255, 200, 50)
    else col = Color3.fromRGB(80, 200, 80) end

    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1, -8, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Text = "  " .. egg.name .. " [" .. egg.multi .. "x]"
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.BorderSizePixel = 0
    btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

    local accent = Instance.new("Frame", btn)
    accent.Size = UDim2.new(0, 5, 1, 0)
    accent.BackgroundColor3 = col
    accent.BorderSizePixel = 0
    Instance.new("UICorner", accent).CornerRadius = UDim.new(0, 4)

    btn.MouseButton1Click:Connect(function()
        local c = lp.Character
        if not c or not c:FindFirstChild("HumanoidRootPart") then return end
        if not egg.part or not egg.part.Parent then
            btn.Text = "  [GONE] " .. egg.name
            btn.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
            return
        end
        c.HumanoidRootPart.CFrame = egg.part.CFrame + Vector3.new(0, 5, 0)
        btn.BackgroundColor3 = Color3.fromRGB(20, 60, 20)
        task.delay(1, function() btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
    end)
end
