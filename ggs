    StatusLabel.TextColor3 = Color3.fromRGB(140, 200, 140)
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

-- ==========================================
-- CORE SCAN LOGIC
-- ==========================================

local function getGeneratedBackrooms()
    local things = Workspace:FindFirstChild("__THINGS")
    if not things then return nil end
    local container = things:FindFirstChild("__INSTANCE_CONTAINER")
    if not container then return nil end
    local active = container:FindFirstChild("Active")
    if not active then return nil end
    local backrooms = active:FindFirstChild("Backrooms")
    if not backrooms then return nil end
    return backrooms:FindFirstChild("GeneratedBackrooms")
end

local function getRoomCenter(room)
    if not room then return nil end
    if room:IsA("Model") then
        local pivot = room:GetPivot()
        if pivot then return pivot.Position end
        local totalX, totalY, totalZ, count = 0, 0, 0, 0
        for _, child in ipairs(room:GetDescendants()) do
            if child:IsA("BasePart") then
                totalX += child.Position.X
                totalY += child.Position.Y
                totalZ += child.Position.Z
                count += 1
            end
        end
        if count > 0 then
            return Vector3.new(totalX / count, totalY / count, totalZ / count)
        end
    end
    if room:IsA("BasePart") then return room.Position end
    return nil
end

local function getPositionKey(pos)
    if not pos then return nil end
    return string.format("%.0f_%.0f_%.0f", pos.X, pos.Y, pos.Z)
end

local function getMultiplier(obj)
    if not obj then return 1 end
    -- Check attributes first (fastest)
    local attr = obj:GetAttribute("Multiplier") or obj:GetAttribute("EggMultiplier")
    if attr then return attr end
    -- Check direct children
    for _, child in ipairs(obj:GetChildren()) do
        if child:IsA("IntValue") or child:IsA("NumberValue") then
            if child.Name:lower():find("mult") then
                return math.floor(child.Value)
            end
        end
    end
    -- Deep search (slower, only if needed)
    for _, child in ipairs(obj:GetDescendants()) do
        if (child:IsA("IntValue") or child:IsA("NumberValue")) and child.Name:lower():find("mult") then
            return math.floor(child.Value)
        end
    end
    return 1
end

local function scanForRooms()
    local generatedBackrooms = getGeneratedBackrooms()
    if not generatedBackrooms then return end

    local currentPositions = {}

    for _, obj in ipairs(generatedBackrooms:GetChildren()) do
        if TARGETS[obj.Name] then
            local pos = getRoomCenter(obj)
            if pos then
                local posKey = getPositionKey(pos)
                currentPositions[posKey] = true
                local multiplier = getMultiplier(obj)

                if not FoundRooms[posKey] then
                    FoundRooms[posKey] = { Object = obj, Position = pos, Name = obj.Name, Multiplier = multiplier }
                    IsDirty = true
                    print(string.format("[EGG] %s | x%s | %.0f, %.0f, %.0f", obj.Name, tostring(multiplier), pos.X, pos.Y, pos.Z))
                else
                    if FoundRooms[posKey].Multiplier ~= multiplier then IsDirty = true end
                    FoundRooms[posKey].Object = obj
                    FoundRooms[posKey].Position = pos
                    FoundRooms[posKey].Multiplier = multiplier
                end
            end
        end
    end

    for posKey in pairs(FoundRooms) do
        if not currentPositions[posKey] then
            FoundRooms[posKey] = nil
            IsDirty = true
        end
    end

    if IsDirty then
        IsDirty = false
        updateGUI()
    end
end

-- Locked door scanning — only inside GeneratedBackrooms to avoid lag
local function scanForLockedDoors()
    local generatedBackrooms = getGeneratedBackrooms()
    if not generatedBackrooms then return end

    local doorPositions = {}

    for _, obj in ipairs(generatedBackrooms:GetDescendants()) do
        local lowerName = obj.Name:lower()
        if (lowerName:find("lock") or lowerName:find("door")) and obj:IsA("BasePart") then
            local pos = obj.Position
            local posKey = getPositionKey(pos)
            if not doorPositions[posKey] then
                doorPositions[posKey] = true
                if not FoundLockedDoors[posKey] then
                    FoundLockedDoors[posKey] = { Position = pos, Name = obj.Name }
                    IsDirty = true
                    print(string.format("[DOOR] %s | %.0f, %.0f, %.0f", obj.Name, pos.X, pos.Y, pos.Z))
                end
            end
        end
    end

    for posKey in pairs(FoundLockedDoors) do
        if not doorPositions[posKey] then
            FoundLockedDoors[posKey] = nil
            IsDirty = true
        end
    end

    if IsDirty then
        IsDirty = false
        updateGUI()
    end
end

local function watchGeneratedBackrooms(folder)
    if not folder then return end
    folder.ChildAdded:Connect(function(room)
        if TARGETS[room.Name] then
            task.wait(0.2)
            scanForRooms()
        end
    end)
    folder.ChildRemoved:Connect(function(room)
        if TARGETS[room.Name] then
            task.wait(0.1)
            scanForRooms()
        end
    end)
end

local function startActiveScanning()
    task.spawn(function()
        while task.wait(CONFIG.UPDATE_INTERVAL) do
            scanForRooms()
        end
    end)
    task.spawn(function()
        while task.wait(2) do -- Doors scan every 2s to reduce lag
            scanForLockedDoors()
        end
    end)
end

local function initialize()
    updateGUI() -- Show empty state first
    local generatedBackrooms = getGeneratedBackrooms()
    if generatedBackrooms then
        print("[INIT] Found GeneratedBackrooms")
        scanForRooms()
        scanForLockedDoors()
        watchGeneratedBackrooms(generatedBackrooms)
        startActiveScanning()
    else
        print("[INIT] Waiting for GeneratedBackrooms...")
        StatusLabel.Text = "⏳ Waiting for backrooms..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
        local things = Workspace:FindFirstChild("__THINGS")
        if things then
            local container = things:FindFirstChild("__INSTANCE_CONTAINER")
            if container then
                local active = container:FindFirstChild("Active")
                if active then
                    local backrooms = active:FindFirstChild("Backrooms")
                    if backrooms then
                        backrooms.ChildAdded:Connect(function(child)
                            if child.Name == "GeneratedBackrooms" then
                                task.wait(0.5)
                                scanForRooms()
                                scanForLockedDoors()
                                watchGeneratedBackrooms(child)
                                startActiveScanning()
                            end
                        end)
                    end
                end
            end
        end
    end
end

initialize()
