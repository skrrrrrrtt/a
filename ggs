-- TELEPORT LOGIC
-- ==========================================

local function teleportToPosition(pos)
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp or not pos then return end

    if AutoLoadEnabled then
        -- Teleport first
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        StatusLabel.Text = "⏳ Waiting for rooms to load..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)

        -- Wait a moment for Roblox to stream in nearby parts
        task.delay(2, function()
            StatusLabel.Text = "✅ Done loading!"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            task.delay(2, function()
                StatusLabel.Text = "Scanning..."
                StatusLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
            end)
        end)
    else
        -- Just teleport immediately, no waiting
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    end
end

