local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

-- // CONFIG
local WEBHOOK_URL = "https://discord.com/api/webhooks/1496669423241789640/bh2vCOFL1ILrur3RV1BAHYIzhzhrXVxb7M4dbh8VOD9m6gUUODh4f5Ua0hfMxj6C4bAg"
local INTERVAL = 60 * 60 -- 1 hour

repeat task.wait() until game:IsLoaded()
repeat task.wait() until not LocalPlayer.PlayerGui:FindFirstChild("__INTRO")

local Save = require(ReplicatedStorage.Library.Client.Save)

-- // TRACK PREVIOUS COUNTS
local prevCounts = {
    ["Spring Bluebell Token"] = nil,
    ["Spring Egg Token"] = nil,
}

-- // GET TOKEN COUNTS
local function getTokenCounts()
    local counts = {
        ["Spring Bluebell Token"] = 0,
        ["Spring Egg Token"] = 0,
    }

    local ok, inv = pcall(function() return Save.Get().Inventory end)
    if not ok or not inv then return counts end

    for _, items in pairs(inv) do
        for _, data in pairs(items) do
            if counts[data.id] ~= nil then
                counts[data.id] += (data._am or 1)
            end
        end
    end

    return counts
end

-- // FORMAT NUMBER
local function fmt(n)
    if n >= 1e9 then return string.format("%.2fB", n/1e9)
    elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.2fK", n/1e3)
    else return tostring(n) end
end

-- // FORMAT WITH DELTA
local function fmtDelta(current, prev, isFirst)
    if isFirst or prev == nil then
        return fmt(current) .. " (first report)"
    end
    local delta = current - prev
    local sign = delta >= 0 and "+" or ""
    return string.format("%s (%s%s/h)", fmt(current), sign, fmt(delta))
end

-- // SEND WEBHOOK
local function sendWebhook(counts, isFirst)
    local bluebellLine = fmtDelta(counts["Spring Bluebell Token"], prevCounts["Spring Bluebell Token"], isFirst)
    local eggLine = fmtDelta(counts["Spring Egg Token"], prevCounts["Spring Egg Token"], isFirst)

    local body = HttpService:JSONEncode({
        embeds = {{
            title = "🌸 Spring Token Report",
            description = string.format("**%s**'s hourly token update", LocalPlayer.Name),
            color = 0x57F287,
            timestamp = DateTime.now():ToIsoDate(),
            fields = {
                {
                    name = "🫐 Bluebell Tokens",
                    value = bluebellLine,
                    inline = true
                },
                {
                    name = "🥚 Spring Egg Tokens",
                    value = eggLine,
                    inline = true
                }
            },
            footer = { text = "Next update in 1 hour" }
        }}
    })

    pcall(function()
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = body
        })
    end)

    print(string.format("[Spring Tracker] Bluebell: %s | Egg: %s", bluebellLine, eggLine))
end

-- // LOOP
local isFirst = true
while true do
    local counts = getTokenCounts()
    sendWebhook(counts, isFirst)

    prevCounts["Spring Bluebell Token"] = counts["Spring Bluebell Token"]
    prevCounts["Spring Egg Token"] = counts["Spring Egg Token"]

    isFirst = false
    task.wait(INTERVAL)
end
