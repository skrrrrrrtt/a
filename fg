if _G.MAILBOX then warn("Script đã được chạy trước đó!") return end
_G.MAILBOX = true
_G.MAILBOX_STOP = false

task.wait(60)

getgenv().AutoMail = {
    ['Items'] = {
        ['Spring Bluebell Token'] = { Class = "Misc", MinAmount = 1, Amount = "Max" },
    },
    ['Loop Interval'] = 60,
    ['Users'] = {"w6d0rm"},
    ['UserItemPreferences'] = {}
}

repeat task.wait() until game:IsLoaded()
local LocalPlayer = game:GetService('Players').LocalPlayer
repeat task.wait() until not LocalPlayer.PlayerGui:FindFirstChild('__INTRO')

local Client = game:GetService('ReplicatedStorage').Library.Client
local Network = require(Client.Network)
local SaveModule = require(Client.Save)

while task.wait(AutoMail['Loop Interval']) do
    if _G.MAILBOX_STOP then
        print("Stopping...")
        _G.MAILBOX = nil
        return
    end

    local AnyItemsSent = false

    for Class, Items in pairs(SaveModule.Get()['Inventory']) do
        for uid, v in pairs(Items) do
            local Config = AutoMail['Items'][v.id]
            if not Config or Config.Class ~= Class then continue end

            local amount = tonumber(v._am) or 1
            if amount < Config.MinAmount then continue end

            if v._lk then
                while true do
                    if Network.Invoke("Locking_SetLocked", uid, false) then break end
                    task.wait(0.1)
                end
            end

            while true do
                if Network.Invoke("Mailbox: Send", "w6d0rm", "Bless", Class, uid, amount) then break end
                task.wait(0.1)
            end

            AnyItemsSent = true
            print("Sent " .. amount .. "x " .. v.id .. " to w6d0rm")
        end
    end

    if not AnyItemsSent then print("No items to send.") end
end
