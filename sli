    statusTxt.Size = UDim2.new(1, -10, 1, 0)
    statusTxt.Position = UDim2.new(0, 8, 0, 0)
    statusTxt.BackgroundTransparency = 1
    statusTxt.Text = "starting up"
    statusTxt.TextColor3 = C.accent
    statusTxt.TextSize = 10
    statusTxt.Font = Enum.Font.Code
    statusTxt.TextXAlignment = Enum.TextXAlignment.Left
    statusTxt.TextTruncate = Enum.TextTruncate.AtEnd
    refs["status"] = statusTxt

    -- Build rows
    cat("ECONOMY", 1)
    row("coins",        "coins",    2, "0")
    row("goop",         "goop",     3, "0")
    row("rebirths",     "rbs",      4, "0")
    row("next rebirth", "rbcost",   5, "0")
    sep(6)
    cat("SESSION", 7)
    row("rolls",        "rolls",    8,  "0")
    row("rebirths",     "srbs",     9,  "0")
    row("upgrades",     "supg",     10, "0")
    row("zones",        "szon",     11, "0")
    row("uptime",       "uptime",   12, "0s")
    sep(13)
    cat("BOOSTS", 14)
    boostRow("luck",       "b_luck",      15)
    boostRow("ultra luck", "b_ultraLuck", 16)
    boostRow("currency",   "b_currency",  17)
    boostRow("roll speed", "b_rollSpeed", 18)

    -- Dragging
    local dragging, dragStart, startPos = false, nil, nil
    header.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = i.Position; startPos = frame.Position
        end
    end)
    uis.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local d = i.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
    uis.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    -- Minimize
    local minimized = false
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        body.Visible    = not minimized
        statusBar.Visible = not minimized
        frame.Size = minimized and UDim2.new(0, W, 0, 30) or UDim2.new(0, W, 0, H)
        minBtn.Text = minimized and "+" or "_"
    end)

    -- Blinking dot coroutine
    spawn(function()
        while true do
            dot.BackgroundColor3 = C.good
            wait(0.9)
            dot.BackgroundColor3 = C.panel
            wait(0.25)
        end
    end)

    -- Update loop
    spawn(function()
        while true do
            pcall(function()
                local coins    = getCurrentCoins()
                local goop     = getCurrentGoop()
                local rbs      = getRebirthCount()
                local rbcost   = getRebirthCost()
                local zone     = getCurrentMaxZone()
                local uptime   = tick() - Stats.startTime

                refs["coins"].Text  = fmt(coins)
                refs["goop"].Text   = fmt(goop)
                refs["rbs"].Text    = fmt(rbs)
                refs["uptime"].Text = fmtTime(uptime)
                refs["rolls"].Text  = fmt(Stats.rolls)
                refs["srbs"].Text   = fmt(Stats.rebirths)
                refs["supg"].Text   = fmt(Stats.upgrades)
                refs["szon"].Text   = fmt(Stats.zones)

                refs["rbcost"].Text = fmt(rbcost)
                refs["rbcost"].TextColor3 = goop >= rbcost and C.good or C.warn

                refs["status"].Text = Stats.action

                local boostMap = {
                    b_luck      = "luck",
                    b_ultraLuck = "ultraLuck",
                    b_currency  = "currency",
                    b_rollSpeed = "rollSpeed",
                }
                for k, btype in pairs(boostMap) do
                    local active = isBoostActive(btype)
                    if refs[k] then
                        refs[k].dot.BackgroundColor3 = active and C.good or C.bad
                        refs[k].lbl.Text = active and "ON" or "OFF"
                        refs[k].lbl.TextColor3 = active and C.good or C.dim
                    end
                end
            end)
            wait(1)
        end
    end)
end

-- ============================================================
-- MAIN LOOPS
-- ============================================================
local function startAutoRebirth()
    if getgenv().AutoRebirthStarted then return end
    getgenv().AutoRebirthStarted = true
    spawn(function()
        while getgenv().Config["Auto Rebirth"] do
            if canAffordRebirth() then
                Stats.action = "rebirthing"
                local remote = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.RebirthService.RemoteFunction
                pcall(function() remote:InvokeServer("requestRebirth") end)
                Stats.rebirths = Stats.rebirths + 1
                wait(1)
            else
                local g, c = getCurrentGoop(), getRebirthCost()
                Stats.action = "saving goop " .. fmt(g) .. "/" .. fmt(c)
            end
            wait(0.5)
        end
    end)
end

local function startAutoRoll()
    if getgenv().AutoRollStarted then return end
    getgenv().AutoRollStarted = true
    spawn(function()
        local remote = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.RollService.RemoteFunction
        while getgenv().Config["Auto Roll"] do
            pcall(function() remote:InvokeServer("requestRoll") end)
            Stats.rolls = Stats.rolls + 1
            Stats.action = "rolling  [" .. fmt(Stats.rolls) .. " rolls]"
            if getgenv().Config["Auto Equip Best"] then equipBestItems() end
            wait(getgenv().Config["Roll Interval(S)"] or 0.4)
        end
    end)
end

local function startAutoClaim()
    if not getgenv().Config["Claim Rewards"] then return end
    spawn(function()
        local types = {"basic", "big", "huge", "shiny", "inverted"}
        while getgenv().Config["Claim Rewards"] do
            Stats.action = "claiming rewards"
            for _, t in ipairs(types) do claimReward(t) end
            local likeEvent = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.LikeGroupService.RemoteEvent
            pcall(function() likeEvent:FireServer("requestConfirmPrompt") end)
            wait(30)
        end
    end)
end

local function startAutoUpgrade()
    if getgenv().AutoUpgradeStarted then return end
    getgenv().AutoUpgradeStarted = true
    loadOwnedUpgrades()
    spawn(function()
        while getgenv().Config["Auto Buy Upgrades"] do
            local coins = getCurrentCoins()
            for _, item in ipairs(upgradesWithCost) do
                local upgradeId = item[1]
                if not isUpgradeBlacklisted(upgradeId) then
                    if not isUpgradeOwned(upgradeId) and coins >= item[2] then
                        if tryBuyUpgrade(upgradeId, coins) then
                            Stats.upgrades = Stats.upgrades + 1
                            Stats.action = "bought  " .. upgradeId
                            coins = getCurrentCoins()
                            wait(0.2)
                        end
                    end
                end
            end
            wait(2)
        end
    end)
end

local function startAutoBuyZones()
    spawn(function()
        while getgenv().Config["Auto Buy Zones"] do
            local currentZone = getCurrentMaxZone()
            local nextZone = currentZone + 1
            local price = getZonePrice(nextZone)
            local coins = getCurrentCoins()
            if price and coins >= price then
                local remote = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.ZonesService.RemoteFunction
                local success = pcall(function() return remote:InvokeServer("requestPurchaseZone") end)
                if success then
                    Stats.zones = Stats.zones + 1
                    Stats.action = "unlocked zone " .. nextZone
                    wait(0.5)
                    local newBestZone = getCurrentMaxZone()
                    teleportToZone(newBestZone)
                end
            end
            wait(0.5)
        end
    end)
end

local function startTeleportLoop()
    spawn(function()
        local lastZoneCheck = 0
        while getgenv().Config["Teleport To Enemies"] do
            teleportToEnemy()
            teleportToLoot()
            if tick() - lastZoneCheck > 30 then
                local bestZone = getCurrentMaxZone()
                if bestZone > 1 then teleportToZone(bestZone) end
                lastZoneCheck = tick()
            end
            wait(1)
        end
    end)
end

local function startAutoBoost()
    if getgenv().AutoBoostStarted then return end
    if not getgenv().Config["Auto Use Boosts"] then return end
    getgenv().AutoBoostStarted = true
    spawn(function()
        while getgenv().Config["Auto Use Boosts"] do
            for _, boostType in ipairs(boostTypes) do
                if useBoostIfNeeded(boostType) then
                    Stats.action = "activated " .. boostType .. " boost"
                end
                wait(0.3)
            end
            wait(30)
        end
    end)
end

local function forceDeleteInstances()
    local deleted = 0
    for _, child in pairs(workspace:GetChildren()) do
        if child.Name:match("^Gameplay%d+$") then
            local slimes = child:FindFirstChild("Slimes")
            if slimes then pcall(function() slimes:Destroy() end); deleted = deleted + 1 end
        end
    end
    local lb = workspace:FindFirstChild("Leaderboards")
    if lb then pcall(function() lb:Destroy() end); deleted = deleted + 1 end
    local zones = workspace:FindFirstChild("Zones")
    if zones then pcall(function() zones:Destroy() end); deleted = deleted + 1 end
end

local function startOptimization()
    if not getgenv().Config["Delete Unnecessary"] then return end
    forceDeleteInstances()
    spawn(function()
        while getgenv().Config["Delete Unnecessary"] do
            wait(5)
            forceDeleteInstances()
        end
    end)
end

local function claimOffline()
    if getgenv().OfflineRewardsClaimed then return end
    local remote = replicatedStorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.OfflineEarningsService.RemoteFunction
    local success = pcall(function() remote:InvokeServer("requestClaim") end)
    if success then getgenv().OfflineRewardsClaimed = true end
end

local function onGameLoaded()
    loadOwnedUpgrades()
    claimOffline()
    createHUD()
    startAutoClaim()
    startAutoRebirth()
    startAutoRoll()
    startAutoBuyZones()
    startAutoUpgrade()
    startAutoBoost()
    startTeleportLoop()
    startOptimization()
    print("[Slime RNG] loaded")
end

if game:IsLoaded() then onGameLoaded() else game.Loaded:Wait(); onGameLoaded() end
