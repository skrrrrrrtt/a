local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

-- // CONFIG
local WEBHOOK_URL = "https://discord.com/api/webhooks/1496669423241789640/bh2vCOFL1ILrur3RV1BAHYIzhzhrXVxb7M4dbh8VOD9m6gUUODh4f5Ua0hfMxj6C4bAg"
local INTERVAL = 60 * 60 -- 1 hour

repeat task.wait() until game:IsLoaded()
repeat task.wait() until not LocalPlayer.PlayerGui:FindFirstChild("__INTRO")

local Save = require(ReplicatedStorage.Library.Client.Save)

local function getBluebellCount()
    local count = 0
    local inv = Save.Get().Inventory
    if not inv then return 0 end
    for _, items in pairs(inv) do
        for _, data in pairs(items) do
            if data.id == "Spring Bluebell Token" then
                count += (data._am or 1)
            end
        end
    end
    return count
end

local function sendWebhook(count)
    local body = HttpService:JSONEncode({
        embeds = {{
            title = "🌸 Bluebell Token Report",
            description = string.format("**%s** currently has **%d** Bluebell Tokens", LocalPlayer.Name, count),
            color = 0x5865F2,
            timestamp = DateTime.now():ToIsoDate(),
            footer = { text = "Next update in 1 hour" }
        }}
    })
    pcall(function()
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = body
        })
    end)
    print("Webhook sent - Bluebell count: " .. count)
end

-- send immediately then every 1h
while true do
    sendWebhook(getBluebellCount())
    task.wait(INTERVAL)
end
