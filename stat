task.spawn(function()
    while task.wait(1) do
        local Save = PlayerSave.Get()
        if Save and Save.Inventory then
            for _, info in pairs(TrackedItems) do
                local count = 0
                if info.ID == "Diamonds" then
                    count = Save.Diamonds or 0
                else
                    for category, items in pairs(Save.Inventory) do
                        for _, data in pairs(items) do
                            if data.id == info.ID then
                                count = count + (data._am or 1)
                            end
                        end
                    end
                end
                
                if Labels[info.ID] then
                    Labels[info.ID].Text = info.Name .. ": " .. FormatNumber(count)
                end
            end
        end
    end
end)
