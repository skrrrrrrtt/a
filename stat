-- Helper: Format Numbers (2,5K)
local function FormatNumber(n)
    if n >= 1000000 then
        return string.format("%.1fM", n / 1000000):gsub("%.", ",")
    elseif n >= 1000 then
        return string.format("%.1fK", n / 1000):gsub("%.", ",")
    end
    return tostring(math.floor(n))
end

